@using System;
@using Sandbox;
@using Sandbox.UI;
@using Gambit.World;
@namespace Gambit.UI
@inherits PanelComponent

@*
	Floating occupancy sign over each chess table (WorldPanel, camera-billboarded
	by ChessRing). Empty tables show nothing — the walk-up "Press E" prompt lives
	on the LobbyOverlay, and the board number is its own panel above this one.
	Display-only; no pointer-events.
*@

<root>
	@* Hidden while the local player is seated in 2D (M16): from the top-down camera this sign
	   projects onto the board (the ⬜/⬛ render as big square blocks, the names sprawl across the
	   pieces). You already have the seat names on the HUD there. *@
	@if ( _station != null && ( _station.WhiteSteamId != 0 || _station.BlackSteamId != 0 )
		&& !ChessStation.LocalNadir )
	{
		<div class="frame seats">
			<div class="seat">⬜ @( _station.WhiteName ?? "—" )</div>
			<div class="seat">⬛ @( _station.BlackName ?? "—" )</div>
			@if ( StatusLine() is string status )
			{
				<div class="game-status">@status</div>
			}
		</div>
	}
</root>

<style>
	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	.frame {
		width: 100%;
		height: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 8px;
	}

	.seat {
		font-size: 13px;
		color: rgba(255, 255, 255, 0.85);
		letter-spacing: 2px;
		text-shadow: 0px 0px 8px rgba(0, 0, 0, 0.8);
	}

	.game-status {
		font-size: 10px;
		color: #ffd60a;
		letter-spacing: 3px;
		text-shadow: 0px 0px 8px rgba(0, 0, 0, 0.8);
	}
</style>

@code
{
	ChessStation _station;
	Gambit.Game.LocalGameController _controller;

	protected override void OnStart()
	{
		_station = Components.Get<ChessStation>( FindMode.Enabled | FindMode.InSelf | FindMode.InAncestors );
		_controller = Gambit.Game.LocalGameController.For( _station );
	}

	/// <summary>"GAME IN PROGRESS" while a game runs at this table, the result
	/// once it ends (until the table resets), null when idle.</summary>
	string StatusLine()
	{
		if ( _controller == null ) return null;
		if ( _controller.GameOver ) return _controller.OverResult;
		if ( _controller.Playing ) return "GAME IN PROGRESS";
		return null;
	}

	protected override int BuildHash() =>
		System.HashCode.Combine( _station?.WhiteSteamId, _station?.WhiteName,
			_station?.BlackSteamId, _station?.BlackName, StatusLine(), ChessStation.LocalNadir );
}
