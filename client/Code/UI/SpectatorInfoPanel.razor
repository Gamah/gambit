@using System
@using System.Collections.Generic
@using System.Linq
@using Sandbox
@using Sandbox.UI
@using Gambit.Game
@using Gambit.World
@namespace Gambit.UI
@inherits PanelComponent

@*
	Walk-up control board (M5) at walk-up height on the north wall, under the giant
	floating spectator board (SpectatorWall). It shows what the board is watching — channel,
	players, time control + move number, and a live/latency status line — and prompts "Press E
	to spectate", which opens the interactive channel picker (SpectatorScreen) via the
	co-located SpectatorStation.

	Sized and floor-anchored to match the east-wall info board exactly (WallBoardGeometry) so
	every wall sign reads as one size — hence the small info-board font scale (more info, smaller
	text). Display-only: no pointer events; colours track the world light via WallTheme.

	No chess glyphs here — s&box renders some of them as colour emoji / stray floating glyphs.
	Keep this board plain text.
*@

<root>
	<div class="board" style="background-color:@WallTheme.Bg; border:1.5px solid @WallTheme.Border;">
		<div class="title" style="color:@WallTheme.Text;">SPECTATOR</div>
		<div class="divider" style="background-color:@WallTheme.Divider;"></div>

		<div class="channel" style="color:@WallTheme.AccentCss;">@Channel()</div>
		<div class="players" style="color:@WallTheme.Text;">@Players()</div>
		<div class="meta" style="color:@WallTheme.TextDim;">@Meta()</div>
		<div class="status" style="color:@LiveColor();">@LiveText()</div>

		<div class="divider" style="background-color:@WallTheme.Divider;"></div>
		<div class="hint" style="color:@WallTheme.TextFaint;">Press E to spectate</div>
	</div>
</root>

<style>
	@@import "WallTheme.scss";

	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	/* Colours are runtime-driven (WallTheme, bound inline above); only layout + static tokens
	   live here. Fixed px in the default WorldPanel's intrinsic space — the SAME font scale as
	   CenterInfoPanel so the boards match. Change these px (not the GO scale) to fix spacing. */
	.board {
		width: 100%;
		height: auto;
		flex-direction: column;
		align-items: stretch;
		justify-content: flex-start;
		padding: 9px 12px;
		border-radius: 7.5px;
		font-family: $wall-font;
		gap: 4px;
	}

	/* Fixed-height flex column: without this, items shrink to ~one line and wrapped text
	   spills under the following divider. */
	.board > div { flex-shrink: 0; }

	.title {
		font-size: 13px;
		font-weight: bold;
		letter-spacing: 3px;
		text-align: center;
	}

	.divider { height: 0.75px; margin: 1.5px 0; }

	.channel {
		font-size: 6px;
		font-weight: bold;
		letter-spacing: 1.5px;
		text-align: center;
		white-space: nowrap;
	}

	.players {
		font-size: 7px;
		font-weight: bold;
		letter-spacing: 0.5px;
		text-align: center;
		white-space: nowrap;
	}

	.meta {
		font-size: 5px;
		letter-spacing: 0.75px;
		text-align: center;
		white-space: nowrap;
	}

	.status {
		font-size: 5px;
		font-style: italic;
		letter-spacing: 0.5px;
		text-align: center;
	}

	.hint {
		font-size: 6px;
		letter-spacing: 1.5px;
		text-align: center;
		margin-top: 1px;
	}
</style>

@code
{
	SpectatorController C => SpectatorController.Instance;

	/// <summary>World units to keep between the content's bottom edge and the floor.</summary>
	[Property] public float FloorClearance { get; set; } = 30f;

	/// <summary>Headline — which table the board is mirroring.</summary>
	string Channel()
	{
		var c = C;
		return c == null ? "LIVE TABLES" : c.ChannelLabel;
	}

	/// <summary>The two players when a game is up, else a short invite.</summary>
	string Players()
	{
		var c = C;
		if ( c == null || !c.HasPosition ) return "Live tables";
		return $"{c.WhiteName}  vs  {c.BlackName}";
	}

	/// <summary>Time control and move number, when a game is up. One line, built as a
	/// single string — inline spans would become separate flex items (CLAUDE.md).</summary>
	string Meta()
	{
		var c = C;
		if ( c == null || !c.HasPosition ) return "Sit at a table to start a game";

		string move = c.MoveNumber > 0 ? $"move {c.MoveNumber}" : "";
		string tc = c.TimeControlLabel ?? "";
		if ( tc.Length == 0 ) return move;
		return move.Length == 0 ? tc : $"{tc} · {move}";
	}

	/// <summary>Liveness line.
	///
	/// <para>A table game is the host-folded FEN, so it is genuinely real-time. lichess TV
	/// is polled, and it is a different claim — saying "table game" over a game from
	/// lichess was simply wrong, and it said it because this line predates TV.</para>
	///
	/// <para>A finished game is not live at all: the result takes the line, because
	/// claiming LIVE over a board we are deliberately holding on a dead position is the
	/// one thing this line must never do.</para></summary>
	string LiveText()
	{
		var c = C;
		if ( c == null ) return "";
		if ( !c.HasPosition ) return string.IsNullOrEmpty( c.StatusText ) ? "" : c.StatusText;
		if ( !string.IsNullOrEmpty( c.FanfareText ) ) return c.FanfareText;
		return c.IsTvSource ? "LIVE · lichess TV" : "LIVE · table game";
	}

	string LiveColor()
	{
		var c = C;
		if ( c == null || !c.HasPosition ) return WallTheme.TextFaint;
		// A finished game reads as ended, not as live.
		if ( !string.IsNullOrEmpty( c.FanfareText ) ) return WallTheme.Text;
		return WallTheme.AccentCss;
	}

	protected override int BuildHash() => HashCode.Combine(
		C?.ChannelLabel, C?.WhiteName, C?.BlackName, C?.HasPosition,
		C?.MoveNumber, C?.StatusText, C?.TimeControlLabel, SettingsModel.SettingsVersion );

	protected override void OnUpdate()
	{
		// Every wall board anchors the same way, from one place — see
		// WallBoardGeometry. Do not re-derive this here.
		Gambit.World.WallBoardGeometry.FloorAnchor( this, FloorClearance );
	}
}
