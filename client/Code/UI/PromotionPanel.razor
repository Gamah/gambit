@using System;
@using Sandbox;
@using Sandbox.UI;
@using Gambit.World;
@namespace Gambit.UI
@inherits Panel

@*
	The pawn-promotion picker: a full-screen veil over the board with the four choices,
	shown while a move is parked waiting on a promotion piece (ChessBoardView.PendingPromotion).

	Split out of GameHud (M17). It has ZERO coupling to the rest of the HUD — it reads
	only the ChessBoardView and was already a full-screen sibling of the .hud column — so
	it carries its OWN style rather than leaning on GameHud's: s&box panel stylesheets do
	not reliably cascade across a nested-panel boundary (each nested Panel in the menu
	addon ships its own .scss, e.g. Toast), so a split panel that relied on its parent's
	rules would render unstyled. Nested inside GameHud's root, so it lives and dies with
	the seated HUD and needs no separate self-attach.
*@

<root>
	@{ var view = View(); }
	@if ( view?.PendingPromotion != null )
	{
		<div class="promo-veil">
			<div class="promo">
				<div class="promo-title">Promote to</div>
				<div class="promo-row">
					<div class="promo-pick" onclick="@( () => view.ChoosePromotion( 'q' ) )">♛</div>
					<div class="promo-pick" onclick="@( () => view.ChoosePromotion( 'r' ) )">♜</div>
					<div class="promo-pick" onclick="@( () => view.ChoosePromotion( 'b' ) )">♝</div>
					<div class="promo-pick" onclick="@( () => view.ChoosePromotion( 'n' ) )">♞</div>
				</div>
				<div class="promo-cancel" onclick="@( () => view.CancelPromotion() )">cancel</div>
			</div>
		</div>
	}
</root>

<style>
	/* Full-screen pass-through: only the veil (rendered when a promotion is pending)
	   opts into pointer input; z-index above the .hud column (50) so the picker is
	   never covered by it. */
	root {
		position: absolute;
		left: 0; top: 0;
		width: 100%; height: 100%;
		pointer-events: none;
		z-index: 60;
	}
	.promo-veil {
		position: absolute;
		left: 0; top: 0;
		width: 100%; height: 100%;
		justify-content: center;
		align-items: center;
		background-color: rgba(0, 0, 0, 0.35);
		pointer-events: all;
	}
	.promo {
		flex-direction: column;
		align-items: center;
		gap: 10px;
		padding: 18px 26px;
		background-color: rgba(10, 10, 14, 0.92);
		border-radius: 12px;
	}
	.promo-title { font-size: 15px; color: rgba(255, 255, 255, 0.8); }
	.promo-row { flex-direction: row; gap: 14px; }
	.promo-pick {
		font-size: 42px;
		color: white;
		padding: 4px 10px;
		border-radius: 8px;
		cursor: pointer;
		pointer-events: all;
		background-color: rgba(255, 255, 255, 0.08);
	}
	.promo-pick:hover { background-color: rgba(90, 140, 255, 0.45); }
	.promo-cancel {
		font-size: 12px;
		color: rgba(255, 255, 255, 0.5);
		cursor: pointer;
		pointer-events: all;
	}
	.promo-cancel:hover { color: white; }
</style>

@code
{
	static ChessBoardView View() => ChessStation.Active?.Components.Get<ChessBoardView>();

	/// <summary>Repaint when a promotion parks or clears — the only state this panel reads.</summary>
	protected override int BuildHash() => System.HashCode.Combine( View()?.PendingPromotion != null );
}
