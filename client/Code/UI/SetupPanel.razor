@using System;
@using System.Collections.Generic;
@using System.Threading.Tasks;
@using Sandbox;
@using Sandbox.UI;
@using Gambit.World;
@using Gambit.Game;
@using Gambit.Api;
@using Gambit.Chess;
@namespace Gambit.UI
@inherits Panel

@*
	The table's pre-game setup: the time-control picker, the four lichess start flows
	(play the person opposite, seek a stranger, challenge a named player, hand out a
	shareable link), and the Ready button. Shown whenever the table is not mid-game, so
	it covers both a fresh table and the rematch after a result.

	Split out of GameHud (M17). It is the sole owner of the seek/challenge/link
	preferences (_seekRated/_seekColor/_challengeRated/_openRated/_openColor), the
	challenge TextEntry, the seat-align-once machinery (_seatAlignPending, resolved in
	Tick), and every TimeControl.All / LichessTable call — so it carries its own state,
	its own style, and its own repaint hash. Re-resolving Controller()/Lichess() off
	ChessStation.Active per panel (rather than threading them in) is the sanctioned
	pattern: they are cheap statics keyed on the one active station.

	Carries its OWN style: s&box panel stylesheets do not reliably cross a nested-panel
	boundary (each nested Panel in the menu addon ships its own .scss), so the setup
	rules — and a private copy of the shared .button base — live here rather than in
	GameHud. The root is .setup-scoped so GameHud's bare `root { height: 100% }` (were it
	to cascade in) cannot stretch this panel over the column below it.
*@

<root class="setup">
	@{ var ctrl = Controller(); }
	@if ( ShowSetup( ctrl ) )
	{
		<div class="setup-label">TIME CONTROL</div>
		<div class="tc-list">
			@for ( int i = 0; i < TimeControl.All.Count; i++ )
			{
				var index = i; // capture per iteration — the lambda outlives the loop
				<div class="tc @( ctrl.TimeControlIndex == index ? "on" : "" )"
					onclick="@( () => ctrl.RequestSetTimeControl( index ) )">@TimeControl.All[index].Name</div>
			}
		</div>

		@* Play the computer (M19). The solo entry point — a full local game against the
		   built-in engine, needing no lichess account and no second player, at ANY time
		   control (bullet included: nothing here has to clear lichess's speed floors).
		   Shown to a seated player whose opposite side has no human, or whenever a computer
		   is already at the table (change its difficulty, or start a rematch). *@
		@if ( ctrl.CanAddBot || ctrl.HasBotOpponent )
		{
			<div class="setup-label">PLAY THE COMPUTER</div>
			<div class="seek-row">
				<div class="chip @( _botLevel == BotLevel.Easy ? "on" : "" )" onclick="@( () => SetBotLevel( BotLevel.Easy ) )">Easy</div>
				<div class="chip @( _botLevel == BotLevel.Medium ? "on" : "" )" onclick="@( () => SetBotLevel( BotLevel.Medium ) )">Medium</div>
				<div class="chip @( _botLevel == BotLevel.Hard ? "on" : "" )" onclick="@( () => SetBotLevel( BotLevel.Hard ) )">Hard</div>
			</div>
			<div class="button bot" onclick="@( () => ctrl.PlayComputer( _botLevel ) )">♟ Play the computer (@_botLevel)</div>
			@if ( ctrl.HasBotOpponent )
			{
				<div class="setup-remove" onclick="@( () => ctrl.RemoveComputer() )">Remove computer — play a person instead</div>
			}
			else
			{
				<div class="setup-hint">No account needed. Play a full game against the built-in engine.</div>
			}
		}

		@* Lichess (M8). Two ways to put a real game on your lichess record: play the
		   person opposite you, or play a stranger. Each is offered only where it could
		   actually work — the two flows have DIFFERENT speed floors (blitz for a
		   challenge, rapid for a seek), which is lichess's rule, not ours.

		   No "already engaged" branch needed: ShowSetup is false whenever lichess owns
		   the board, so this block is only ever reached with no lichess game in flight. *@
		@if ( !LichessLinkState.Linked )
		{
			<div class="setup-hint">Link a lichess account at the east wall to play real games from this table</div>
		}
		@* One lichess game at a time: lichess doesn't document permission to play concurrent
		   games through the Board API, so if you're already playing one at another table this
		   table plays locally instead. (Local two-seat games have no such limit.) *@
		else if ( LobbyPlayer.Local?.LichessGameElsewhere( Station() ) is { } busyTable )
		{
			<div class="setup-hint">You're playing a lichess game at Table @busyTable.Number — finish it before starting another. This table plays a local game.</div>
		}
		else
		{
			@* Play the person opposite you. Both seats must opt in — and gamchess
			   independently requires both to ask, so this is the agreement, not the
			   authorisation. *@
			@if ( LichessTable.CanMirror( ctrl.Tc ) )
			{
				<div class="button lichess @( LocalLichess( ctrl ) ? "on" : "" )" onclick="@( () => ctrl.ToggleLichess() )">@LichessText( ctrl )</div>
				@if ( LichessOptInHint( ctrl ) is string hint )
				{
					<div class="setup-hint">@hint</div>
				}
			}
			else
			{
				<div class="setup-hint">@LichessTable.WhyNot( ctrl.Tc )</div>
			}

			@* Or play a stranger. Needs nobody's agreement but yours: you're spending
			   your own grant on an opponent who opted in on lichess, in their own client,
			   by their own choice. Works alone at a table.

			   The HEADER is outside the CanSeek check on purpose. It used to be inside, so
			   picking Blitz made the whole section vanish and the only trace was a hint the
			   player had no reason to read — the feature looked missing rather than
			   unavailable, and that cost a round of "the board only supports two people in
			   sbox". A control that can't be offered still has to say so where it would
			   have been. *@
			<div class="setup-label">OR PLAY A RANDOM OPPONENT</div>
			@if ( LichessTable.CanSeek( ctrl.Tc ) )
			{
				<div class="seek-row">
					<div class="chip @( _seekRated ? "on" : "" )" onclick="@( () => ToggleSeekRated() )">@( _seekRated ? "Rated" : "Casual" )</div>
					<div class="chip @( _seekColor != "random" ? "on" : "" )" onclick="@( () => CycleSeekColor() )">@SeekColorText()</div>
				</div>
				<div class="button lichess" onclick="@( () => StartSeek() )">♞ Find a game on lichess</div>
				<div class="setup-hint">@SeekHint()</div>
			}
			else
			{
				<div class="setup-hint">@LichessTable.WhySeekNot( ctrl.Tc )</div>
			}

			@* Or challenge a SPECIFIC lichess player by name. Same speed floor as playing
			   the person opposite (blitz), NOT the seek's (rapid) — so it shares CanMirror,
			   and only needs a seat (for the colour it plays).

			   The header is outside the CanMirror check for the same reason the seek's is
			   outside CanSeek: a control that can't be offered still has to say so where it
			   would have been, or its absence reads as a bug. Gated on holding a seat,
			   though — with no seat there is no side to challenge with, and nothing useful
			   to say about that. *@
			@if ( LichessSeatColor( ctrl ) is string seatColor )
			{
				<div class="setup-label">OR CHALLENGE A LICHESS PLAYER</div>
				@if ( LichessTable.CanMirror( ctrl.Tc ) )
				{
					<div class="seek-row">
						<div class="chip @( _challengeRated ? "on" : "" )" onclick="@( () => ToggleChallengeRated() )">@( _challengeRated ? "Rated" : "Casual" )</div>
						<div class="chip">You play @seatColor</div>
					</div>
					<TextEntry @ref="_challengeEntry" placeholder="lichess username" class="challenge-entry" maxlength="30" />
					<div class="button lichess" onclick="@( () => StartChallenge() )">♞ Send the challenge</div>
					<div class="setup-hint">@ChallengeHint()</div>
				}
				else
				{
					<div class="setup-hint">@LichessTable.WhyNot( ctrl.Tc )</div>
				}
			}

			@* Or hand out a link an ANONYMOUS browser player opens to play YOU on this
			   board — no lichess account needed their side. gamchess seats your account in
			   an open challenge and relays your side here (server runOpen). Blitz+ only
			   (your side plays via the Board API), and the colour chip is which side YOU
			   take — picking it moves your seat to match. *@
			@if ( LichessSeatColor( ctrl ) is not null )
			{
				<div class="setup-label">OR GET A SHAREABLE LINK</div>
				@if ( LichessTable.CanMirror( ctrl.Tc ) )
				{
					<div class="seek-row">
						<div class="chip @( _openRated ? "on" : "" )" onclick="@( () => ToggleOpenRated() )">@( _openRated ? "Rated" : "Casual" )</div>
						<div class="chip @( _openColor != "random" ? "on" : "" )" onclick="@( () => CycleOpenColor() )">@OpenColorText()</div>
					</div>
					<div class="button lichess" onclick="@( () => StartOpenLink() )">♞ Get a shareable link</div>
					<div class="setup-hint">Send the link to anyone — they open it in a browser and play you here. No account needed.</div>
				}
				else
				{
					<div class="setup-hint">@LichessTable.WhyNot( ctrl.Tc )</div>
				}
			}
		}

		@if ( BothSeated() )
		{
			<div class="button ready @( LocalReady( ctrl ) ? "on" : "" )" onclick="@( () => ctrl.ToggleReady() )">@ReadyText( ctrl )</div>
		}
		else if ( ctrl.CanAddBot || ctrl.HasBotOpponent )
		{
			@* A solo player has a real action above — don't tell them to go find a person. *@
			<div class="setup-hint">Waiting for a second player — or play the computer above.</div>
		}
		else
		{
			<div class="setup-hint">Ready unlocks when both seats fill</div>
		}
	}
</root>

<style>
	.setup {
		flex-direction: column;
		gap: 5px;
		width: 100%;
		height: auto;
	}

	.setup-label {
		font-size: 11px;
		letter-spacing: 2px;
		color: rgba(255, 255, 255, 0.45);
		margin-top: 4px;
	}
	.tc-list { flex-direction: column; gap: 3px; }
	.tc {
		font-size: 13px;
		padding: 4px 8px;
		border-radius: 5px;
		cursor: pointer;
		pointer-events: all;
		background-color: rgba(255, 255, 255, 0.06);
		color: rgba(255, 255, 255, 0.75);
	}
	.tc:hover { background-color: rgba(255, 255, 255, 0.16); }
	.tc.on {
		background-color: rgba(90, 140, 255, 0.4);
		color: white;
	}
	.setup-hint { font-size: 12px; color: rgba(255, 255, 255, 0.45); }

	/* Shared .button base — a private copy, because GameHud's stylesheet is not
	   guaranteed to reach this nested panel (see the header comment). */
	.button {
		padding: 6px 12px;
		background-color: rgba(90, 140, 255, 0.25);
		border-radius: 6px;
		cursor: pointer;
		pointer-events: all;
		font-size: 13px;
		justify-content: center;
	}
	.button:hover { background-color: rgba(90, 140, 255, 0.45); }

	/* Play-the-computer: a violet tint, distinct from lichess's white and Ready's green. */
	.button.bot { background-color: rgba(150, 120, 235, 0.3); }
	.button.bot:hover { background-color: rgba(150, 120, 235, 0.5); }

	/* A quiet, clickable "remove computer" line — reads as a link, not a button. */
	.setup-remove {
		font-size: 12px;
		color: rgba(255, 255, 255, 0.5);
		cursor: pointer;
		pointer-events: all;
	}
	.setup-remove:hover { color: rgba(255, 180, 180, 0.9); }

	.button.ready { background-color: rgba(127, 212, 127, 0.22); }
	.button.ready:hover { background-color: rgba(127, 212, 127, 0.4); }
	.button.ready.on {
		background-color: rgba(127, 212, 127, 0.55);
		color: white;
		font-weight: bold;
	}

	/* Lichess opt-in: lichess's own black/white, so it reads as "this leaves Gambit"
	   rather than as another table control. */
	.button.lichess { background-color: rgba(240, 240, 240, 0.14); }
	.button.lichess:hover { background-color: rgba(240, 240, 240, 0.28); }
	.button.lichess.on {
		background-color: rgba(240, 240, 240, 0.8);
		color: rgba(15, 15, 15, 0.95);
		font-weight: bold;
	}

	/* Seek controls: small toggles, so the row reads as settings rather than actions. */
	.seek-row { flex-direction: row; gap: 4px; }
	.chip {
		flex-grow: 1;
		justify-content: center;
		font-size: 12px;
		padding: 4px 6px;
		border-radius: 5px;
		cursor: pointer;
		pointer-events: all;
		background-color: rgba(255, 255, 255, 0.06);
		color: rgba(255, 255, 255, 0.7);
	}
	.chip:hover { background-color: rgba(255, 255, 255, 0.16); }
	.chip.on { background-color: rgba(255, 255, 255, 0.2); color: white; }

	.challenge-entry {
		pointer-events: all;
		font-size: 13px;
		padding: 5px 7px;
		border-radius: 5px;
		background-color: rgba(0, 0, 0, 0.3);
		border: 1px solid rgba(255, 255, 255, 0.14);
		color: white;
	}
</style>

@code
{
	// ── Shared spine, re-resolved per panel off the one active station ──

	static ChessStation Station() => ChessStation.Active;
	static LocalGameController Controller() => LocalGameController.For( ChessStation.Active );
	static LichessGameController Lichess() => LichessGameController.For( ChessStation.Active );

	/// <summary>A real lichess game owns this board right now.</summary>
	static bool OnLichess() => Lichess() is { Engaged: true };

	/// <summary>A lichess game is running (or being started) here — as opposed to one
	/// whose result is merely still on display.</summary>
	static bool LichessInFlight() =>
		OnLichess() && !( Lichess()?.State?.finished ?? false );

	/// <summary>The setup block shows whenever the table isn't mid-game — a fresh table,
	/// or one showing a result and open to a rematch.
	///
	/// <para>Also hidden while a lichess game is IN FLIGHT. A SEEK starts no local game,
	/// so <c>ctrl.Playing</c> stays false for its whole duration — without this, Ready
	/// would sit there clickable under a live lichess game and start a second, local one
	/// behind it.</para>
	///
	/// <para>"In flight", not "on screen": the lichess controller deliberately stays
	/// engaged while the result is displayed, so gating on OnLichess() alone would leave a
	/// finished lichess game with no time control and no Ready — the pair would have to
	/// stand up and re-sit to play again.</para></summary>
	static bool ShowSetup( LocalGameController ctrl ) =>
		ctrl != null && !ctrl.Playing && !LichessInFlight();

	static bool BothSeated() =>
		Station() is { } s && s.WhiteSteamId != 0 && s.BlackSteamId != 0;

	static bool LocalReady( LocalGameController ctrl ) =>
		ctrl?.LocalSeat is { } seat && ctrl.ReadyFor( seat );

	static bool LocalLichess( LocalGameController ctrl ) =>
		ctrl?.LocalSeat is { } seat && ctrl.LichessFor( seat );

	static string ReadyText( LocalGameController ctrl )
	{
		if ( ctrl?.LocalSeat == null ) return "Ready";
		return LocalReady( ctrl ) ? "Ready ✓ (click to cancel)" : "Ready";
	}

	static string LichessText( LocalGameController ctrl ) =>
		LocalLichess( ctrl )
			? $"♞ Playing on lichess as {LichessLinkState.Username} ✓ (click to cancel)"
			: "♞ Play this game on lichess";

	/// <summary>What the opt-in is waiting on, or null when there's nothing to say.
	/// Deliberately honest about the one thing a player can't see: whether the person
	/// opposite has a lichess account at all.</summary>
	static string LichessOptInHint( LocalGameController ctrl )
	{
		if ( ctrl == null || !LocalLichess( ctrl ) ) return null;
		if ( ctrl.BothWantLichess ) return "Both in — this game will be played on lichess for real.";
		return "Waiting for your opponent to opt in too. They need a linked lichess account.";
	}

	/// <summary>The colour the local player would challenge with — their seat's side — or
	/// null if they hold no seat at this table (so the challenge UI is hidden, because we'd
	/// have no colour to ask lichess for). "White"/"Black" as a display string; the
	/// controller re-derives the seat itself rather than trusting this.</summary>
	static string LichessSeatColor( LocalGameController ctrl )
	{
		if ( ctrl?.LocalSeat is not { } seat ) return null;
		return seat == ChessSeat.White ? "White" : "Black";
	}

	// ── Computer opponent (this player's chosen difficulty; doesn't outlive the HUD) ──

	BotLevel _botLevel = BotLevel.Medium;

	void SetBotLevel( BotLevel level ) { _botLevel = level; StateHasChanged(); }

	// ── Seek preferences (this player's, for their next seek; don't outlive the HUD) ──

	bool _seekRated;
	string _seekColor = "random";

	void ToggleSeekRated() { _seekRated = !_seekRated; StateHasChanged(); }

	void CycleSeekColor()
	{
		_seekColor = _seekColor switch { "random" => "white", "white" => "black", _ => "random" };
		StateHasChanged();
	}

	string SeekColorText() => _seekColor switch
	{
		"white" => "Play White",
		"black" => "Play Black",
		_ => "Either colour",
	};

	string SeekHint()
	{
		if ( _seekRated ) return "Rated: this will move your real lichess rating.";
		return "Casual: it won't touch your lichess rating.";
	}

	/// <summary>We send NO ratingRange, ever, and that is the strongest option rather than
	/// the laziest — see CLAUDE.md's ratingRange trap. lila treats an omitted range as "no
	/// preference" and substitutes a Gaussian band centred on the player's REAL rating, so
	/// lichess centres the pool on them for free, with no scope and no rating stored our
	/// side.</summary>
	void StartSeek()
	{
		Lichess()?.RequestSeek( _seekRated, color: _seekColor );
		// lichess assigns the side when matched — align the seat to it at game start.
		_seatAlignPending = true;
		StateHasChanged();
	}

	// The username the player is challenging, and whether that game is rated. A challenge
	// takes the SEAT's colour (a physical board has sides), so there is no colour chip
	// here — unlike a seek.
	TextEntry _challengeEntry;
	bool _challengeRated;

	void ToggleChallengeRated() { _challengeRated = !_challengeRated; StateHasChanged(); }

	void StartChallenge()
	{
		string name = _challengeEntry?.Text?.Trim();
		if ( string.IsNullOrWhiteSpace( name ) ) return;
		Lichess()?.RequestChallenge( name, _challengeRated );
		// A challenge plays the seat's colour, so this is normally a no-op — but harmless,
		// and keeps every lichess-start path aligning the seat the same way.
		_seatAlignPending = true;
		if ( _challengeEntry != null ) _challengeEntry.Text = "";
		StateHasChanged();
	}

	string ChallengeHint()
	{
		if ( _challengeRated ) return "Rated: this will move your real lichess rating.";
		return "They'll get a challenge on lichess to accept or decline.";
	}

	// ── Shareable link (an anonymous browser opponent plays this player on the board) ──
	// Colour is which side WE take; the opponent's link is the opposite side. Picking a
	// side moves our seat to it (MoveSeatToColor); a colour lichess ASSIGNS (a random link,
	// or ANY seek) is settled when the game starts and moved then (_seatAlignPending,
	// resolved in Tick) — that is why sitting White and being matched Black rotates you.
	bool _openRated;
	string _openColor = "random";
	bool _seatAlignPending;

	void ToggleOpenRated() { _openRated = !_openRated; StateHasChanged(); }

	void CycleOpenColor()
	{
		_openColor = _openColor switch { "random" => "white", "white" => "black", _ => "random" };
		MoveSeatToColor( _openColor );
		StateHasChanged();
	}

	string OpenColorText() => _openColor switch
	{
		"white" => "You play White",
		"black" => "You play Black",
		_ => "Either colour",
	};

	void StartOpenLink()
	{
		Lichess()?.RequestOpenLink( _openRated, _openColor );
		_seatAlignPending = true; // move to the assigned side once the game starts (random)
		StateHasChanged();
	}

	/// <summary>Move the local player's seat to the side they picked, so the board shows
	/// them where they'll play. white/black only — "random" is settled at game start.
	/// No-op if the target seat is taken or there's a live game (see LobbyPlayer.SwitchSeat).</summary>
	static void MoveSeatToColor( string color )
	{
		var seat = color switch
		{
			"white" => ChessSeat.White,
			"black" => ChessSeat.Black,
			_ => (ChessSeat?)null,
		};
		if ( seat is { } s ) LobbyPlayer.Local?.SwitchSeat( s );
	}

	/// <summary>Resolve the seat-align-once request set by a seek/challenge/link start.
	///
	/// <para>Any lichess game where lichess ASSIGNS the side (a seek, a random link) can
	/// put us on the opposite colour from the seat we sat at — sit White, matched Black.
	/// Move our seat to the assigned side once the game starts and we know it. One-shot;
	/// also cleared if the request never became a game. (A picked colour was already moved
	/// at pick time; this then no-ops.)</para>
	///
	/// <para>Runs in Tick (not the start action) because the assignment isn't known until
	/// the game begins, and this panel keeps ticking through the seek even though its setup
	/// content stops rendering (ShowSetup goes false the moment a game is in flight).</para></summary>
	public override void Tick()
	{
		if ( _seatAlignPending && Lichess() is { } lc )
		{
			if ( lc is { Playing: true, LocalSeat: { } seat } )
			{
				LobbyPlayer.Local?.SwitchSeat( seat );
				_seatAlignPending = false;
			}
			else if ( !lc.Engaged )
			{
				_seatAlignPending = false;
			}
		}
	}

	/// <summary>Repaint triggers — everything this panel's markup reads. Flat, unlike the
	/// nested tree GameHud needs, which is why the username finally has a home: LichessText
	/// renders <c>LichessLinkState.Username</c>, and hashing only <c>.Linked</c> (as the old
	/// combined GameHud hash did) left a username change unpainted until something else
	/// forced a repaint. It survived on luck — the username arrives as Linked flips — and
	/// this is the fix the split was for.</summary>
	protected override int BuildHash()
	{
		var ctrl = Controller();
		return System.HashCode.Combine(
			ctrl?.Playing, OnLichess(), Lichess()?.State?.finished, ctrl?.TimeControlIndex,
			BothSeated(), ctrl?.LocalSeat,
			System.HashCode.Combine(
				ctrl?.WhiteReady, ctrl?.BlackReady, ctrl?.WhiteLichess, ctrl?.BlackLichess,
				ctrl?.BothWantLichess, LichessLinkState.Linked, LichessLinkState.Username,
				// The one-game gate: repaint when a lichess game starts/ends at another table.
				LobbyPlayer.Local?.LichessGameElsewhere( Station() )?.Number ),
			System.HashCode.Combine( _seekRated, _seekColor, _challengeRated, _openRated, _openColor,
				// Computer opponent: repaint when one is added/removed at this table, when the
				// opposite seat frees up (CanAddBot), or when the player picks a difficulty.
				ctrl?.HasBotOpponent, ctrl?.CanAddBot, _botLevel ) );
	}
}
