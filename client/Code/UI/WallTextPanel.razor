@using System;
@using Sandbox;
@using Sandbox.UI;
@namespace Gambit.UI
@inherits PanelComponent

@* Single line of big centered text on a WorldPanel (wall headings). Display only. *@

<root>
	<div class="text" style="@FontStyle()">@Text</div>
</root>

<style>
	@@import "WallTheme.scss";

	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	.text {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		align-items: center;
		justify-content: center;
		text-align: center;
		/* overflow is CLIPPED at the panel edge — layout happens in the WorldPanel's
		   fixed intrinsic pixel space, so FontSize is a px value tuned to fit, not
		   derived from a measured rect (Box.Rect measurement proved unreliable here) */
		white-space: nowrap;
		font-family: $wall-font;
		font-weight: bold;
		letter-spacing: 4px;
	}
</style>

@code {
	[Property] public string Text { get; set; } = "";

	/// <summary>Font size in the panel's intrinsic pixel space — tune so Text fits
	/// the panel width; world size comes from the GO scale.</summary>
	[Property] public float FontSize { get; set; } = 20f;

	string FontStyle() => $"font-size: {FontSize:0.#}px; color: {WallTheme.Text};";

	protected override int BuildHash() => HashCode.Combine( Text, FontSize, SettingsModel.SettingsVersion );
}
