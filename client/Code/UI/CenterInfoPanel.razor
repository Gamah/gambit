@using System.Collections.Generic;
@using System.Linq;
@using Sandbox;
@using Sandbox.UI;
@using Gambit.World;
@namespace Gambit.UI
@inherits PanelComponent

@*
	Display-only info board mounted on the east wall (see InfoWall). No pointer events.

	A SIGNPOST, NOT A PAGE. It used to be the short version of InfoScreen's Welcome
	page and it is where this repo learned that duplicated copy rots: it described a
	lobby where the first sitter was usually White and where saved games were "coming
	soon", long after neither was true, because nobody re-reads a wall. Saying one
	thing — where the answers are — is the only version that cannot go stale.

	So DON'T restore the summary. If a fact belongs to players, it belongs in
	InfoScreen's Welcome branch (press E), which is one place to keep honest instead
	of two. See CLAUDE.md.
*@

<root>
	<div class="board" style="background-color:@WallTheme.Bg; border:1.5px solid @WallTheme.Border;">
		<div class="title" style="color:@WallTheme.Text;">@WallTheme.BrandTitle</div>
		<div class="tagline" style="color:@WallTheme.TextFaint;">@WallTheme.Tagline</div>

		<div class="divider" style="background-color:@WallTheme.Divider;"></div>

		<div class="prompt" style="color:@WallTheme.AccentCss;">PRESS E FOR HELP / INFO</div>
	</div>
</root>

<style>
	@@import "WallTheme.scss";

	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	/* Shared WallTheme palette (see WallTheme.scss); geometry stays board-specific —
	   layout happens in the WorldPanel's fixed intrinsic pixel space (sub-px borders),
	   so this board keeps its own small radii/sizes, not the theme radius. The GO scale
	   only sizes/stretches the rendered quad; change these px (not the GO scale) to fix
	   blank space or overflow.

	   height:auto and a bottom anchor mean this board is now SHORT — it holds three
	   lines, not a page. That's the signpost working, not a layout bug to pad out. */
	.board {
		width: 100%;
		height: auto;
		flex-direction: column;
		align-items: stretch;
		justify-content: flex-start;
		padding: $wall-pad;
		border-radius: $wall-radius;
		font-family: $wall-font;
		gap: $wall-gap;
		/* Shrink toward the floor-anchored BOTTOM edge (see FitToHeight in OnUpdate) so a
		   down-scale keeps FloorAnchor accurate. No-op at today's three lines. */
		transform-origin: 50% 100%;
	}

	/* Fixed-height flex column: without this, items shrink to ~one line and
	   wrapped text spills under the following divider. */
	.board > div {
		flex-shrink: 0;
	}

	.title {
		font-size: $wall-fs-title;
		font-weight: bold;
		letter-spacing: 3px;
		text-align: center;
	}

	.tagline {
		font-size: $wall-fs-body;
		text-align: center;
		letter-spacing: 0.75px;
	}

	.divider {
		height: $wall-divider-h;
		margin: $wall-divider-gap 0;
	}

	/* The whole point of the board, so it is sized like it: bigger than the title,
	   which is the only other thing here. This is intrinsic panel px (see CLAUDE.md
	   — px here is not world size; the GO scale does that), calibrated against the
	   13px title rather than derived from Box.Rect, which doesn't work on a
	   WorldPanel. */
	.prompt {
		font-size: $wall-fs-hero;
		font-weight: bold;
		letter-spacing: 1.5px;
		text-align: center;
		justify-content: center;
		padding: 3px 0 1px 0;
	}
</style>

@code
{
	/// <summary>World units to keep between the content's bottom edge and the floor.
	/// <para>The calibration behind the anchor (half-extent = 18 × scale) now lives in
	/// WallBoardGeometry, since every wall board shares it. WorldPanel sizing is
	/// undocumented, so tune it there if the boards float or sink — they'll move
	/// together.</para></summary>
	[Property] public float FloorClearance { get; set; } = 60f;

	// Re-render when the world light colour (and thus the theme) changes.
	protected override int BuildHash() => SettingsModel.SettingsVersion;

	protected override void OnUpdate()
	{
		// Every wall board anchors the same way, from one place — see
		// WallBoardGeometry. Do not re-derive this here.
		Gambit.World.WallBoardGeometry.FloorAnchor( this, FloorClearance );

		// Keep the signpost within its own board rect — sized by the board's vertical
		// space, not by content overflowing it. A no-op at today's three lines (scale 1);
		// it only engages if the board ever grows past its rect. Same fit helper the
		// engaged InfoScreen uses; bottom transform-origin (see .board) keeps FloorAnchor
		// accurate under a shrink.
		var board = Panel?.Children.FirstOrDefault();
		if ( board is not null )
			Gambit.World.WallBoardGeometry.FitToHeight( board, Panel.Box.Rect.Height );
	}
}
