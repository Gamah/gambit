@using System.Collections.Generic;
@using System.Linq;
@using Sandbox;
@using Sandbox.UI;
@using Gambit.World;
@namespace Gambit.UI
@inherits PanelComponent

@*
	Display-only info board mounted on the east wall (see InfoWall). No pointer events.
	The short version of InfoScreen's Welcome page — walk up and press E for that.

	THIS BOARD IS THE GAME'S FRONT DOOR, and it is the first thing to go stale: it
	described a lobby where the first sitter was usually White and where saved games were
	"coming soon", long after neither was true. If you change how the world behaves, this
	board and InfoScreen's Welcome branch are part of the change — see CLAUDE.md.
*@

<root>
	<div class="board" style="background-color:@WallTheme.Bg; border:1.5px solid @WallTheme.Border;">
		<div class="title" style="color:@WallTheme.Text;">TERRY'S GAMBIT</div>
		<div class="tagline" style="color:@WallTheme.TextFaint;">Chess in the lobby</div>

		<div class="divider" style="background-color:@WallTheme.Divider;"></div>

		<div class="section-header" style="color:@WallTheme.AccentCss;">HOW TO PLAY</div>
		<div class="body-text" style="color:@WallTheme.TextDim;">Walk up to either side of a chess table and press E to take that seat — you play the colour you walked up to. A friend takes the other side. Pick a time control before you start. Escape stands you up.</div>

		<div class="divider" style="background-color:@WallTheme.Divider;"></div>

		<div class="section-header" style="color:@WallTheme.AccentCss;">ALSO HERE</div>
		<div class="body-text" style="color:@WallTheme.TextDim;">Your games are saved to chess.gamah.net · Link lichess and play there for real · The north wall shows a live table, or lichess TV</div>

		<div class="discord-btn">Check out the Discord: @Gambit.World.DiscordButton.InviteCode. Press E to view &amp; copy</div>
	</div>
</root>

<style>
	@@import "WallTheme.scss";

	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	/* Shared WallTheme palette (see WallTheme.scss); geometry stays board-specific —
	   layout happens in the WorldPanel's fixed intrinsic pixel space (sub-px borders,
	   ~5px fonts), so this board keeps its own small radii/sizes, not the theme radius.
	   The GO scale only sizes/stretches the rendered quad. These px values are tuned so
	   the content fills the panel height with just a small margin under the Discord line —
	   change them (not the GO scale) to fix blank space or overflow. */
	.board {
		width: 100%;
		height: auto;
		flex-direction: column;
		align-items: stretch;
		justify-content: flex-start;
		padding: 9px 12px;
		border-radius: 7.5px;
		font-family: $wall-font;
		gap: 4px;
	}

	/* Fixed-height flex column: without this, items shrink to ~one line and
	   wrapped text spills under the following divider. */
	.board > div {
		flex-shrink: 0;
	}

	.title {
		font-size: 13px;
		font-weight: bold;
		letter-spacing: 3px;
		text-align: center;
	}

	.tagline {
		font-size: 5.5px;
		text-align: center;
		letter-spacing: 0.75px;
	}

	.divider {
		height: 0.75px;
		margin: 1.5px 0;
	}

	.section-header {
		font-size: 5px;
		font-weight: bold;
		letter-spacing: 1.5px;
	}

	.body-text {
		font-size: 5px;
		line-height: 1.4;
		white-space: pre-wrap;
	}

	.note {
		font-size: 5px;
		font-style: italic;
	}

	.discord-btn {
		justify-content: center;
		margin-top: 2px;
		padding: 4px 7px;
		background-color: rgba(88, 101, 242, 0.25);
		border: 0.75px solid rgba(88, 101, 242, 0.6);
		border-radius: 5.25px;
		font-size: 6px;
		color: rgba(255, 255, 255, 0.85);
		font-weight: bold;
	}

	.prizes-notice {
		justify-content: center;
		margin-top: 2px;
		padding: 4px 7px;
		background-color: rgba(44, 200, 20, 0.25);
		border: 0.75px solid rgba(88, 101, 242, 0.6);
		border-radius: 5.25px;
		font-size: 6px;
		color: rgba(255, 255, 255, 0.85);
		font-weight: bold;
	}
</style>

@code
{
	/// <summary>World units to keep between the content's bottom edge and the floor.
	/// <para>The calibration behind the anchor (half-extent = 18 × scale) now lives in
	/// WallBoardGeometry, since every wall board shares it. WorldPanel sizing is
	/// undocumented, so tune it there if the boards float or sink — they'll move
	/// together.</para></summary>
	[Property] public float FloorClearance { get; set; } = 60f;

	// Re-render when the world light colour (and thus the theme) changes.
	protected override int BuildHash() => SettingsModel.SettingsVersion;

	protected override void OnUpdate()
	{
		// Every wall board anchors the same way, from one place — see
		// WallBoardGeometry. Do not re-derive this here.
		Gambit.World.WallBoardGeometry.FloorAnchor( this, FloorClearance );
	}
}
