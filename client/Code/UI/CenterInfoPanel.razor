@using System.Collections.Generic;
@using System.Linq;
@using Sandbox;
@using Sandbox.UI;
@using Gambit.World;
@namespace Gambit.UI
@inherits PanelComponent

@* Display-only info board mounted on the east wall (see InfoWall). No pointer events. *@

<root>
	<div class="board" style="background-color:@WallTheme.Bg; border:1.5px solid @WallTheme.Border;">
		<div class="title" style="color:@WallTheme.Text;">TERRY'S GAMBIT</div>
		<div class="tagline" style="color:@WallTheme.TextFaint;">Chess in the lobby</div>

		<div class="divider" style="background-color:@WallTheme.Divider;"></div>

		<div class="section-header" style="color:@WallTheme.AccentCss;">HOW TO PLAY</div>
		<div class="body-text" style="color:@WallTheme.TextDim;">Walk up to either side of a chess table and press E to take that seat — first sitter is usually White. A friend can take the other side of the same board. Press Escape to stand up.</div>

		<div class="divider" style="background-color:@WallTheme.Divider;"></div>

		<div class="section-header" style="color:@WallTheme.AccentCss;">COMING SOON</div>
		<div class="body-text" style="color:@WallTheme.TextDim;">Sit at any table · Play a friend across the board · Your games are saved to chess.gamah.net</div>

		<div class="discord-btn">Check out the Discord: @Gambit.World.DiscordButton.InviteCode. Press E to view &amp; copy</div>
	</div>
</root>

<style>
	@@import "WallTheme.scss";

	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	/* Shared WallTheme palette (see WallTheme.scss); geometry stays board-specific —
	   layout happens in the WorldPanel's fixed intrinsic pixel space (sub-px borders,
	   ~5px fonts), so this board keeps its own small radii/sizes, not the theme radius.
	   The GO scale only sizes/stretches the rendered quad. These px values are tuned so
	   the content fills the panel height with just a small margin under the Discord line —
	   change them (not the GO scale) to fix blank space or overflow. */
	.board {
		width: 100%;
		height: auto;
		flex-direction: column;
		align-items: stretch;
		justify-content: flex-start;
		padding: 9px 12px;
		border-radius: 7.5px;
		font-family: $wall-font;
		gap: 4px;
	}

	/* Fixed-height flex column: without this, items shrink to ~one line and
	   wrapped text spills under the following divider. */
	.board > div {
		flex-shrink: 0;
	}

	.title {
		font-size: 13px;
		font-weight: bold;
		letter-spacing: 3px;
		text-align: center;
	}

	.tagline {
		font-size: 5.5px;
		text-align: center;
		letter-spacing: 0.75px;
	}

	.divider {
		height: 0.75px;
		margin: 1.5px 0;
	}

	.section-header {
		font-size: 5px;
		font-weight: bold;
		letter-spacing: 1.5px;
	}

	.body-text {
		font-size: 5px;
		line-height: 1.4;
		white-space: pre-wrap;
	}

	.note {
		font-size: 5px;
		font-style: italic;
	}

	.discord-btn {
		justify-content: center;
		margin-top: 2px;
		padding: 4px 7px;
		background-color: rgba(88, 101, 242, 0.25);
		border: 0.75px solid rgba(88, 101, 242, 0.6);
		border-radius: 5.25px;
		font-size: 6px;
		color: rgba(255, 255, 255, 0.85);
		font-weight: bold;
	}

	.prizes-notice {
		justify-content: center;
		margin-top: 2px;
		padding: 4px 7px;
		background-color: rgba(44, 200, 20, 0.25);
		border: 0.75px solid rgba(88, 101, 242, 0.6);
		border-radius: 5.25px;
		font-size: 6px;
		color: rgba(255, 255, 255, 0.85);
		font-weight: bold;
	}
</style>

@code
{
	/// <summary>
	/// World half-height of the panel's intrinsic rect per unit of GO Z-scale.
	/// Same calibration constant as the cabinet screens (half-extent = 18 * scale);
	/// WorldPanel sizing is undocumented, so tune in the editor if the board
	/// floats or sinks.
	/// </summary>
	[Property] public float HalfHeightPerScale { get; set; } = 18f;

	/// <summary>World units to keep between the content's bottom edge and the floor.</summary>
	[Property] public float FloorClearance { get; set; } = 60f;

	// Re-render when the world light colour (and thus the theme) changes.
	protected override int BuildHash() => SettingsModel.SettingsVersion;

	protected override void OnUpdate()
	{
		// .board is height:auto, so it can be shorter or taller than the panel's
		// intrinsic rect. Measure the content/root pixel ratio (unit-agnostic) and
		// lift the GO so the content's bottom edge sits FloorClearance above z=0.
		// The intrinsic rect is centered on the GO with content anchored at its top:
		// contentBottom = z + rootHalf - contentHeight.
		var board = Panel?.Children.FirstOrDefault();
		if ( board is null || Panel.Box.Rect.Height <= 0f ) return;

		float rootHalf = HalfHeightPerScale * WorldScale.z;
		float contentHeight = 1.5f * rootHalf * ( board.Box.Rect.Height / Panel.Box.Rect.Height );

		var pos = LocalPosition;
		pos.z = FloorClearance + contentHeight - rootHalf;
		LocalPosition = pos;
	}
}
