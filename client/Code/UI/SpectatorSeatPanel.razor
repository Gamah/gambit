@using System
@using Sandbox
@using Sandbox.UI
@using Gambit.Game
@using Gambit.World
@namespace Gambit.UI
@inherits PanelComponent

@*
	One player's tag for the spectator board — a small board that hugs a corner of the giant 3D
	spectator board: White at the bottom-right, Black at the top-left, mirroring the board below.
	Replaces the single overhead scoreboard (which tried to show both sides at once and read
	poorly from across the room).

	Display-only WorldPanel (no pointer input); colours track the world light via WallTheme. The
	colour chip and border key off which side this is.

	Two lines, and the split is deliberate:

	  line 1   chip · TITLE · name        — identity, and the widest thing here
	  line 2   rating · clock             — the numbers

	The name gets a line to itself because it is the one field we don't control the length
	of: a Steam persona name is up to 32 chars and a lichess name up to 20 plus a title
	(see SpectatorWall.SeatPxWidth, which is sized for the worst of those). Putting the
	rating beside it would have made the long case clip.

	Line 2 varies by source, which is why both halves are conditional:
	  - an sbox table has no rating (Gambit has no rating) — clock only
	  - lichess TV always has both
	  - an untimed table has no clock — and if there's also no rating, line 2 is dropped
	    entirely rather than left as an empty gap.
*@

<root>
	<div class="tag" style="background-color:@WallTheme.Bg; border:3px solid @( White ? "#f5f5f7" : "#101014" );">
		<div class="name-row">
			<div class="chip @( White ? "w" : "b" )"></div>
			@if ( !string.IsNullOrEmpty( Title() ) )
			{
				<div class="title-badge">@Title()</div>
			}
			<div class="name" style="color:@WallTheme.Text;">@Name()</div>
		</div>
		@if ( HasSubLine() )
		{
			<div class="sub">
				@if ( Rating() > 0 )
				{
					<div class="rating" style="color:@WallTheme.Text;">@Rating()</div>
				}
				@if ( !string.IsNullOrEmpty( Clock() ) )
				{
					<div class="clock" style="color:@ClockColor();">@Clock()</div>
				}
			</div>
		}
	</div>
</root>

<style>
	@@import "WallTheme.scss";

	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	.tag {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		flex-direction: column;
		align-items: stretch;
		justify-content: center;
		padding: 14px 40px;
		border-radius: 12px;
		font-family: $wall-font;
		gap: 4px;
	}

	.tag > div { flex-shrink: 0; }

	.name-row {
		flex-direction: row;
		align-items: center;
		justify-content: center;
	}

	.chip {
		width: 22px;
		height: 22px;
		border-radius: 11px;
		margin-right: 14px;
		flex-shrink: 0;
	}
	.chip.w { background-color: #f5f5f7; border: 2px solid #101014; }
	.chip.b { background-color: #101014; border: 2px solid #f5f5f7; }

	.name {
		white-space: nowrap;
		font-size: 30px;
		font-weight: bold;
		letter-spacing: 1px;
	}

	/* A lichess title, worn like lichess wears it: small, bold, and coloured rather
	   than boxed. BOT/anonymous never reach this — they have no title. */
	.title-badge {
		white-space: nowrap;
		font-size: 24px;
		font-weight: bold;
		letter-spacing: 1px;
		color: #d0a44c;
		margin-right: 10px;
		flex-shrink: 0;
	}

	.sub {
		flex-direction: row;
		align-items: center;
		justify-content: center;
		white-space: nowrap;
		/* Gap, not margins: either child can be absent (a table has no rating, an
		   untimed game has no clock) and a margin would leave the survivor off-centre. */
		gap: 18px;
	}

	.rating {
		font-size: 26px;
		font-weight: bold;
		letter-spacing: 1px;
		opacity: 0.75;
	}

	.clock { font-size: 28px; font-weight: bold; letter-spacing: 1px; }
</style>

@code
{
	/// <summary>True = the White seat (bottom-right tag); false = Black (top-left tag).</summary>
	[Property] public bool White { get; set; }

	SpectatorController C => SpectatorController.Instance;

	string Name()
	{
		var name = White ? C?.WhiteName : C?.BlackName;
		return string.IsNullOrEmpty( name ) ? ( White ? "White" : "Black" ) : name;
	}

	/// <summary>lichess title ("GM", "WFM"), or null. Always null for an sbox table.</summary>
	string Title() => White ? C?.WhiteTitle : C?.BlackTitle;

	/// <summary>lichess rating, or 0 when there isn't one (always 0 for an sbox table —
	/// Gambit has no rating).</summary>
	int Rating() => ( White ? C?.WhiteRating : C?.BlackRating ) ?? 0;

	/// <summary>Pre-formatted clock face, or null when the featured game is untimed.</summary>
	string Clock() => White ? C?.WhiteClock : C?.BlackClock;

	/// <summary>Is there anything on line 2? An untimed sbox table has neither a rating
	/// nor a clock, and an empty row would just be a gap under the name.</summary>
	bool HasSubLine() => Rating() > 0 || !string.IsNullOrEmpty( Clock() );

	/// <summary>This seat's clock is the one running.</summary>
	bool Ticking() => C?.TickingSeat == ( White ? ChessSeat.White : ChessSeat.Black );

	/// <summary>This seat is under the panic threshold on a live game.</summary>
	bool Panic() => ( White ? C?.WhitePanic : C?.BlackPanic ) ?? false;

	/// <summary>Clock colour, in precedence order: red under time pressure (the same
	/// <c>#ff5f5f</c> the table clock reddens to), else green while it's the running clock,
	/// else the wall's normal text. Red wins over green — a seat can be both ticking and in
	/// time trouble, and the urgent state is the one to show.</summary>
	string ClockColor() => Panic() ? "#ff5f5f" : Ticking() ? "#7fd47f" : WallTheme.Text;

	protected override int BuildHash() =>
		// HashCode.Combine tops out at 8 args; fold the last two into one so Panic() and
		// the settings version both still feed the hash (a repaint must catch a clock
		// crossing the panic threshold).
		HashCode.Combine( White, C?.WhiteName, C?.BlackName, Title(), Rating(), Clock(),
			Ticking(), HashCode.Combine( Panic(), SettingsModel.SettingsVersion ) );
}
