@using System
@using Sandbox
@using Sandbox.UI
@using Gambit.Game
@using Gambit.World
@namespace Gambit.UI
@inherits PanelComponent

@*
	One player's tag for the spectator board — a small board that hugs a corner of the giant 3D
	spectator board: White at the bottom-right, Black at the top-left, mirroring the board below.
	Replaces the single overhead scoreboard (which tried to show both sides at once and read
	poorly from across the room).

	Display-only WorldPanel (no pointer input); colours track the world light via WallTheme. The
	colour chip and border key off which side this is.

	The tag carries the name, plus the clock when the featured table is playing a timed game
	(the wall's source is an sbox table, so the clock is our own host-run one). Untimed games
	show the name alone. There is no rating line — Gambit has no rating.
*@

<root>
	<div class="tag" style="background-color:@WallTheme.Bg; border:3px solid @( White ? "#f5f5f7" : "#101014" );">
		<div class="name-row">
			<div class="chip @( White ? "w" : "b" )"></div>
			<div class="name" style="color:@WallTheme.Text;">@Name()</div>
		</div>
		@if ( !string.IsNullOrEmpty( Clock() ) )
		{
			<div class="sub">
				<div class="clock" style="color:@( Ticking() ? "#7fd47f" : WallTheme.Text );">@Clock()</div>
			</div>
		}
	</div>
</root>

<style>
	@@import "WallTheme.scss";

	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	.tag {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		flex-direction: column;
		align-items: stretch;
		justify-content: center;
		padding: 14px 40px;
		border-radius: 12px;
		font-family: $wall-font;
		gap: 4px;
	}

	.tag > div { flex-shrink: 0; }

	.name-row {
		flex-direction: row;
		align-items: center;
		justify-content: center;
	}

	.chip {
		width: 22px;
		height: 22px;
		border-radius: 11px;
		margin-right: 14px;
		flex-shrink: 0;
	}
	.chip.w { background-color: #f5f5f7; border: 2px solid #101014; }
	.chip.b { background-color: #101014; border: 2px solid #f5f5f7; }

	.name {
		white-space: nowrap;
		font-size: 30px;
		font-weight: bold;
		letter-spacing: 1px;
	}

	.sub {
		flex-direction: row;
		align-items: center;
		justify-content: center;
		white-space: nowrap;
	}

	.clock { font-size: 28px; font-weight: bold; letter-spacing: 1px; }
</style>

@code
{
	/// <summary>True = the White seat (bottom-right tag); false = Black (top-left tag).</summary>
	[Property] public bool White { get; set; }

	SpectatorController C => SpectatorController.Instance;

	string Name()
	{
		var name = White ? C?.WhiteName : C?.BlackName;
		return string.IsNullOrEmpty( name ) ? ( White ? "White" : "Black" ) : name;
	}

	/// <summary>Pre-formatted clock face, or null when the featured game is untimed.</summary>
	string Clock() => White ? C?.WhiteClock : C?.BlackClock;

	/// <summary>This seat's clock is the one running.</summary>
	bool Ticking() => C?.TickingSeat == ( White ? ChessSeat.White : ChessSeat.Black );

	protected override int BuildHash() =>
		HashCode.Combine( White, C?.WhiteName, C?.BlackName, Clock(), Ticking(),
			SettingsModel.SettingsVersion );
}
