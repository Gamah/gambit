@using System;
@using System.Collections.Generic;
@using System.Threading.Tasks;
@using Sandbox;
@using Sandbox.UI;
@using Gambit.World;
@using Gambit.Game;
@using Gambit.Api;
@namespace Gambit.UI
@inherits PanelComponent

@*
	Seated-game HUD: seat names, whose turn, the status/turn line, standing draw and
	takeback offers, the SAN move list, the waiting-on-an-opponent controls (a seek, a
	named challenge, a shareable link), and resign, plus the result after the game.
	Attached to the scene ScreenPanel at runtime by LobbyPlayer.EnsureGameHud.
	Screen-space overlay: the board itself is the 3D world — this sits in a column on the
	right edge, clear of the board (px values are uncalibrated, tune in-editor).

	Two pieces split out of here in M17 (this file was 1089 lines): the pre-game SETUP
	block (time control + the four lichess start flows + Ready) is now <SetupPanel />,
	rendered in-column where the block was; the PROMOTION picker is now <PromotionPanel />,
	a full-screen sibling of the column. Both are nested @inherits Panel widgets that
	re-resolve the controllers off ChessStation.Active and carry their own style and
	repaint hash — s&box panel stylesheets don't reliably cross a nested-panel boundary,
	so a split panel that leaned on this file's <style> would render unstyled.

	NO CLOCKS (M11). They are on the table now, as a real mesh clock with a face per seat
	— ChessRing.BuildStationClock and TableClock. Both clocks used to be text in this
	column, pinned to the right of the screen while the board sat in the middle of it,
	which in a 3+0 game is the wrong place for the number that ends the game. If a clock
	ever comes back here, TimeControl.PanicSeconds and the rendered-string hashing have to
	come with it — see BuildHash.
*@

<root>
	@if ( Visible() )
	{
		var ctrl = Controller();

		<div class="hud">
			<div class="title">@BoardTitle( ctrl )</div>
			<div class="names">
				<div class="name @SeatClass( ChessSeat.White )">⬜ @SeatLine( ctrl, ChessSeat.White )</div>
				<div class="name @SeatClass( ChessSeat.Black )">⬛ @SeatLine( ctrl, ChessSeat.Black )</div>
			</div>

			@* While a lichess game owns the board, LICHESS is the authority on what
			   happened — the local controller's ChessGame never advances during one
			   (moves go to the relay, not NetChessMove), so its result and clocks
			   are stale by construction. Read lichess's verdict, not ours. *@
			@if ( OnLichess() )
			{
				var lc = Lichess();

				@if ( lc.State is { finished: true } )
				{
					<div class="status over">@lc.ResultString</div>
					<div class="reason">@lc.OverReason (on lichess)</div>
					@* The board holds the finished position so you can see what happened;
					   this is the button that clears it and frees the table for a new game
					   (and releases the server-side play so the next link starts clean). *@
					<div class="button" onclick="@( () => NewGame() )">New game — clear the board</div>
				}
				else if ( LichessStatus() is string note )
				{
					<div class="status">@note</div>
				}
				else
				{
					<div class="status turn">@TurnText( Source() )</div>
				}

			}
			else if ( ctrl == null || !ctrl.HasGame || ( !ctrl.Playing && !ctrl.GameOver ) )
			{
				<div class="status">@WaitingText()</div>
			}
			else if ( ctrl.GameOver )
			{
				<div class="status over">@( ctrl.OverResult ?? ctrl.Game?.ResultString )</div>
				<div class="reason">@( ctrl.OverReason ?? ctrl.Game?.ResultReason )</div>
				<div class="button" onclick="@( () => NewGame() )">New game — clear the board</div>
			}
			else
			{
				<div class="status turn">@TurnText( Source() )</div>
			}

			@* Standing offers, read off the seam. OUTSIDE the OnLichess() block: a draw
			   and a takeback mean the same thing at either kind of table, and the
			   controller that owns the board answers for its own. *@
			@if ( Source() is { DrawOffered: true } )
			{
				<div class="reason">Your opponent offers a draw.</div>
			}
			@if ( Source() is { TakebackOffered: true } )
			{
				<div class="reason">Your opponent wants to take back a move.</div>
			}
			@if ( Source() is { DrawPending: true } )
			{
				<div class="reason">Draw offered — waiting for your opponent.</div>
			}
			@if ( Source() is { TakebackPending: true } )
			{
				<div class="reason">Takeback offered — waiting for your opponent.</div>
			}

			@* A premove is the one thing on this HUD the player can't see on the board
			   from their seat if they've looked away: say it in words too, because it
			   will play itself the moment they're back on move.

			   OUTSIDE the OnLichess() block: premove works at any table with a clock,
			   not just a lichess one — see IBoardGame.PremoveUci. *@
			@if ( PremoveUci() is string pre )
			{
				<div class="reason premove">Premove armed: @( pre[..2] )→@( pre[2..4] ). Click the board to cancel.</div>
			}

			@* And when it didn't fire. Without this the highlight just vanishes, which
			   is precisely what it does on success — so a dropped premove read as a
			   played one and you'd sit waiting for a move you never made. *@
			@if ( Source() is { PremoveDropped: true } )
			{
				<div class="reason premove">Premove dropped — it wasn't legal any more.</div>
			}

			@* A lichess game that never started. Lives OUTSIDE the OnLichess() block
			   above on purpose: the controller disengages when it fails, so this is
			   the only place the reason can be seen. The table has fallen back to a
			   normal local game. *@
			@if ( !OnLichess() && Lichess()?.Error is string lerr )
			{
				<div class="reason lichess-err">♞ @lerr — playing here instead.</div>
			}

			@* The pre-game setup — time control, the four lichess start flows, and Ready —
			   is its own panel now (M17). It re-gates on ShowSetup internally, carries its own
			   style, and keeps ticking through a seek to resolve the assigned seat. *@
			<SetupPanel />

			@if ( Source()?.Game != null )
			{
				<div class="moves">
					@foreach ( var row in MoveRows( Source() ) )
					{
						<div class="move-row">@row</div>
					}
				</div>
			}

			@* Waiting on an opponent who isn't in this lobby — a lobby seek, or a
			   named user who hasn't accepted our challenge yet. Cancelling is what
			   actually withdraws the request (a seek's held connection, a challenge's
			   explicit /cancel) — without it we stay pairable after walking away. *@
			@if ( Lichess() is { AwaitingOpponent: true } )
			{
				@* Shareable link: show the url to hand out while we wait for someone to
				   open it. The game itself renders on the board once they join. *@
				@if ( Lichess() is { Opening: true, ShareUrl: string share } )
				{
					<div class="link-url" onclick="@( () => CopyShareUrl( share ) )">@share</div>
					<div class="button lichess" onclick="@( () => CopyShareUrl( share ) )">@ShareCopyText()</div>
					<div class="setup-hint">Send this to your opponent — they open it in a browser and play you here.</div>
				}
				<div class="button" onclick="@( () => Lichess()?.CancelWaiting() )">
					@CancelWaitingText()
				</div>
			}

			@* Draw offers and takebacks. Read off the seam, so they work at a lichess
			   table AND a local one.

			   The local game had neither until now, on the reasoning that two players
			   at a table can just say so. That was wrong about the draw in a way worth
			   remembering: saying so doesn't END the game — there was no way to record
			   a 1/2-1/2 at all, so agreeing meant someone resigning a drawn position.
			   And the clocks are real, so a misclick in a 3+0 game had no way back. *@
			@if ( Source() is { Playing: true, LocalSeat: not null } )
			{
				@* Nothing while OUR offer is standing and there's nothing to answer:
				   re-offering is a no-op, and the waiting state is already said once
				   above. Same rule as the takeback below. *@
				@if ( ShowOfferButton( Source()?.DrawPending, Source()?.DrawOffered ) )
				{
					<div class="offer-row">
						<div class="button draw" onclick="@( () => Source()?.OfferDraw() )">@DrawText()</div>
						@* Only offer a decline when there's something to decline — a
						   standing "no" button would be a way to decline nothing. *@
						@if ( Source() is { DrawOffered: true } )
						{
							<div class="button decline" onclick="@( () => Source()?.DeclineDraw() )">No</div>
						}
					</div>
				}

				@* Hidden, not disabled, before both sides have moved: lichess drops
				   a takeback proposed that early and still answers 200, so a button
				   there would look like it worked and do nothing. The local table
				   keeps the same rule rather than being subtly more permissive at
				   the next board along.

				   Nothing here while OUR proposal is standing, either: re-offering is
				   a no-op, and the waiting state is already said once as a status line
				   above. A button whose only effect is to re-send a request the
				   opponent has already been asked is a button that lies about doing
				   something. *@
				@if ( Source() is { CanTakeback: true }
					&& ShowOfferButton( Source()?.TakebackPending, Source()?.TakebackOffered ) )
				{
					<div class="offer-row">
						<div class="button takeback" onclick="@( () => Source()?.OfferTakeback() )">@TakebackText()</div>
						@if ( Source() is { TakebackOffered: true } )
						{
							<div class="button decline" onclick="@( () => Source()?.DeclineTakeback() )">No</div>
						}
					</div>
				}
			}

			@* Resign is its own explicit, confirmed action now (M17) — decoupled from
			   standing up, which just gets you out of the seat to roam without ending the
			   game. Two-stage: first click arms, second confirms. Escape/Leave no longer
			   resigns, so this button is the ONLY way to end a live game from the board. *@
			@if ( ( Source()?.Playing ?? false ) )
			{
				<div class="button resign" onclick="@( () => LobbyPlayer.Local?.Resign() )">
					@( ( LobbyPlayer.Local?.LeaveArmed ?? false ) ? "Sure? Resign the game" : "Resign" )
				</div>
			}
		</div>

		<PromotionPanel />
	}
</root>

<style>
	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: 50;
	}

	.hud {
		position: absolute;
		right: 24px;
		/* Size to content (no fixed height, no overflow: scroll — scroll drag-pans and
		   fights clicks, CLAUDE.md). Anchored near the top so the tall signed-in panel
		   uses the full height downward; the tight gaps/padding/font below keep it on
		   screen at normal resolutions. */
		top: 2%;
		width: 250px;
		flex-direction: column;
		gap: 5px;
		padding: 12px;
		background-color: rgba(10, 10, 14, 0.78);
		border-radius: 10px;
		color: rgba(255, 255, 255, 0.9);
		font-size: 13px;
	}

	.title {
		font-size: 12px;
		letter-spacing: 2px;
		color: rgba(255, 255, 255, 0.45);
	}

	.names { flex-direction: column; gap: 2px; }
	.name { font-size: 14px; }
	/* The side whose clock is running. */
	.name.ticking { color: #7fd47f; font-weight: bold; }

	/* The setup block moved to SetupPanel (M17), but the shareable-link "waiting"
	   controls below still use this one hint style, so it stays. */
	.setup-hint { font-size: 12px; color: rgba(255, 255, 255, 0.45); }

	/* Lichess opt-in: lichess's own black/white, so it reads as "this leaves
	   Gambit" rather than as another table control. */
	.button.lichess { background-color: rgba(240, 240, 240, 0.14); }
	.button.lichess:hover { background-color: rgba(240, 240, 240, 0.28); }
	.button.lichess.on {
		background-color: rgba(240, 240, 240, 0.8);
		color: rgba(15, 15, 15, 0.95);
		font-weight: bold;
	}
	/* The shareable link itself: monospace so it reads as a URL, click-to-copy. */
	.link-url {
		pointer-events: all;
		cursor: pointer;
		font-family: monospace;
		font-size: 12px;
		word-break: break-all;
		padding: 5px 7px;
		border-radius: 5px;
		background-color: rgba(0, 0, 0, 0.3);
		color: rgba(255, 255, 255, 0.85);
	}
	.link-url:hover { background-color: rgba(0, 0, 0, 0.45); }

	.button.draw { background-color: rgba(255, 214, 10, 0.18); }
	.button.draw:hover { background-color: rgba(255, 214, 10, 0.34); }

	/* Takeback: the same "ask the opponent for something" family as the draw, one
	   hue over, so the two read as a pair of offers rather than two unrelated
	   controls. */
	.button.takeback { background-color: rgba(120, 210, 255, 0.18); }
	.button.takeback:hover { background-color: rgba(120, 210, 255, 0.34); }

	/* Decline sits beside the offer it refuses, so it stays narrow: the offer is
	   the choice being made, "No" is the escape from it. */
	.offer-row { flex-direction: row; gap: 4px; }
	.offer-row .button { flex-grow: 1; }
	.button.decline {
		flex-grow: 0;
		background-color: rgba(255, 255, 255, 0.1);
	}
	.button.decline:hover { background-color: rgba(255, 45, 85, 0.4); }

	.status { font-size: 16px; font-weight: bold; }
	.status.turn { color: #7fd47f; }
	.status.over { color: #ffd60a; font-size: 20px; }
	.reason { font-size: 13px; color: rgba(255, 255, 255, 0.6); }
	.reason.lichess-err { color: rgba(255, 180, 40, 0.95); }
	/* Same purple as the board's premove highlight (ChessBoardView.PremoveTint) —
	   the line and the squares are one statement. */
	.reason.premove { color: rgba(197, 120, 240, 0.95); }

	.moves {
		flex-direction: column;
		max-height: 180px;
		overflow: hidden;
		background-color: rgba(255, 255, 255, 0.05);
		border-radius: 6px;
		padding: 6px 10px;
	}
	.move-row { font-size: 13px; font-family: monospace; color: rgba(255, 255, 255, 0.8); }

	.button {
		padding: 6px 12px;
		background-color: rgba(90, 140, 255, 0.25);
		border-radius: 6px;
		cursor: pointer;
		pointer-events: all;
		font-size: 13px;
		justify-content: center;
	}
	.button:hover { background-color: rgba(90, 140, 255, 0.45); }
	.button.resign { background-color: rgba(255, 45, 85, 0.25); }
	.button.resign:hover { background-color: rgba(255, 45, 85, 0.5); }
</style>

@code
{
	static ChessStation Station() => ChessStation.Active;
	static LocalGameController Controller() => LocalGameController.For( ChessStation.Active );
	static ChessBoardView View() => ChessStation.Active?.Components.Get<ChessBoardView>();

	static string BoardTitle( LocalGameController ctrl ) =>
		( ctrl?.HasGame ?? false ) ? "GAME" : "CHESS BOARD";

	/// <summary>What the board is waiting for when no game is running.</summary>
	static string WaitingText()
	{
		if ( Station() is not { } s ) return "";
		if ( s.WhiteSteamId == 0 && s.BlackSteamId == 0 ) return "Waiting for players…";
		if ( !BothSeated() ) return "Waiting for an opponent to sit down…";

		// Both seated: the game is now gated on ready, not on occupancy.
		var ctrl = Controller();
		if ( ctrl == null ) return "";
		if ( ctrl.WhiteReady && ctrl.BlackReady ) return "Starting…";
		if ( LocalReady( ctrl ) ) return "Waiting for your opponent to ready up…";
		return "Pick a time control and ready up";
	}

	static bool LocalReady( LocalGameController ctrl ) =>
		ctrl?.LocalSeat is { } seat && ctrl.ReadyFor( seat );

	// ── Lichess (M8) ──

	/// <summary>The lichess controller beside the table we're seated at.</summary>
	static LichessGameController Lichess() => LichessGameController.For( ChessStation.Active );

	/// <summary>Whichever controller owns this board. Goes through BoardGame.Source, the
	/// one copy of that resolution — the view, the sounds and the table clock all ask it
	/// too, so none of them can end up describing a different game from this HUD.</summary>
	static IBoardGame Source() => BoardGame.Source( Controller(), Lichess() );

	/// <summary>A real lichess game owns this board right now — the HUD reads
	/// lichess's state instead of the local table's.</summary>
	static bool OnLichess() => Lichess() is { Engaged: true };

	/// <summary>The armed premove on whichever game owns this board, or null. Read
	/// off the seam, not off the lichess controller: a premove at a local table is
	/// just as real, and costs the same clock.</summary>
	static string PremoveUci() =>
		Source()?.PremoveUci is { Length: >= 4 } u ? u : null;

	// The "Copied ✓" flash on the shareable-link copy button (shown while a link game is
	// awaiting an opponent). Self-clears on a timer, so it must be hashed or it would stick.
	RealTimeSince _shareCopied = 999f;

	void CopyShareUrl( string url )
	{
		if ( string.IsNullOrEmpty( url ) ) return;
		Clipboard.SetText( url );
		_shareCopied = 0f;
		StateHasChanged();
	}

	/// <summary>"New game — clear the board": drop a finished game and return the table
	/// to setup without standing up. Cleans up the server-side lichess play too (a no-op
	/// for a local game), then resets the local table to idle.</summary>
	void NewGame()
	{
		Lichess()?.DismissFinished();
		Controller()?.RequestNewGame();
		StateHasChanged();
	}

	string ShareCopyText() => _shareCopied < 2f ? "Copied ✓" : "Copy the link to send";

	string CancelWaitingText()
	{
		var lc = Lichess();
		if ( lc is { Opening: true } ) return "Cancel this link";
		if ( lc is { Challenging: true } ) return "Cancel the challenge";
		return "Cancel — stop looking";
	}


	/// <summary>Should an offer button render at all?
	///
	/// <para>Hidden only while we're purely WAITING: our own offer stands and there's
	/// nothing of theirs to answer. Re-sending an offer the opponent has already been
	/// asked does nothing, and a button whose click does nothing is a lie.</para>
	///
	/// <para>The <c>offered</c> half is what stops that hiding too much: if both sides
	/// have an offer standing at once, ours pending must NOT hide the button that
	/// accepts theirs — that would be a game neither player could agree.</para></summary>
	static bool ShowOfferButton( bool? pending, bool? offered ) =>
		!( pending ?? false ) || ( offered ?? false );

	/// <summary>The draw button doubles as accept, because lichess's draw/yes does:
	/// offering when one is pending IS accepting it. The local table copies that rather
	/// than inventing a second vocabulary for the same gesture.</summary>
	static string DrawText() =>
		Source() is { DrawOffered: true } ? "Accept draw" : "Offer draw";

	/// <summary>Two states, like the draw button, because lichess's takeback/yes is
	/// the same call for proposing and accepting. There is no third "waiting" state
	/// here: while our own proposal stands the button isn't rendered at all, and the
	/// status line says so instead.</summary>
	static string TakebackText() =>
		Source() is { TakebackOffered: true } ? "Accept takeback" : "Ask for takeback";

	/// <summary>Status line while a lichess game is being set up or run, or null
	/// when there is nothing to say and the turn indicator should show.</summary>
	static string LichessStatus()
	{
		var lc = Lichess();
		if ( lc == null || !lc.Engaged ) return null;
		if ( lc.Error is string e ) return e;

		if ( lc.Seeking ) return "Looking for an opponent on lichess…";
		if ( lc.Challenging ) return $"Waiting for {lc.ChallengeOpponent} to accept on lichess…";
		if ( lc.Opening ) return "Waiting for someone to open your link…";

		return lc.State?.status switch
		{
			// A seek or challenge needs nobody in THIS lobby; only the paired flow
			// waits on the other seat's Gambit client.
			"waiting" => lc.IsSeek ? "Waiting for a lichess opponent…"
				: "Waiting for your opponent's client…",
			// A named opponent hasn't answered yet — say who we're waiting on. A seek
			// is still just looking. The paired flow is mid-handshake with lichess.
			"challenging" => !lc.IsSeek ? "Starting the game on lichess…"
				: lc.ChallengeOpponent is string who ? $"Waiting for {who} to accept on lichess…"
				: "Looking for an opponent on lichess…",
			_ => null,
		};
	}


	/// <summary>Seat line: who is on a side, and what they've agreed to.
	/// One div per line and no inline markup — CLAUDE.md UI Gotchas.</summary>
	///
	/// <remarks>
	/// <para><b>The clock is not here any more (M11).</b> It lives on the table, as a real
	/// mesh clock with a face for each seat — see ChessRing.BuildStationClock and
	/// TableClock. Both clocks used to be text in this 250px column pinned to the
	/// right of the screen while the board sat in the middle of it, which in a 3+0 game is
	/// the wrong place for the number that ends the game.</para>
	///
	/// <para><b>The hashing moved with it, and that was the load-bearing part.</b> These
	/// lines are hashed as their rendered STRINGS, which is what repainted the HUD on a
	/// visible digit change rather than every frame. Now that the clock is elsewhere, the
	/// panel showing it does that instead; this line changes rarely and hashes for almost
	/// nothing. Don't put a clock back in here without moving that consideration back too.</para>
	///
	/// <para>Still lichess-first, for the half that remains: a SEEK starts no local game,
	/// so ctrl.Playing is false for its whole duration, and checking the local table first
	/// would fall into the idle branch and never show a seek's opponent.</para>
	/// </remarks>
	static string SeatLine( LocalGameController ctrl, ChessSeat seat )
	{
		string name = SeatName( seat );

		if ( OnLichess() ) return name;
		if ( ctrl == null ) return name;

		// Idle table: say who has agreed to what. Nothing to say once a game is live —
		// the clock on the table is the live state now.
		if ( !ctrl.Playing && !ctrl.GameOver )
		{
			if ( ctrl.ReadyFor( seat ) ) return $"{name}  ready";
			return ctrl.LichessFor( seat ) ? $"{name}  ♞" : name;
		}

		return name;
	}

	/// <summary>Who is on a side.
	///
	/// <para>During a lichess game the LICHESS names win, because they're who is
	/// actually playing. That matters most for a seek, where the opponent is a
	/// stranger who isn't in this lobby at all and the station has no name for
	/// them — but it's also the honest label for a paired game, where the lichess
	/// account is what the result lands on.</para></summary>
	static string SeatName( ChessSeat seat )
	{
		if ( OnLichess() && Lichess()?.State is { } st )
		{
			string lichessName = seat == ChessSeat.White ? st.white_name : st.black_name;
			if ( !string.IsNullOrEmpty( lichessName ) ) return lichessName;
			if ( Lichess().AwaitingOpponent || st.seek ) return "…";  // nobody yet
		}

		string name = Station()?.SeatName( seat );
		return string.IsNullOrEmpty( name ) ? "—" : name;
	}

	/// <summary>Accent the side on move.
	///
	/// <para><b>No panic red here any more (M11).</b> This used to return "ticking low"
	/// under TimeControl.PanicSeconds — reddening a name that sat next to a clock. The
	/// clock is on the table now, and its own face reddens; reddening a NAME on a HUD with
	/// no clock on it would be an alarm about a number that isn't in the same place, or
	/// even on the same screen.</para>
	///
	/// <para>Reads the SEAM rather than ctrl.TickingSeat: during a lichess game the local
	/// controller's ChessGame never advances (moves go to the relay, not NetChessMove), so
	/// it answers "White" for the whole game.</para></summary>
	static string SeatClass( ChessSeat seat )
	{
		if ( Source() is not { Playing: true, Game: { } game } ) return "";
		var ticking = game.WhiteToMove ? ChessSeat.White : ChessSeat.Black;
		return ticking == seat ? "ticking" : "";
	}

	static bool Visible() =>
		ChessStation.Active != null && ( LobbyPlayer.Local?.CameraSettled ?? false );

	/// <summary>Ask whether we're linked, while sitting at a table.
	///
	/// <para>Load-bearing, not housekeeping. Every lichess control here — the opt-in,
	/// the seek, and so the draw and takeback that follow from a game existing — is
	/// behind <c>LichessLinkState.Linked</c>, which starts false and only becomes
	/// true when someone ASKS. Until this existed the only caller was the east-wall
	/// board's own screen, so a linked player who sat down without visiting that wall
	/// first was told to go and link an account they already had, and the table
	/// offered nothing but a local game. It looked exactly like the feature hadn't
	/// shipped.</para>
	///
	/// <para>This keeps the rule that made the old caller narrow — never poll in the
	/// background — by asking only while a station is engaged. LichessLinkState
	/// single-flights, rate-limits to 3s, and early-returns forever once linked, so
	/// per-frame here is its intended use.</para></summary>
	protected override void OnUpdate()
	{
		if ( ChessStation.Active != null )
			LichessLinkState.Poll();
	}

	static bool BothSeated() =>
		Station() is { } s && s.WhiteSteamId != 0 && s.BlackSteamId != 0;

	/// <summary>Whose move it is, read from whichever controller owns the board.
	/// <para>Takes IBoardGame rather than LocalGameController for the same reason
	/// ChessBoardView does: during a lichess game the local controller's ChessGame
	/// never advances (moves go to the relay, not NetChessMove), so asking it whose
	/// turn it is would answer "White" forever.</para></summary>
	static string TurnText( IBoardGame src )
	{
		if ( src?.Game == null ) return "";
		if ( src.IsMyTurn )
			return src.Game.IsCheck ? "Your move — check!" : "Your move";
		return src.Game.WhiteToMove ? "White is thinking…" : "Black is thinking…";
	}

	/// <summary>Last few full-move rows, "12. Nf3 Nc6" style. The list column is
	/// fixed-height with overflow hidden (drag-scroll fights clicks — CLAUDE.md),
	/// so we render only the tail.</summary>
	static IEnumerable<string> MoveRows( IBoardGame src )
	{
		var san = src?.Game?.SanMoves;
		if ( san == null || san.Count == 0 ) yield break;

		const int maxRows = 12;
		int totalRows = ( san.Count + 1 ) / 2;
		for ( int row = Math.Max( 0, totalRows - maxRows ); row < totalRows; row++ )
		{
			int i = row * 2;
			string line = $"{row + 1}. {san[i]}";
			if ( i + 1 < san.Count ) line += $"  {san[i + 1]}";
			yield return line;
		}
	}

	/// <summary>Repaint triggers. The seat lines are still hashed as their rendered
	/// strings — now cheap rather than load-bearing. With the clock moved onto the table
	/// (M11) they change only when a name or a ready state does, so this HUD no longer
	/// repaints on a ticking digit at all. TableClockTextPanel took that job and carries the
	/// same string-hashing reasoning; read its BuildHash before putting any per-second
	/// value back in here.
	///
	/// <para>Anything the markup reads has to be in here. The offers are hashed off
	/// SOURCE(), not off the lichess controller: they render for a local game too now,
	/// and Lichess() is null at a local table — so hashing it would have left a draw
	/// offer sitting there unpainted until something else happened to change.</para>
	///
	/// <para>Nested because HashCode.Combine tops out at eight arguments.</para></summary>
	protected override int BuildHash()
	{
		var ctrl = Controller();
		var src = Source();
		return System.HashCode.Combine(
			Visible(), ctrl?.GameId, src?.Game?.MoveCount, ctrl?.GameOver,
			src?.IsMyTurn, View()?.PendingPromotion != null,
			LobbyPlayer.Local?.LeaveArmed,
			System.HashCode.Combine(
				System.HashCode.Combine(
					BothSeated(), ctrl?.TimeControlIndex, ctrl?.WhiteReady, ctrl?.BlackReady,
					ctrl?.TickingSeat,
					SeatLine( ctrl, ChessSeat.White ), SeatLine( ctrl, ChessSeat.Black ) ),
				// Lichess-only: status, result, whether it owns the board, the link.
				// Its clocks and names ride in the seat lines above (hashed as text).
				System.HashCode.Combine(
					OnLichess(), Lichess()?.State?.status, Lichess()?.State?.finished,
					Lichess()?.Error, Lichess()?.Seeking,
					ctrl?.WhiteLichess, ctrl?.BlackLichess,
					LichessLinkState.Linked ),
				// Offers and the premove, off the seam — true for either kind of game.
				// PremoveDropped self-clears on a timer rather than on an event, so it
				// is the one value in here that changes with nothing else changing: left
				// out, the notice would appear (some other repaint would carry it) and
				// then never go away. 7 of 8 used.
				System.HashCode.Combine(
					src?.DrawOffered, src?.DrawPending,
					src?.TakebackOffered, src?.TakebackPending,
					src?.CanTakeback, PremoveUci(), src?.PremoveDropped ),
				// The waiting-on-an-opponent state (a seek, a named challenge, or a
				// shareable link): the status line and the cancel button hang off
				// Challenging/Opening, ChallengeOpponent names who, and the link section
				// shows ShareUrl with the "Copied ✓" flash. The seek/challenge/link
				// PREFERENCES moved to SetupPanel with the setup block (M17), and hash there.
				System.HashCode.Combine(
					Lichess()?.Challenging, Lichess()?.ChallengeOpponent,
					Lichess()?.Opening, Lichess()?.ShareUrl, _shareCopied < 2f ) ) );
	}
}
