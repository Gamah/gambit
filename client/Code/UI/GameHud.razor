@using System;
@using System.Collections.Generic;
@using Sandbox;
@using Sandbox.UI;
@using Gambit.World;
@using Gambit.Game;
@using Gambit.Api;
@namespace Gambit.UI
@inherits PanelComponent

@*
	Seated-game HUD: seat names and clocks, whose turn, the time-control picker and
	ready button while the table is idle, SAN move list, resign,
	promotion picker, and the result after the game. Attached to
	the scene ScreenPanel at runtime by LobbyPlayer.EnsureGameHud. Screen-space
	overlay: the board itself is the 3D world — this sits in a column on the
	right edge, clear of the board (px values are uncalibrated, tune in-editor).
*@

<root>
	@if ( Visible() )
	{
		var ctrl = Controller();
		var view = View();

		<div class="hud">
			<div class="title">@BoardTitle( ctrl )</div>
			<div class="names">
				<div class="name @SeatClass( ctrl, ChessSeat.White )">⬜ @SeatLine( ctrl, ChessSeat.White )</div>
				<div class="name @SeatClass( ctrl, ChessSeat.Black )">⬛ @SeatLine( ctrl, ChessSeat.Black )</div>
			</div>

			@* While a lichess game owns the board, LICHESS is the authority on what
			   happened — the local controller's ChessGame never advances during one
			   (moves go to the relay, not NetChessMove), so its result and clocks
			   are stale by construction. Read lichess's verdict, not ours. *@
			@if ( OnLichess() )
			{
				var lc = Lichess();

				@if ( lc.State is { finished: true } )
				{
					<div class="status over">@lc.ResultString</div>
					<div class="reason">@lc.OverReason (on lichess)</div>
				}
				else if ( LichessStatus() is string note )
				{
					<div class="status">@note</div>
				}
				else
				{
					<div class="status turn">@TurnText( Source() )</div>
				}

				@if ( lc.DrawOffered )
				{
					<div class="reason">Your opponent offers a draw.</div>
				}
				@if ( lc.TakebackOffered )
				{
					<div class="reason">Your opponent wants to take back a move.</div>
				}
				@if ( lc.TakebackPending )
				{
					<div class="reason">Takeback offered — waiting for your opponent.</div>
				}
			}
			else if ( ctrl == null || !ctrl.HasGame || ( !ctrl.Playing && !ctrl.GameOver ) )
			{
				<div class="status">@WaitingText()</div>
			}
			else if ( ctrl.GameOver )
			{
				<div class="status over">@( ctrl.OverResult ?? ctrl.Game?.ResultString )</div>
				<div class="reason">@( ctrl.OverReason ?? ctrl.Game?.ResultReason )</div>
			}
			else
			{
				<div class="status turn">@TurnText( Source() )</div>
			}

			@* A premove is the one thing on this HUD the player can't see on the board
			   from their seat if they've looked away: say it in words too, because it
			   will play itself the moment they're back on move.

			   OUTSIDE the OnLichess() block: premove works at any table with a clock,
			   not just a lichess one — see IBoardGame.PremoveUci. *@
			@if ( PremoveUci() is string pre )
			{
				<div class="reason premove">Premove armed: @( pre[..2] )→@( pre[2..4] ). Click the board to cancel.</div>
			}

			@* A lichess game that never started. Lives OUTSIDE the OnLichess() block
			   above on purpose: the controller disengages when it fails, so this is
			   the only place the reason can be seen. The table has fallen back to a
			   normal local game. *@
			@if ( !OnLichess() && Lichess()?.Error is string lerr )
			{
				<div class="reason lichess-err">♞ @lerr — playing here instead.</div>
			}

			@* Time control + ready. Shown whenever the table is not mid-game, so it
			   covers both a fresh table and the rematch after a result. *@
			@if ( ShowSetup( ctrl ) )
			{
				<div class="setup-label">TIME CONTROL</div>
				<div class="tc-list">
					@for ( int i = 0; i < TimeControl.All.Count; i++ )
					{
						var index = i; // capture per iteration — the lambda outlives the loop
						<div class="tc @( ctrl.TimeControlIndex == index ? "on" : "" )"
							onclick="@( () => ctrl.RequestSetTimeControl( index ) )">@TimeControl.All[index].Name</div>
					}
				</div>

				@* Lichess (M8). Two ways to put a real game on your lichess record:
				   play the person opposite you, or play a stranger. Each is offered
				   only where it could actually work — the two flows have DIFFERENT
				   speed floors (blitz for a challenge, rapid for a seek), which is
				   lichess's rule, not ours. *@
				@* No "already engaged" branch needed: ShowSetup is false whenever
				   lichess owns the board, so this block is only ever reached with no
				   lichess game in flight. *@
				@if ( !LichessLinkState.Linked )
				{
					<div class="setup-hint">Link a lichess account at the east wall to play real games from this table</div>
				}
				else
				{
					@* Play the person opposite you. Both seats must opt in — and
					   gamchess independently requires both to ask, so this is the
					   agreement, not the authorisation. *@
					@if ( LichessTable.CanMirror( ctrl.Tc ) )
					{
						<div class="button lichess @( LocalLichess( ctrl ) ? "on" : "" )" onclick="@( () => ctrl.ToggleLichess() )">@LichessText( ctrl )</div>
						@if ( LichessOptInHint( ctrl ) is string hint )
						{
							<div class="setup-hint">@hint</div>
						}
					}
					else
					{
						<div class="setup-hint">@LichessTable.WhyNot( ctrl.Tc )</div>
					}

					@* Or play a stranger. Needs nobody's agreement but yours: you're
					   spending your own grant on an opponent who opted in on lichess,
					   in their own client, by their own choice. Works alone at a table.

					   The HEADER is outside the CanSeek check on purpose. It used to be
					   inside, so picking Blitz made the whole section vanish and the only
					   trace was a hint the player had no reason to read — the feature
					   looked missing rather than unavailable, and that cost a round of
					   "the board only supports two people in sbox". A control that can't
					   be offered still has to say so where it would have been. *@
					<div class="setup-label">OR PLAY A RANDOM OPPONENT</div>
					@if ( LichessTable.CanSeek( ctrl.Tc ) )
					{
						<div class="seek-row">
							<div class="chip @( _seekRated ? "on" : "" )" onclick="@( () => ToggleSeekRated() )">@( _seekRated ? "Rated" : "Casual" )</div>
							<div class="chip @( _seekColor != "random" ? "on" : "" )" onclick="@( () => CycleSeekColor() )">@SeekColorText()</div>
						</div>
						<div class="seek-row">
							<div class="chip @( _seekNarrow ? "on" : "" )" onclick="@( () => ToggleSeekNarrow() )">@( _seekNarrow ? "Near my rating" : "Any rating" )</div>
						</div>
						<div class="button lichess" onclick="@( () => StartSeek() )">♞ Find a game on lichess</div>
						<div class="setup-hint">@SeekHint()</div>
					}
					else
					{
						<div class="setup-hint">@LichessTable.WhySeekNot( ctrl.Tc )</div>
					}
				}

				@if ( BothSeated() )
				{
					<div class="button ready @( LocalReady( ctrl ) ? "on" : "" )" onclick="@( () => ctrl.ToggleReady() )">@ReadyText( ctrl )</div>
				}
				else
				{
					<div class="setup-hint">Ready unlocks when both seats fill</div>
				}
			}

			@if ( Source()?.Game != null )
			{
				<div class="moves">
					@foreach ( var row in MoveRows( Source() ) )
					{
						<div class="move-row">@row</div>
					}
				</div>
			}

			@* Waiting for a stranger. Cancelling is what actually withdraws us from
			   lichess's lobby — without it we stay pairable after walking away. *@
			@if ( Lichess() is { Seeking: true } )
			{
				<div class="button" onclick="@( () => Lichess()?.CancelSeek() )">Cancel — stop looking</div>
			}

			@* Draw offers and takebacks, lichess only: the local two-seat game has
			   never had them (there's a table between the players — they can just
			   say so, and take the move back themselves). *@
			@if ( OnLichess() && ( Lichess()?.Playing ?? false ) )
			{
				<div class="offer-row">
					<div class="button draw" onclick="@( () => Lichess()?.OfferDraw() )">@DrawText()</div>
					@* Only offer a decline when there's something to decline — a
					   standing "no" button would be a way to decline nothing. *@
					@if ( Lichess()?.DrawOffered ?? false )
					{
						<div class="button decline" onclick="@( () => Lichess()?.DeclineDraw() )">No</div>
					}
				</div>

				@* Hidden, not disabled, before both sides have moved: lichess drops
				   a takeback proposed that early and still answers 200, so a button
				   there would look like it worked and do nothing.

				   Nothing here while OUR proposal is standing, either: re-offering is
				   a no-op on lichess's side, and the waiting state is already said
				   once as a status line above. A button whose only effect is to
				   re-send a request the opponent has already been asked is a button
				   that lies about doing something. *@
				@if ( ( Lichess()?.CanTakeback ?? false ) && !( Lichess()?.TakebackPending ?? false ) )
				{
					<div class="offer-row">
						<div class="button takeback" onclick="@( () => Lichess()?.OfferTakeback() )">@TakebackText()</div>
						@if ( Lichess()?.TakebackOffered ?? false )
						{
							<div class="button decline" onclick="@( () => Lichess()?.DeclineTakeback() )">No</div>
						}
					</div>
				}
			}

			@if ( ( Source()?.Playing ?? false ) )
			{
				<div class="button resign" onclick="@( () => LobbyPlayer.Local?.RequestLeave() )">
					@( ( LobbyPlayer.Local?.LeaveArmed ?? false ) ? "Sure? This resigns" : "Resign & stand up" )
				</div>
			}
		</div>

		@if ( view?.PendingPromotion != null )
		{
			<div class="promo-veil">
				<div class="promo">
					<div class="promo-title">Promote to</div>
					<div class="promo-row">
						<div class="promo-pick" onclick="@( () => view.ChoosePromotion( 'q' ) )">♛</div>
						<div class="promo-pick" onclick="@( () => view.ChoosePromotion( 'r' ) )">♜</div>
						<div class="promo-pick" onclick="@( () => view.ChoosePromotion( 'b' ) )">♝</div>
						<div class="promo-pick" onclick="@( () => view.ChoosePromotion( 'n' ) )">♞</div>
					</div>
					<div class="promo-cancel" onclick="@( () => view.CancelPromotion() )">cancel</div>
				</div>
			</div>
		}
	}
</root>

<style>
	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: 50;
	}

	.hud {
		position: absolute;
		right: 24px;
		/* Size to content (no fixed height, no overflow: scroll — scroll drag-pans and
		   fights clicks, CLAUDE.md). Anchored near the top so the tall signed-in panel
		   uses the full height downward; the tight gaps/padding/font below keep it on
		   screen at normal resolutions. */
		top: 2%;
		width: 250px;
		flex-direction: column;
		gap: 5px;
		padding: 12px;
		background-color: rgba(10, 10, 14, 0.78);
		border-radius: 10px;
		color: rgba(255, 255, 255, 0.9);
		font-size: 13px;
	}

	.title {
		font-size: 12px;
		letter-spacing: 2px;
		color: rgba(255, 255, 255, 0.45);
	}

	.names { flex-direction: column; gap: 2px; }
	.name { font-size: 14px; }
	/* The side whose clock is running. */
	.name.ticking { color: #7fd47f; font-weight: bold; }
	.name.ticking.low { color: #ff453a; }

	.setup-label {
		font-size: 11px;
		letter-spacing: 2px;
		color: rgba(255, 255, 255, 0.45);
		margin-top: 4px;
	}
	.tc-list { flex-direction: column; gap: 3px; }
	.tc {
		font-size: 13px;
		padding: 4px 8px;
		border-radius: 5px;
		cursor: pointer;
		pointer-events: all;
		background-color: rgba(255, 255, 255, 0.06);
		color: rgba(255, 255, 255, 0.75);
	}
	.tc:hover { background-color: rgba(255, 255, 255, 0.16); }
	.tc.on {
		background-color: rgba(90, 140, 255, 0.4);
		color: white;
	}
	.setup-hint { font-size: 12px; color: rgba(255, 255, 255, 0.45); }

	.button.ready { background-color: rgba(127, 212, 127, 0.22); }
	.button.ready:hover { background-color: rgba(127, 212, 127, 0.4); }
	.button.ready.on {
		background-color: rgba(127, 212, 127, 0.55);
		color: white;
		font-weight: bold;
	}

	/* Lichess opt-in: lichess's own black/white, so it reads as "this leaves
	   Gambit" rather than as another table control. */
	.button.lichess { background-color: rgba(240, 240, 240, 0.14); }
	.button.lichess:hover { background-color: rgba(240, 240, 240, 0.28); }
	.button.lichess.on {
		background-color: rgba(240, 240, 240, 0.8);
		color: rgba(15, 15, 15, 0.95);
		font-weight: bold;
	}

	/* Seek controls: small toggles, so the row reads as settings rather than
	   actions. */
	.seek-row { flex-direction: row; gap: 4px; }
	.chip {
		flex-grow: 1;
		justify-content: center;
		font-size: 12px;
		padding: 4px 6px;
		border-radius: 5px;
		cursor: pointer;
		pointer-events: all;
		background-color: rgba(255, 255, 255, 0.06);
		color: rgba(255, 255, 255, 0.7);
	}
	.chip:hover { background-color: rgba(255, 255, 255, 0.16); }
	.chip.on { background-color: rgba(255, 255, 255, 0.2); color: white; }

	.button.draw { background-color: rgba(255, 214, 10, 0.18); }
	.button.draw:hover { background-color: rgba(255, 214, 10, 0.34); }

	/* Takeback: the same "ask the opponent for something" family as the draw, one
	   hue over, so the two read as a pair of offers rather than two unrelated
	   controls. */
	.button.takeback { background-color: rgba(120, 210, 255, 0.18); }
	.button.takeback:hover { background-color: rgba(120, 210, 255, 0.34); }

	/* Decline sits beside the offer it refuses, so it stays narrow: the offer is
	   the choice being made, "No" is the escape from it. */
	.offer-row { flex-direction: row; gap: 4px; }
	.offer-row .button { flex-grow: 1; }
	.button.decline {
		flex-grow: 0;
		background-color: rgba(255, 255, 255, 0.1);
	}
	.button.decline:hover { background-color: rgba(255, 45, 85, 0.4); }

	.status { font-size: 16px; font-weight: bold; }
	.status.wait { color: #ffd60a; font-weight: normal; font-size: 14px; }
	.status.turn { color: #7fd47f; }
	.status.over { color: #ffd60a; font-size: 20px; }
	.reason { font-size: 13px; color: rgba(255, 255, 255, 0.6); }
	.reason.lichess-err { color: rgba(255, 180, 40, 0.95); }
	/* Same purple as the board's premove highlight (ChessBoardView.PremoveTint) —
	   the line and the squares are one statement. */
	.reason.premove { color: rgba(197, 120, 240, 0.95); }

	.moves {
		flex-direction: column;
		max-height: 180px;
		overflow: hidden;
		background-color: rgba(255, 255, 255, 0.05);
		border-radius: 6px;
		padding: 6px 10px;
	}
	.move-row { font-size: 13px; font-family: monospace; color: rgba(255, 255, 255, 0.8); }

	.button {
		padding: 6px 12px;
		background-color: rgba(90, 140, 255, 0.25);
		border-radius: 6px;
		cursor: pointer;
		pointer-events: all;
		font-size: 13px;
		justify-content: center;
	}
	.button:hover { background-color: rgba(90, 140, 255, 0.45); }
	.button.disabled { color: rgba(255, 255, 255, 0.4); pointer-events: none; }
	.button.resign { background-color: rgba(255, 45, 85, 0.25); }
	.button.resign:hover { background-color: rgba(255, 45, 85, 0.5); }


	.button.ghost { background-color: rgba(255, 255, 255, 0.08); }
	.button.ghost:hover { background-color: rgba(255, 255, 255, 0.18); }

	.promo-veil {
		position: absolute;
		left: 0; top: 0;
		width: 100%; height: 100%;
		justify-content: center;
		align-items: center;
		background-color: rgba(0, 0, 0, 0.35);
		pointer-events: all;
	}
	.promo {
		flex-direction: column;
		align-items: center;
		gap: 10px;
		padding: 18px 26px;
		background-color: rgba(10, 10, 14, 0.92);
		border-radius: 12px;
	}
	.promo-title { font-size: 15px; color: rgba(255, 255, 255, 0.8); }
	.promo-row { flex-direction: row; gap: 14px; }
	.promo-pick {
		font-size: 42px;
		color: white;
		padding: 4px 10px;
		border-radius: 8px;
		cursor: pointer;
		pointer-events: all;
		background-color: rgba(255, 255, 255, 0.08);
	}
	.promo-pick:hover { background-color: rgba(90, 140, 255, 0.45); }
	.promo-cancel {
		font-size: 12px;
		color: rgba(255, 255, 255, 0.5);
		cursor: pointer;
		pointer-events: all;
	}
	.promo-cancel:hover { color: white; }
</style>

@code
{
	static ChessStation Station() => ChessStation.Active;
	static LocalGameController Controller() => LocalGameController.For( ChessStation.Active );
	static ChessBoardView View() => ChessStation.Active?.Components.Get<ChessBoardView>();

	static string BoardTitle( LocalGameController ctrl ) =>
		( ctrl?.HasGame ?? false ) ? "GAME" : "CHESS BOARD";

	/// <summary>What the board is waiting for when no game is running.</summary>
	static string WaitingText()
	{
		if ( Station() is not { } s ) return "";
		if ( s.WhiteSteamId == 0 && s.BlackSteamId == 0 ) return "Waiting for players…";
		if ( !BothSeated() ) return "Waiting for an opponent to sit down…";

		// Both seated: the game is now gated on ready, not on occupancy.
		var ctrl = Controller();
		if ( ctrl == null ) return "";
		if ( ctrl.WhiteReady && ctrl.BlackReady ) return "Starting…";
		if ( LocalReady( ctrl ) ) return "Waiting for your opponent to ready up…";
		return "Pick a time control and ready up";
	}

	// ── Time control + ready ──

	/// <summary>The setup block (time control + ready) shows whenever the table isn't
	/// mid-game — a fresh table, or one showing a result and open to a rematch.
	///
	/// <para>Also hidden while a lichess game is IN FLIGHT. A SEEK starts no local
	/// game, so <c>ctrl.Playing</c> stays false for its whole duration — without
	/// this, Ready would sit there clickable under a live lichess game and start a
	/// second, local one behind it.</para>
	///
	/// <para>"In flight", not "on screen": the lichess controller deliberately stays
	/// engaged while the result is displayed, so gating on OnLichess() alone would
	/// leave a finished lichess game with no time control and no Ready — the pair
	/// would have to stand up and re-sit to play again.</para></summary>
	static bool ShowSetup( LocalGameController ctrl ) =>
		ctrl != null && !ctrl.Playing && !LichessInFlight();

	/// <summary>A lichess game is running (or being started) at this board — as
	/// opposed to one whose result is merely still on display.</summary>
	static bool LichessInFlight() =>
		OnLichess() && !( Lichess()?.State?.finished ?? false );

	static bool LocalReady( LocalGameController ctrl ) =>
		ctrl?.LocalSeat is { } seat && ctrl.ReadyFor( seat );

	// ── Lichess (M8) ──

	/// <summary>The lichess controller beside the table we're seated at.</summary>
	static LichessGameController Lichess() => LichessGameController.For( ChessStation.Active );

	/// <summary>Whichever controller owns this board — the same resolution
	/// ChessBoardView.Source does, and for the same reason: everything that reads
	/// the position should be unable to tell a lichess game from a local one.</summary>
	static IBoardGame Source()
	{
		var lc = Lichess();
		return lc is { Engaged: true } ? lc : Controller();
	}

	/// <summary>A real lichess game owns this board right now — the HUD reads
	/// lichess's state instead of the local table's.</summary>
	static bool OnLichess() => Lichess() is { Engaged: true };

	/// <summary>The armed premove on whichever game owns this board, or null. Read
	/// off the seam, not off the lichess controller: a premove at a local table is
	/// just as real, and costs the same clock.</summary>
	static string PremoveUci() =>
		Source()?.PremoveUci is { Length: >= 4 } u ? u : null;

	static bool LocalLichess( LocalGameController ctrl ) =>
		ctrl?.LocalSeat is { } seat && ctrl.LichessFor( seat );

	// ── Seek controls ──
	//
	// Instance state, not static: these are this player's preferences for their
	// next seek, and they don't outlive the HUD.

	bool _seekRated;
	string _seekColor = "random";
	bool _seekNarrow;

	void ToggleSeekRated() { _seekRated = !_seekRated; StateHasChanged(); }
	void ToggleSeekNarrow() { _seekNarrow = !_seekNarrow; StateHasChanged(); }

	void CycleSeekColor()
	{
		_seekColor = _seekColor switch { "random" => "white", "white" => "black", _ => "random" };
		StateHasChanged();
	}

	string SeekColorText() => _seekColor switch
	{
		"white" => "Play White",
		"black" => "Play Black",
		_ => "Either colour",
	};

	/// <summary>lichess's own advice is to leave the rating range empty — a narrow
	/// range on a small pool is a seek that never pairs, and ours are scarce
	/// already. So "near my rating" is a deliberate opt-in, not the default.
	/// <para>gamchess doesn't know the player's lichess rating (we never asked for
	/// a scope that could read it), so the range can't be centred on them — this
	/// asks for a broad middle band instead. Honest about what it can do.</para></summary>
	string SeekRatingRange() => _seekNarrow ? "1400-1800" : null;

	string SeekHint()
	{
		if ( _seekRated ) return "Rated: this will move your real lichess rating.";
		return "Casual: it won't touch your lichess rating.";
	}

	void StartSeek()
	{
		Lichess()?.RequestSeek( _seekRated, SeekRatingRange(), _seekColor );
		StateHasChanged();
	}

	static string LichessText( LocalGameController ctrl ) =>
		LocalLichess( ctrl )
			? $"♞ Playing on lichess as {LichessLinkState.Username} ✓ (click to cancel)"
			: "♞ Play this game on lichess";

	/// <summary>What the opt-in is waiting on, or null when there's nothing to say.
	/// Deliberately honest about the one thing a player can't see: whether the
	/// person opposite has a lichess account at all.</summary>
	static string LichessOptInHint( LocalGameController ctrl )
	{
		if ( ctrl == null || !LocalLichess( ctrl ) ) return null;
		if ( ctrl.BothWantLichess ) return "Both in — this game will be played on lichess for real.";
		return "Waiting for your opponent to opt in too. They need a linked lichess account.";
	}

	/// <summary>The draw button doubles as accept, because lichess's draw/yes does:
	/// offering when one is pending IS accepting it.</summary>
	static string DrawText() =>
		( Lichess()?.DrawOffered ?? false ) ? "Accept draw" : "Offer draw";

	/// <summary>Two states, like the draw button, because lichess's takeback/yes is
	/// the same call for proposing and accepting. There is no third "waiting" state
	/// here: while our own proposal stands the button isn't rendered at all, and the
	/// status line says so instead.</summary>
	static string TakebackText() =>
		( Lichess()?.TakebackOffered ?? false ) ? "Accept takeback" : "Ask for takeback";

	/// <summary>Status line while a lichess game is being set up or run, or null
	/// when there is nothing to say and the turn indicator should show.</summary>
	static string LichessStatus()
	{
		var lc = Lichess();
		if ( lc == null || !lc.Engaged ) return null;
		if ( lc.Error is string e ) return e;

		if ( lc.Seeking ) return "Looking for an opponent on lichess…";

		return lc.State?.status switch
		{
			// A seek needs nobody else's client; only the paired flow waits.
			"waiting" => lc.IsSeek ? "Looking for an opponent on lichess…"
				: "Waiting for your opponent's client…",
			"challenging" => lc.IsSeek ? "Looking for an opponent on lichess…"
				: "Starting the game on lichess…",
			_ => null,
		};
	}

	static string ReadyText( LocalGameController ctrl )
	{
		if ( ctrl?.LocalSeat == null ) return "Ready";
		return LocalReady( ctrl ) ? "Ready ✓ (click to cancel)" : "Ready";
	}

	/// <summary>Seat line: the name, plus the clock once there's a clock to show.
	/// One div per line and no inline markup — CLAUDE.md UI Gotchas.</summary>
	static string SeatLine( LocalGameController ctrl, ChessSeat seat )
	{
		string name = SeatName( seat );

		// LICHESS FIRST — before any question about the local table.
		//
		// A lichess game runs on lichess's clock, not the host's: the host stops
		// ticking its copy entirely (LocalGameController.HostTickClocks), so its
		// value is frozen and meaningless. And a SEEK starts no local game at all,
		// so ctrl.Playing is false for its whole duration — checking the local
		// table first would fall into the idle branch below and never show a seek's
		// clock or its opponent's name.
		if ( OnLichess() )
			return LichessClock( seat ) is float left ? $"{name}  {TimeControl.Format( left )}" : name;

		if ( ctrl == null || ctrl.Tc.IsUnlimited ) return name;

		// Idle table: advertise the bank rather than a running clock, and say who
		// has agreed to what.
		if ( !ctrl.Playing && !ctrl.GameOver )
		{
			if ( ctrl.ReadyFor( seat ) ) return $"{name}  ready";
			return ctrl.LichessFor( seat ) ? $"{name}  ♞" : name;
		}

		return $"{name}  {TimeControl.Format( ctrl.ClockFor( seat ) )}";
	}

	/// <summary>Who is on a side.
	///
	/// <para>During a lichess game the LICHESS names win, because they're who is
	/// actually playing. That matters most for a seek, where the opponent is a
	/// stranger who isn't in this lobby at all and the station has no name for
	/// them — but it's also the honest label for a paired game, where the lichess
	/// account is what the result lands on.</para></summary>
	static string SeatName( ChessSeat seat )
	{
		if ( OnLichess() && Lichess()?.State is { } st )
		{
			string lichessName = seat == ChessSeat.White ? st.white_name : st.black_name;
			if ( !string.IsNullOrEmpty( lichessName ) ) return lichessName;
			if ( Lichess().Seeking || st.seek ) return "…";  // nobody yet
		}

		string name = Station()?.SeatName( seat );
		return string.IsNullOrEmpty( name ) ? "—" : name;
	}

	/// <summary>Seconds left on a seat's clock per lichess, or null when no lichess
	/// game owns this board.</summary>
	static float? LichessClock( ChessSeat seat )
	{
		if ( !OnLichess() ) return null;
		if ( Lichess().State is not { } st ) return null;

		// An unlimited game has no clock to show, and lichess sends 0 for it — which
		// would render as a flagged 0:00.0. Seeks always have a clock (lichess's
		// lobby refuses a clockless real-time seek), so only the table's control can
		// make this happen.
		if ( !st.seek && ( Controller()?.Tc.IsUnlimited ?? false ) ) return null;

		// lichess sends milliseconds; TimeControl.Format takes seconds. Note 0 is
		// NOT filtered here: a genuine flag must read 0:00.0.
		long ms = seat == ChessSeat.White ? st.white_time_ms : st.black_time_ms;
		return ms / 1000f;
	}

	/// <summary>Where the ticking clock turns red. Its own threshold, deliberately not
	/// TimeControl.DecimalBelowSeconds: that one decides when tenths are legible, this one
	/// decides when you're in trouble. A whole bullet game reads in tenths, and colouring
	/// all of it red would say nothing.</summary>
	const float PanicSeconds = 10f;

	/// <summary>Accent the side whose clock is running, and redden it near the flag.</summary>
	static string SeatClass( LocalGameController ctrl, ChessSeat seat )
	{
		// During a lichess game the local controller's clock is FROZEN (the host
		// stops ticking it — lichess owns the clock) and its ChessGame never
		// advances, so ctrl.TickingSeat would be stuck on White for the whole game.
		// Read the live source instead.
		if ( OnLichess() )
		{
			var lc = Lichess();
			if ( !lc.Playing || lc.Game == null ) return "";
			var ticking = lc.Game.WhiteToMove ? ChessSeat.White : ChessSeat.Black;
			if ( ticking != seat ) return "";
			return LichessClock( seat ) is float left && left < PanicSeconds ? "ticking low" : "ticking";
		}

		if ( ctrl == null || ctrl.TickingSeat != seat ) return "";
		return ctrl.ClockFor( seat ) < PanicSeconds ? "ticking low" : "ticking";
	}

	static bool Visible() =>
		ChessStation.Active != null && ( LobbyPlayer.Local?.CameraSettled ?? false );

	/// <summary>Ask whether we're linked, while sitting at a table.
	///
	/// <para>Load-bearing, not housekeeping. Every lichess control here — the opt-in,
	/// the seek, and so the draw and takeback that follow from a game existing — is
	/// behind <c>LichessLinkState.Linked</c>, which starts false and only becomes
	/// true when someone ASKS. Until this existed the only caller was the east-wall
	/// board's own screen, so a linked player who sat down without visiting that wall
	/// first was told to go and link an account they already had, and the table
	/// offered nothing but a local game. It looked exactly like the feature hadn't
	/// shipped.</para>
	///
	/// <para>This keeps the rule that made the old caller narrow — never poll in the
	/// background — by asking only while a station is engaged. LichessLinkState
	/// single-flights, rate-limits to 3s, and early-returns forever once linked, so
	/// per-frame here is its intended use.</para></summary>
	protected override void OnUpdate()
	{
		if ( ChessStation.Active != null )
			LichessLinkState.Poll();
	}

	static bool BothSeated() =>
		Station() is { } s && s.WhiteSteamId != 0 && s.BlackSteamId != 0;

	/// <summary>Whose move it is, read from whichever controller owns the board.
	/// <para>Takes IBoardGame rather than LocalGameController for the same reason
	/// ChessBoardView does: during a lichess game the local controller's ChessGame
	/// never advances (moves go to the relay, not NetChessMove), so asking it whose
	/// turn it is would answer "White" forever.</para></summary>
	static string TurnText( IBoardGame src )
	{
		if ( src?.Game == null ) return "";
		if ( src.IsMyTurn )
			return src.Game.IsCheck ? "Your move — check!" : "Your move";
		return src.Game.WhiteToMove ? "White is thinking…" : "Black is thinking…";
	}

	/// <summary>Last few full-move rows, "12. Nf3 Nc6" style. The list column is
	/// fixed-height with overflow hidden (drag-scroll fights clicks — CLAUDE.md),
	/// so we render only the tail.</summary>
	static IEnumerable<string> MoveRows( IBoardGame src )
	{
		var san = src?.Game?.SanMoves;
		if ( san == null || san.Count == 0 ) yield break;

		const int maxRows = 12;
		int totalRows = ( san.Count + 1 ) / 2;
		for ( int row = Math.Max( 0, totalRows - maxRows ); row < totalRows; row++ )
		{
			int i = row * 2;
			string line = $"{row + 1}. {san[i]}";
			if ( i + 1 < san.Count ) line += $"  {san[i + 1]}";
			yield return line;
		}
	}

	/// <summary>Repaint triggers. The seat lines are hashed as their rendered strings
	/// rather than as raw clock floats: that is what drives the ticking display, and it
	/// repaints exactly when the visible text changes instead of every frame.
	/// <para>Nested because HashCode.Combine tops out at eight arguments.</para></summary>
	protected override int BuildHash()
	{
		var ctrl = Controller();
		var src = Source();
		return System.HashCode.Combine(
			Visible(), ctrl?.GameId, src?.Game?.MoveCount, ctrl?.GameOver,
			src?.IsMyTurn, View()?.PendingPromotion != null,
			LobbyPlayer.Local?.LeaveArmed,
			System.HashCode.Combine(
				System.HashCode.Combine(
					BothSeated(), ctrl?.TimeControlIndex, ctrl?.WhiteReady, ctrl?.BlackReady,
					ctrl?.TickingSeat,
					SeatLine( ctrl, ChessSeat.White ), SeatLine( ctrl, ChessSeat.Black ) ),
				// Lichess: the seat lines already cover its clocks and names (they
				// hash as rendered text), so this is the rest — status, result, draw
				// and takeback offers, the armed premove, whether it owns the board,
				// and the seek controls.
				System.HashCode.Combine(
					System.HashCode.Combine(
						OnLichess(), Lichess()?.State?.status, Lichess()?.State?.finished,
						Lichess()?.DrawOffered, Lichess()?.Error, Lichess()?.Seeking,
						ctrl?.WhiteLichess, ctrl?.BlackLichess ),
					System.HashCode.Combine(
						LichessLinkState.Linked, _seekRated, _seekColor, _seekNarrow,
						Lichess()?.TakebackOffered, Lichess()?.TakebackPending,
						Lichess()?.CanTakeback, PremoveUci() ) ) ) );
	}
}
