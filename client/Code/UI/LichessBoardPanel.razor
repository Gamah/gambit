@using System;
@using System.Linq;
@using Sandbox;
@using Sandbox.UI;
@using Gambit.Api;
@namespace Gambit.UI
@inherits PanelComponent

@* Display-only lichess board on the east wall (see InfoWall). A title card: it
   says whether you're linked and to invite a press of E. Everything that matters
   — the copyable link URL, the disclosure, the unlink button — lives in the
   engaged InfoScreen, because none of it is readable from across the room.

   Link state is read from LichessLinkState, which does the polling; this panel
   never calls gamchess itself. *@

<root>
	<div class="board" style="background-color:@WallTheme.Bg; border-color:@WallTheme.Border;">
		<div class="title">LICHESS</div>
		<div class="divider" style="background-color:@WallTheme.Divider;"></div>
		<div class="status" style="color:@StatusColor()">@StatusLine()</div>
		<div class="hint" style="color:@WallTheme.TextFaint;">Press E</div>
	</div>
</root>

<style>
	@@import "WallTheme.scss";

	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	/* Same intrinsic-pixel-space rules as DevNotesPanel/CenterInfoPanel: tune the
	   px values, never the GO scale, to fix overflow. */
	.board {
		width: 100%;
		height: auto;
		flex-direction: column;
		align-items: stretch;
		justify-content: flex-start;
		padding: 9px 12px;
		border: 1.5px solid;
		border-radius: 7.5px;
		font-family: $wall-font;
		gap: 4px;
	}

	.board > div {
		flex-shrink: 0;
	}

	.title {
		font-size: 10px;
		font-weight: bold;
		letter-spacing: 3px;
		text-align: center;
		color: rgba(220, 220, 220, 0.9);
	}

	.divider {
		height: 0.75px;
		margin: 1.5px 0;
	}

	/* One div per line — a div's auto height doesn't grow for wrapped text. */
	.status {
		font-size: 5.5px;
		text-align: center;
	}

	.hint {
		font-size: 4.5px;
		letter-spacing: 2px;
		text-align: center;
	}
</style>

@code
{
	/// <summary>World half-height of the panel's intrinsic rect per unit of GO
	/// Z-scale (same calibration constant as CenterInfoPanel/DevNotesPanel).</summary>
	[Property] public float HalfHeightPerScale { get; set; } = 18f;

	/// <summary>World units to keep between the content's bottom edge and the floor.</summary>
	[Property] public float FloorClearance { get; set; } = 60f;

	string StatusLine()
	{
		if ( !GamchessAuth.Available ) return "Steam required";
		if ( LichessLinkState.Linked ) return $"linked as {LichessLinkState.Username}";
		if ( LichessLinkState.Offline ) return "offline";
		return "not linked";
	}

	string StatusColor() =>
		LichessLinkState.Linked ? "rgba(130, 220, 130, 0.9)" : WallTheme.TextDim;

	protected override int BuildHash() =>
		HashCode.Combine( LichessLinkState.Linked, LichessLinkState.Username,
			LichessLinkState.Offline, GamchessAuth.Available,
			SettingsModel.SettingsVersion );

	protected override void OnUpdate()
	{
		// Same content-measured floor anchor as the other wall boards: lift the GO
		// so the content's bottom edge sits FloorClearance above z=0.
		var board = Panel?.Children.FirstOrDefault();
		if ( board is null || Panel.Box.Rect.Height <= 0f ) return;

		float rootHalf = HalfHeightPerScale * WorldScale.z;
		float contentHeight = 1.5f * rootHalf * ( board.Box.Rect.Height / Panel.Box.Rect.Height );

		var pos = LocalPosition;
		pos.z = FloorClearance + contentHeight - rootHalf;
		LocalPosition = pos;
	}
}
