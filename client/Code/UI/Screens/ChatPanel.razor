@using System;
@using Sandbox;
@using Sandbox.UI;
@using Gambit.World;
@namespace Gambit.UI.Screens
@inherits PanelComponent

@*
	Lobby text chat now runs on the ENGINE'S built-in overlay (ChatShowUI is true in
	Platform.config), so this panel no longer draws a feed or an input box — the engine
	does both, and messages still route/filter through the host. All that's left here is a
	small hint glyph telling a roaming player which key opens chat.

	This used to be a 288-line custom chat box (feed + TextEntry + fade + word-wrap),
	copied from rotaliate and kept alive only by turning the engine overlay off to redraw
	it worse. terryball threw the same box away ("use the built-in chat"); this is Gambit
	catching up.

	The Chat action is bound to T in Input.config and the overlay opens on it; the keycap
	is read live from the binding (Input.GetButtonOrigin) so a rebind can never make this
	hint lie — the old panel claimed the key was "rebindable in Settings" when nothing
	anywhere wrote a rebind.
*@

<root>
	@if ( CanOpen )
	{
		<div class="chat-hint">
			<div class="key">@ChatKeyLabel()</div>
			<div>Chat</div>
		</div>
	}
</root>

<style>
	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: 90;
	}

	.chat-hint {
		position: absolute;
		left: 16px;
		top: 50%;
		flex-direction: row;
		gap: 6px;
		font-size: 14px;
		color: rgba(255, 165, 0, 0.7);
		text-shadow: 0px 1px 3px rgba(0, 0, 0, 0.8);
		pointer-events: none;
	}

	.chat-hint .key {
		color: rgba(255, 165, 0, 1);
		font-weight: bold;
	}
</style>

@code
{
	/// <summary>Retained stub so <see cref="LobbyPlayer"/>'s "don't walk while typing"
	/// gate still compiles. The engine overlay owns focus now, so this is always false —
	/// that gate is dead code, and that's fine (the engine already stops WASD leaking into
	/// the world while its chat box has focus).</summary>
	public static bool IsOpen => false;

	// Only hint while roaming — a seated player is looking at a board, not the room.
	static bool CanOpen => LobbyPlayer.Local != null && !LobbyPlayer.Local.Engaged;

	// The current chat key, read live from the binding so the hint can't drift from it.
	// Falls back to "T" (the Input.config default) if the origin can't be resolved yet.
	static string ChatKeyLabel()
	{
		var origin = Input.GetButtonOrigin( "Chat" );
		return string.IsNullOrEmpty( origin ) ? "T" : origin.ToUpper();
	}

	protected override int BuildHash() => HashCode.Combine( CanOpen, ChatKeyLabel() );
}
