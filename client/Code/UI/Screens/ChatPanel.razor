@using System;
@using Sandbox;
@using Sandbox.UI;
@using Gambit.World;
@namespace Gambit.UI.Screens
@inherits PanelComponent

@*
	Lobby text chat runs on the ENGINE'S built-in overlay (ChatShowUI is true in
	Platform.config): the feed and input box are the engine's, and messages still
	route/filter through the host. This used to also draw the "which key opens chat" hint,
	but that moved to VoicePanel (M17) so all the bottom-left UX-glyph hints — Chat over G
	(voice) over B (mute) — are drawn by one panel and share the keycap glyph style, each
	read live from its binding (Input.GetButtonOrigin).

	So this panel now draws nothing. It survives only for the IsOpen stub below, which is
	wired into lobby.scene (a serialized component, not self-attaching) and read by
	LobbyPlayer — removing the class would orphan that scene entry.
*@

<root></root>

@code
{
	/// <summary>Retained stub so <see cref="LobbyPlayer"/>'s "don't walk while typing"
	/// gate still compiles. The engine overlay owns focus now, so this is always false —
	/// that gate is dead code, and that's fine (the engine already stops WASD leaking into
	/// the world while its chat box has focus).</summary>
	public static bool IsOpen => false;
}
