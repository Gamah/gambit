@using System
@using Sandbox
@using Sandbox.UI
@using Gambit.World
@using Gambit.Game
@namespace Gambit.UI.Screens
@inherits PanelComponent

@*
	Controls for the spectator wall. A screen-space ScreenPanel, shown only while
	engaged at the SpectatorStation (walk up + press E) — the camera stays put;
	LobbyPlayer frees the cursor. Self-attached to the scene ScreenPanel at runtime by
	LobbyPlayer.EnsureSpectatorScreen (no scene rewire). The board itself renders on the
	wall (SpectatorBoard3D); this just picks which table it shows.

	The wall cycles live sbox tables and then lichess TV (M9), so "Next" steps through all
	of them — TV is one more source, not a mode.

	THIS IS THE ONLY BOARD FOR TV. Channel, follow-the-lobby, and on/off all live here and
	nowhere else. They were briefly split across the south-wall settings board, which meant
	picking a channel on one wall for a board on another — and the lobby's channel was a
	third control on a third row. One board, because this is the one you are standing at
	when you care what's on.

	The admin uses the SAME picker: theirs moves the lobby's suggestion instead of setting a
	personal override, so "follow the lobby" is meaningless for them (it is all they can
	ever be doing) and is hidden rather than shown as a dead toggle.
*@

<root>
	@if ( SpectatorStation.Active != null )
	{
		var c = SpectatorController.Instance;
		var admin = LobbyNetworkManager.LocalIsAdmin;
		bool tvOn = SpectatorController.TvEnabled;
		bool following = SpectatorController.FollowingLobbyTv;
		string watching = SpectatorController.DesiredChannel;

		<div class="screen-fit">
			<div class="spectate">
				<div class="title">SPECTATE</div>
				<div class="now">@( c?.ChannelLabel ?? "—" )</div>

				<div class="section">SOURCE</div>
				<div class="row">
					<div class="button" onclick="@( () => c?.CycleFeatured() )">Next</div>
					<div class="button @( tvOn ? "" : "ghost" )"
						 onclick="@( () => SpectatorController.SetTvEnabled( !tvOn ) )">
						@( tvOn ? "lichess TV: on" : "lichess TV: off" )
					</div>
				</div>

				@if ( !string.IsNullOrEmpty( c?.StatusText ) )
				{
					<div class="status">@c.StatusText</div>
				}

				@if ( tvOn )
				{
					<div class="section">TV CHANNEL — @( LichessTv.Label( watching ) )</div>

					@if ( !admin )
					{
						<div class="row">
							<div class="button @( following ? "" : "ghost" )"
								 onclick="@( () => SpectatorController.FollowLobbyTv() )">
								Follow the lobby (@LichessTv.Label( SpectatorController.SuggestedChannel ))
							</div>
						</div>
					}

					@foreach ( var g in Groups )
					{
						<div class="section">@g.Label</div>
						<div class="row wrap">
							@foreach ( var info in LichessTv.InGroup( g.Group ) )
							{
								var key = info.Key;
								<div class="button chan @( watching == key ? "" : "ghost" )"
									 onclick="@( () => SpectatorController.PickTvChannel( key ) )">
									@info.Label
								</div>
							}
						</div>
					}

					@if ( LichessTv.HidesState( watching ) )
					{
						@* The position is always right; these two keep state off the 64
						   squares, and a viewer should know it exists rather than think the
						   board is broken. *@
						<div class="note">@LichessTv.HiddenStateNote( watching )</div>
					}
					@if ( admin )
					{
						<div class="note">You set the lobby's channel — anyone following it sees this.</div>
					}
				}
				else
				{
					<div class="note">The wall mirrors a live game from the tables.</div>
				}
				<div class="note">Press Escape to leave.</div>
			</div>
		</div>
	}
</root>

<style>
	root { width: 100%; height: 100%; pointer-events: none; }

	.screen-fit {
		position: absolute;
		left: 0; top: 0;
		width: 100%; height: 100%;
		justify-content: center;
		align-items: center;
	}

	/* Wider than the 420 this was: the channel grid is 16 cells over three rows, and
	   at 420 the longer labels ("King of the Hill", "UltraBullet") wrapped to one
	   button per line and the panel became a column of sixteen. */
	.spectate {
		flex-direction: column;
		width: 560px;
		gap: 8px;
		padding: 22px;
		background-color: rgba(10, 10, 14, 0.92);
		border-radius: 14px;
		color: rgba(255, 255, 255, 0.9);
		pointer-events: all;
	}

	.title { font-size: 22px; letter-spacing: 4px; font-weight: bold; }
	.now { font-size: 14px; color: #7fd47f; }
	.section {
		font-size: 12px;
		letter-spacing: 2px;
		color: rgba(255, 255, 255, 0.45);
		margin-top: 10px;
	}
	.row { flex-direction: row; gap: 8px; }
	.row.wrap { flex-wrap: wrap; }

	/* Channel buttons sit tighter than the actions above them — there are sixteen,
	   and they're a menu rather than a decision. */
	.button.chan { padding: 6px 10px; font-size: 13px; }

	.button {
		padding: 8px 12px;
		background-color: rgba(90, 140, 255, 0.25);
		border-radius: 6px;
		cursor: pointer;
		font-size: 14px;
		justify-content: center;
	}
	.button:hover { background-color: rgba(90, 140, 255, 0.45); }
	.button.ghost { background-color: rgba(255, 255, 255, 0.08); }
	.button.ghost:hover { background-color: rgba(255, 255, 255, 0.18); }

	.input {
		background-color: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.15);
		border-radius: 6px;
		padding: 7px 9px;
		font-size: 13px;
		color: white;
	}

	.status { font-size: 13px; color: rgba(255, 255, 255, 0.6); margin-top: 6px; }
	.note { font-size: 11px; color: rgba(255, 255, 255, 0.4); margin-top: 6px; }
</style>

@code
{
	/// <summary>The channel groups, in the order they're shown. Speeds first — they're
	/// what most people want — then variants, then bots. Labels are ours; the grouping
	/// itself comes from <see cref="LichessTv.Group"/>.</summary>
	static readonly (LichessTv.Group Group, string Label)[] Groups =
	{
		( LichessTv.Group.Speed, "SPEEDS" ),
		( LichessTv.Group.Variant, "VARIANTS" ),
		( LichessTv.Group.Other, "BOTS" ),
	};

	protected override int BuildHash()
	{
		var c = SpectatorController.Instance;
		// Everything the markup branches on. Miss one and the panel keeps rendering the
		// old answer after a click — the channel grid's highlight is the obvious victim.
		return System.HashCode.Combine( SpectatorStation.Active != null,
			c?.ChannelLabel, c?.StatusText,
			SpectatorController.TvEnabled, SpectatorController.DesiredChannel,
			SpectatorController.FollowingLobbyTv, SpectatorController.SuggestedChannel,
			LobbyNetworkManager.LocalIsAdmin );
	}
}
