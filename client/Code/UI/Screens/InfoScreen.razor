@using System;
@using System.Collections.Generic;
@using Sandbox;
@using Sandbox.UI;
@using Gambit.Api;
@using Gambit.World;
@using Gambit.UI;
@namespace Gambit.UI.Screens
@inherits PanelComponent

@*
	Interactive info / dev-notes viewer opened when the player engages an InfoStation
	("Press E to view"). Shown (centered on screen) while InfoStation.Active != null; the
	camera doesn't move for boards, LobbyPlayer just frees the cursor. Mirrors the
	screen-engage pattern (.screen-fit centering wrapper). The Discord link is
	click-to-copy (DiscordButton.Copy); dev notes are read from DevNotesPanel.Notes.
*@

<root>
@{ var station = InfoStation.Active; }
@if ( station != null )
{
	<div class="screen-fit">
	<div class="info-fit" style="background-color:@WallTheme.Bg; border:1.5px solid @WallTheme.Border;">
		<div class="close" onclick="@Close">✕</div>

		@if ( station.Kind == InfoStation.StationKind.Lichess )
		{
			<div class="title" style="color:@WallTheme.Text;">LICHESS</div>
			<div class="divider" style="background-color:@WallTheme.Divider;"></div>

			@if ( !Gambit.Api.GamchessAuth.Available )
			{
				<div class="body" style="color:@WallTheme.TextFaint;">Linking needs Steam. This build isn't signed in to one, so lichess is off — local chess is unaffected.</div>
			}
			else if ( LichessLinkState.Linked )
			{
				<div class="linked-row">✓  linked as @LichessLinkState.Username</div>
				<div class="body" style="color:@WallTheme.TextDim;">Sit at a table with another linked player. When you both choose "play on lichess", a real game runs on lichess between your accounts and shows up in your lichess history.</div>
				<div class="body" style="color:@WallTheme.TextDim;">Bullet tables can't do this — lichess won't play anything faster than blitz.</div>

				<div class="divider" style="background-color:@WallTheme.Divider;"></div>

				<div class="section-header warn">TURNING THIS OFF</div>
				<div class="body warn-body">Changing your lichess password will NOT unlink Gambit — it only ends browser sessions and leaves this token working.</div>
				<div class="body warn-body">Unlink below, or revoke it on lichess's own Security page. (Their /account/oauth/token page won't show this grant — it lists personal tokens only.)</div>

				<div class="lichess-btn" onclick="@Unlink">@UnlinkLabel()</div>
				<div class="lichess-btn subtle" onclick="@CopySecurity">@SecurityLabel()</div>
			}
			else
			{
				<div class="body" style="color:@WallTheme.TextDim;">Link your lichess account and you can play real, rated-history lichess games from a table here — against whoever sits opposite you.</div>

				<div class="divider" style="background-color:@WallTheme.Divider;"></div>

				<div class="section-header" style="color:@WallTheme.AccentCss;">WHAT LINKING DOES</div>
				<div class="body" style="color:@WallTheme.TextDim;">Steam asks for your Steam password on steamcommunity.com. Lichess asks for your lichess password on lichess.org.</div>
				<div class="body" style="color:@WallTheme.TextDim;">Terry's Gambit never sees either one.</div>

				<div class="section-header" style="color:@WallTheme.AccentCss;">WHAT WE ASK FOR</div>
				<div class="body" style="color:@WallTheme.TextDim;">One permission: board:play. It lets us start your game, play your moves, resign and offer draws.</div>
				<div class="body" style="color:@WallTheme.TextDim;">It cannot read your email, read or send messages, see who you follow, or change your account. Lichess has nothing smaller — it's all-or-nothing.</div>

				<div class="section-header" style="color:@WallTheme.AccentCss;">WHERE THE KEY LIVES</div>
				<div class="body" style="color:@WallTheme.TextDim;">On our server, encrypted. It has to: playing a lichess game means holding a live connection open for the whole game, which this client can't do — so our server plays on your behalf while you sit here.</div>

				<div class="divider" style="background-color:@WallTheme.Divider;"></div>

				<div class="body" style="color:@WallTheme.TextFaint;">Copy this link and open it in a browser. It's the same link for everyone and holds no secret — it signs you in with Steam first, so it only ever links your own accounts.</div>
				<div class="lichess-btn" onclick="@CopyLichess">@LichessLabel()</div>

				@if ( LichessLinkState.Offline )
				{
					<div class="body" style="color:@WallTheme.TextFaint;">(Can't reach the Gambit server right now, so we can't tell if you're linked. Chess still works.)</div>
				}
			}
		}
		else if ( station.Kind == InfoStation.StationKind.DevNotes )
		{
			<div class="title amber">DEV NOTES</div>
			<div class="divider" style="background-color:@WallTheme.Divider;"></div>
			@if ( DevNotesPanel.Notes.Count == 0 )
			{
				<div class="body" style="color:@WallTheme.TextFaint;">No dev notes right now.</div>
			}
			else
			{
				@foreach ( var note in DevNotesPanel.Notes )
				{
					<div class="dev-notice">⚠  @note</div>
				}
			}
		}
		else
		{
			<div class="title" style="color:@WallTheme.Text;">Welcome to TERRY'S GAMBIT</div>
			<div class="tagline" style="color:@WallTheme.TextFaint;">Chess in the lobby</div>

			<div class="divider" style="background-color:@WallTheme.Divider;"></div>

			<div class="section-header" style="color:@WallTheme.AccentCss;">HOW TO PLAY</div>
			<div class="body" style="color:@WallTheme.TextDim;">Walk up to either side of a chess table and press E to take a seat — a friend takes the other side. You play the colour you walked up to. Escape stands you up; leaving a live game twice resigns it.</div>
			<div class="body" style="color:@WallTheme.TextDim;">Pick a time control at the table before you start: Bullet 1+0, Blitz 3+0, Rapid 10+0, Classical 30+0, or Unlimited. Clocks run on the board and on the wall.</div>

			<div class="divider" style="background-color:@WallTheme.Divider;"></div>

			<div class="section-header" style="color:@WallTheme.AccentCss;">YOUR GAMES ARE KEPT</div>
			@* "Finished games are saved", not "every finished game is saved": the archive
			   is best-effort by design. gamchess is never required, so if it's down the
			   game plays on and nothing is stored — promising "every" would be false in
			   exactly the case the player can't see. *@
			<div class="body" style="color:@WallTheme.TextDim;">Finished games are saved and replayable at chess.gamah.net — sign in with Steam. Your archive is private: you only ever see games you sat in.</div>

			<div class="divider" style="background-color:@WallTheme.Divider;"></div>

			<div class="section-header" style="color:@WallTheme.AccentCss;">PLAY ON LICHESS FOR REAL</div>
			<div class="body" style="color:@WallTheme.TextDim;">Link a lichess account at the board next door and a game here can be a real game there, in your real lichess history — against the person opposite you, or a stranger from lichess's lobby.</div>
			@* Named because they're the controls a lichess player expects to find and
			   would otherwise assume are missing. Premove is deliberately described
			   by what it does, not by its name: it is the only one of the three that
			   isn't a request to the opponent. *@
			<div class="body" style="color:@WallTheme.TextDim;">Offer a draw or ask for a takeback from the game panel — your opponent has to agree. On their turn you can click out your reply in advance: it plays the moment they move.</div>

			<div class="divider" style="background-color:@WallTheme.Divider;"></div>

			<div class="section-header" style="color:@WallTheme.AccentCss;">THE BIG BOARD</div>
			<div class="body" style="color:@WallTheme.TextDim;">The north wall shows a live game: any table in this room, or lichess TV — the best game in progress on lichess right now. Walk up and press E to change channel, or turn TV off.</div>

			<div class="divider" style="background-color:@WallTheme.Divider;"></div>

			@* Only things that are genuinely NOT built. Checked against the code, not
			   remembered: chat exists on lichess's Board API and is not wired up
			   (PLAN.md), and the piece set is procedural with CC0 models on file (D5).
			   Takebacks came OFF this list when they shipped — which is the whole
			   hazard of this section, so re-check it rather than trusting it.
			   "Rated games" nearly went in here and would have been false — lichess games
			   already take a `rated` flag. This is the copy that rots; re-check it. *@
			<div class="section-header" style="color:@WallTheme.AccentCss;">COMING SOON</div>
			<div class="body" style="color:@WallTheme.TextDim;">Chat on lichess games · a proper 3D piece set</div>

			<div class="discord-btn" onclick="@CopyDiscord">@DiscordLabel()</div>
		}

		<div class="close-hint" style="color:@WallTheme.TextFaint;">Press E or Esc to close</div>
	</div>
	</div>
}
</root>

<style>
	@@import "../WallTheme.scss";

	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	/* Centering must happen on an absolutely-positioned full-screen child, NOT on
	   root — the shared .screen-fit pattern. */
	.screen-fit {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		align-items: center;
		justify-content: center;
		pointer-events: none;
	}

	/* Sizes are 1.6× the base tuning so the engaged viewer reads large on screen. */
	.info-fit {
		width: 992px;
		flex-direction: column;
		border-radius: $wall-radius;
		font-family: $wall-font;
		padding: 24px 34px;
		gap: 8px;
		pointer-events: all;
	}

	.info-fit > div {
		flex-shrink: 0;
	}

	.title {
		font-size: 34px;
		font-weight: bold;
		letter-spacing: 5px;
		text-align: center;
	}

	.title.amber {
		color: rgba(255, 165, 0, 0.9);
	}

	.tagline {
		font-size: 17px;
		text-align: center;
		letter-spacing: 2px;
	}

	.divider {
		height: 2px;
		margin: 3px 0;
	}

	.section-header {
		font-size: 18px;
		font-weight: bold;
		letter-spacing: 3px;
	}

	.body {
		font-size: 18px;
		line-height: 1.35;
		white-space: pre-wrap;
	}

	.note {
		font-size: 19px;
		font-style: italic;
	}

	.dev-notice {
		font-size: 21px;
		color: rgba(255, 165, 0, 0.85);
		background-color: rgba(255, 165, 0, 0.08);
		border-radius: $wall-radius;
		padding: 10px 14px;
		margin-bottom: 3px;
	}

	.discord-btn {
		justify-content: center;
		margin-top: 10px;
		padding: 14px 22px;
		background-color: rgba(88, 101, 242, 0.25);
		border: 2px solid rgba(88, 101, 242, 0.6);
		border-radius: $wall-radius;
		font-size: 22px;
		color: rgba(255, 255, 255, 0.9);
		font-weight: bold;
		cursor: pointer;
		pointer-events: all;
	}

	.discord-btn:hover {
		background-color: rgba(88, 101, 242, 0.4);
	}

	/* Lichess: the site's own black-on-white, so the button reads as "this goes to
	   lichess" rather than as another Gambit control. */
	.lichess-btn {
		justify-content: center;
		margin-top: 8px;
		padding: 12px 22px;
		background-color: rgba(240, 240, 240, 0.2);
		border: 2px solid rgba(240, 240, 240, 0.55);
		border-radius: $wall-radius;
		font-size: 20px;
		color: rgba(255, 255, 255, 0.92);
		font-weight: bold;
		cursor: pointer;
		pointer-events: all;
	}

	.lichess-btn:hover {
		background-color: rgba(240, 240, 240, 0.35);
	}

	/* The Security-page copy is the honest escape hatch, not the main action. */
	.lichess-btn.subtle {
		background-color: rgba(240, 240, 240, 0.06);
		border-color: rgba(240, 240, 240, 0.25);
		font-size: 17px;
		font-weight: normal;
	}

	.linked-row {
		justify-content: center;
		padding: 10px;
		border-radius: $wall-radius;
		background-color: rgba(130, 220, 130, 0.12);
		border: 2px solid rgba(130, 220, 130, 0.45);
		color: rgba(150, 235, 150, 0.95);
		font-size: 21px;
		font-weight: bold;
	}

	/* Close affordances (the panel auto-opens on first load — make dismissing obvious). */
	.close {
		position: absolute;
		right: 20px;
		top: 15px;
		font-size: 30px;
		color: rgba(255, 255, 255, 0.4);
		cursor: pointer;
		pointer-events: all;
	}
	.close:hover { color: white; }

	.close-hint {
		margin-top: 14px;
		font-size: 17px;
		letter-spacing: 3px;
		text-align: center;
	}

	/* The 10+0-only caveat stands out in amber. */
	.section-header.warn { color: rgba(255, 180, 40, 0.95); }
	.body.warn-body { color: rgba(255, 210, 130, 0.9); }


	.prizes-notice {
		justify-content: center;
		margin-top: 10px;
		padding: 14px 22px;
		background-color: rgba(44, 200, 20, 0.25);
		border: 2px solid rgba(88, 101, 242, 0.6);
		border-radius: $wall-radius;
		font-size: 22px;
		color: rgba(255, 255, 255, 0.9);
		font-weight: bold;
	}
</style>

@code
{
	string DiscordLabel() =>
		DiscordButton.SinceCopied < 2f
			? "✓  Discord invite copied to clipboard"
			: $"Check out the Discord: {DiscordButton.InviteCode}  ·  click to copy";

	void CopyDiscord()
	{
		DiscordButton.Copy();
		StateHasChanged();
	}

	// ── Lichess (M8) ──

	string LichessLabel() =>
		LichessButton.SinceCopied < 2f
			? "✓  link copied — paste it in a browser"
			: $"{Gambit.Api.LichessApi.LinkUrl}  ·  click to copy";

	string SecurityLabel() =>
		LichessButton.SinceSecurityCopied < 2f
			? "✓  copied"
			: "Revoke on lichess yourself: lichess.org/account/security  ·  click to copy";

	string UnlinkLabel() => _unlinking ? "unlinking…" : "[ unlink ]";

	bool _unlinking;

	void CopyLichess()
	{
		LichessButton.Copy();
		StateHasChanged();
	}

	void CopySecurity()
	{
		LichessButton.CopySecurity();
		StateHasChanged();
	}

	// Claim before awaiting — a click that fires while the first is in flight would
	// otherwise send a second DELETE.
	async void Unlink()
	{
		if ( _unlinking ) return;
		_unlinking = true;
		StateHasChanged();

		await LichessLinkState.Unlink();

		_unlinking = false;
		StateHasChanged();
	}

	/// <summary>Dismiss the welcome/info panel (X, or the "close" hint). Disengaging the info
	/// station marks it seen so it won't auto-pop again — same as pressing E/Esc.</summary>
	void Close() => LobbyPlayer.Local?.Disengage();

	/// <summary>Poll the link status ONLY while the lichess board is engaged, never
	/// in the background. LichessLinkState rate-limits and single-flights, so
	/// calling it per-frame here is the intended use — the gate that matters is
	/// that we don't call it at all otherwise.</summary>
	protected override void OnUpdate()
	{
		if ( InfoStation.Active?.Kind == InfoStation.StationKind.Lichess )
			LichessLinkState.Poll();
	}

	protected override int BuildHash() =>
		HashCode.Combine( InfoStation.Active != null, InfoStation.Active?.Kind,
			DevNotesPanel.Notes.Count, DiscordButton.SinceCopied < 2f, SettingsModel.SettingsVersion,
			HashCode.Combine( LichessLinkState.Linked, LichessLinkState.Username,
				LichessLinkState.Offline, LichessButton.SinceCopied < 2f,
				LichessButton.SinceSecurityCopied < 2f, _unlinking ) );
}
