@using System;
@using System.Collections.Generic;
@using Sandbox;
@using Sandbox.UI;
@using Gambit.World;
@using Gambit.UI;
@namespace Gambit.UI.Screens
@inherits PanelComponent

@*
	Interactive info / dev-notes viewer opened when the player engages an InfoStation
	("Press E to view"). Shown (centered on screen) while InfoStation.Active != null; the
	camera doesn't move for boards, LobbyPlayer just frees the cursor. Mirrors the
	screen-engage pattern (.screen-fit centering wrapper). The Discord link is
	click-to-copy (DiscordButton.Copy); dev notes are read from DevNotesPanel.Notes.
*@

<root>
@{ var station = InfoStation.Active; }
@if ( station != null )
{
	<div class="screen-fit">
	<div class="info-fit" style="background-color:@WallTheme.Bg; border:1.5px solid @WallTheme.Border;">
		<div class="close" onclick="@Close">✕</div>

		@if ( station.Kind == InfoStation.StationKind.DevNotes )
		{
			<div class="title amber">DEV NOTES</div>
			<div class="divider" style="background-color:@WallTheme.Divider;"></div>
			@if ( DevNotesPanel.Notes.Count == 0 )
			{
				<div class="body" style="color:@WallTheme.TextFaint;">No dev notes right now.</div>
			}
			else
			{
				@foreach ( var note in DevNotesPanel.Notes )
				{
					<div class="dev-notice">⚠  @note</div>
				}
			}
		}
		else
		{
			<div class="title" style="color:@WallTheme.Text;">Welcome to TERRY'S GAMBIT</div>
			<div class="tagline" style="color:@WallTheme.TextFaint;">Chess in the lobby</div>

			<div class="divider" style="background-color:@WallTheme.Divider;"></div>

			<div class="section-header" style="color:@WallTheme.AccentCss;">HOW TO PLAY</div>
			<div class="body" style="color:@WallTheme.TextDim;">Walk up to either side of a chess table and press E to take a seat — a friend takes the other side. Escape stands you up. Live games from the tables show on the west wall.</div>

			<div class="divider" style="background-color:@WallTheme.Divider;"></div>


			<div class="divider" style="background-color:@WallTheme.Divider;"></div>

			<div class="section-header warn">RIGHT NOW: 10+0 GAMES ONLY</div>
			<div class="body warn-body">Playing a real game currently means Rapid 10+0 (ten minutes each, no increment), and the clock isn't shown on the board yet. On-board clocks, other time controls (bullet, blitz, classical) and more modes are coming soon.</div>

			<div class="divider" style="background-color:@WallTheme.Divider;"></div>

			<div class="section-header" style="color:@WallTheme.AccentCss;">COMING SOON</div>
			<div class="body" style="color:@WallTheme.TextDim;">On-board clocks · more time controls · rated games · tournaments</div>

			<div class="discord-btn" onclick="@CopyDiscord">@DiscordLabel()</div>
		}

		<div class="close-hint" style="color:@WallTheme.TextFaint;">Press E or Esc to close</div>
	</div>
	</div>
}
</root>

<style>
	@@import "../WallTheme.scss";

	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	/* Centering must happen on an absolutely-positioned full-screen child, NOT on
	   root — the shared .screen-fit pattern. */
	.screen-fit {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		align-items: center;
		justify-content: center;
		pointer-events: none;
	}

	/* Sizes are 1.6× the base tuning so the engaged viewer reads large on screen. */
	.info-fit {
		width: 992px;
		flex-direction: column;
		border-radius: $wall-radius;
		font-family: $wall-font;
		padding: 24px 34px;
		gap: 8px;
		pointer-events: all;
	}

	.info-fit > div {
		flex-shrink: 0;
	}

	.title {
		font-size: 34px;
		font-weight: bold;
		letter-spacing: 5px;
		text-align: center;
	}

	.title.amber {
		color: rgba(255, 165, 0, 0.9);
	}

	.tagline {
		font-size: 17px;
		text-align: center;
		letter-spacing: 2px;
	}

	.divider {
		height: 2px;
		margin: 3px 0;
	}

	.section-header {
		font-size: 18px;
		font-weight: bold;
		letter-spacing: 3px;
	}

	.body {
		font-size: 18px;
		line-height: 1.35;
		white-space: pre-wrap;
	}

	.note {
		font-size: 19px;
		font-style: italic;
	}

	.dev-notice {
		font-size: 21px;
		color: rgba(255, 165, 0, 0.85);
		background-color: rgba(255, 165, 0, 0.08);
		border-radius: $wall-radius;
		padding: 10px 14px;
		margin-bottom: 3px;
	}

	.discord-btn {
		justify-content: center;
		margin-top: 10px;
		padding: 14px 22px;
		background-color: rgba(88, 101, 242, 0.25);
		border: 2px solid rgba(88, 101, 242, 0.6);
		border-radius: $wall-radius;
		font-size: 22px;
		color: rgba(255, 255, 255, 0.9);
		font-weight: bold;
		cursor: pointer;
		pointer-events: all;
	}

	.discord-btn:hover {
		background-color: rgba(88, 101, 242, 0.4);
	}

	/* Close affordances (the panel auto-opens on first load — make dismissing obvious). */
	.close {
		position: absolute;
		right: 20px;
		top: 15px;
		font-size: 30px;
		color: rgba(255, 255, 255, 0.4);
		cursor: pointer;
		pointer-events: all;
	}
	.close:hover { color: white; }

	.close-hint {
		margin-top: 14px;
		font-size: 17px;
		letter-spacing: 3px;
		text-align: center;
	}

	/* The 10+0-only caveat stands out in amber. */
	.section-header.warn { color: rgba(255, 180, 40, 0.95); }
	.body.warn-body { color: rgba(255, 210, 130, 0.9); }


	.prizes-notice {
		justify-content: center;
		margin-top: 10px;
		padding: 14px 22px;
		background-color: rgba(44, 200, 20, 0.25);
		border: 2px solid rgba(88, 101, 242, 0.6);
		border-radius: $wall-radius;
		font-size: 22px;
		color: rgba(255, 255, 255, 0.9);
		font-weight: bold;
	}
</style>

@code
{
	string DiscordLabel() =>
		DiscordButton.SinceCopied < 2f
			? "✓  Discord invite copied to clipboard"
			: $"Check out the Discord: {DiscordButton.InviteCode}  ·  click to copy";

	void CopyDiscord()
	{
		DiscordButton.Copy();
		StateHasChanged();
	}

	/// <summary>Dismiss the welcome/info panel (X, or the "close" hint). Disengaging the info
	/// station marks it seen so it won't auto-pop again — same as pressing E/Esc.</summary>
	void Close() => LobbyPlayer.Local?.Disengage();

	protected override int BuildHash() =>
		HashCode.Combine( InfoStation.Active != null, InfoStation.Active?.Kind,
			DevNotesPanel.Notes.Count, DiscordButton.SinceCopied < 2f, SettingsModel.SettingsVersion );
}
