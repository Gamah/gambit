@using System;
@using Sandbox;
@using Sandbox.UI;
@using Gambit.Api;
@using Gambit.Game;
@using Gambit.World;
@namespace Gambit.UI.Screens
@inherits PanelComponent

@*
	lichess sign-in / anonymous-name entry (PLAN.md M3, D3). Screen-space modal
	attached to the scene ScreenPanel at runtime by LobbyPlayer.EnsureSplash — no
	scene rewire needed (same self-heal spirit as EnsureGameHud). While open,
	LobbyPlayer disables the PlayerController so the cursor is free to click and
	WASD doesn't walk the avatar (exactly like ChatPanel). Escape closes.

	Three sign-in paths, all converging on LichessAuth.SignInWithToken:

	  1. gamchess (M7, primary) — copy the authorize link, approve in the browser,
	     and GamchessSignIn polls the code back over an FP-authed channel. No
	     RETURN paste. Needs Steam + a reachable gamchess.
	  2. OAuth code-paste (fallback) — same PKCE flow, but lichess redirects to a
	     localhost URL that won't load and the player pastes the address bar back.
	  3. Personal token paste (fallback) — a pre-scoped lip_ token.

	2 and 3 must keep working with gamchess dead — that is non-negotiable, and it's
	why StartOAuth resets RedirectUri to localhost rather than trusting it.

	The FIRST paste never goes away: s&box has no API to open a browser or bind a
	loopback listener (CLAUDE.md), so the player always copies the link. M7 removes
	the return paste, not the outbound one.
*@

<root>
	@if ( IsOpen )
	{
		<div class="veil">
			<div class="card">
				<div class="close" onclick="@( () => Close() )">✕</div>
				<div class="brand">TERRY'S GAMBIT</div>

				@if ( LichessAuth.SignedIn )
				{
					<div class="signed">Signed in to lichess as <span class="user">@LichessAuth.Username</span>@( LichessAuth.Rating > 0 ? $" ({LichessAuth.Rating})" : "" )</div>
					<div class="hint">Your account name and rating show on your lobby name tag.</div>
					<div class="btn ghost" onclick="@( () => SignOut() )">Sign out</div>
					<div class="btn primary" onclick="@( () => Close() )">Done</div>
				}
				else
				{
					@if ( GamchessSignIn.Supported )
					{
						<div class="section">SIGN IN WITH LICHESS</div>
						@if ( !GamchessSignIn.Active )
						{
							<div class="hint">Play real lichess games as yourself. We'll copy a link — open it, click <b>Authorize</b>, and the game picks it up on its own. Nothing to paste back.</div>
							<div class="btn primary" onclick="@( () => BeginGamchess() )">Sign in with lichess</div>
							@if ( GamchessSignIn.Phase == GamchessSignInPhase.Failed && !string.IsNullOrEmpty( GamchessSignIn.Error ) )
							{
								<div class="status err">@GamchessSignIn.Error</div>
							}
						}
						else if ( GamchessSignIn.Phase == GamchessSignInPhase.Starting )
						{
							<div class="hint">Starting…</div>
						}
						else if ( GamchessSignIn.Phase == GamchessSignInPhase.Exchanging )
						{
							<div class="hint">Finishing sign-in with lichess…</div>
						}
						else
						{
							<div class="hint">✓ Link copied. Authorize it in your browser and leave this open — the game is watching for it.</div>
							<div class="minor-row">
								<div class="minor" onclick="@( () => CopyGamchessLink() )">copy link again</div>
								<div class="minor" onclick="@( () => CancelGamchess() )">cancel</div>
							</div>
						}
						<div class="or"><span>or paste a token</span></div>
					}
					else
					{
						<div class="section">SIGN IN WITH LICHESS</div>
					}
					<div class="hint">Copy the sign-in link, open it in your browser, click <b>Create</b> (scopes are pre-filled), then paste the <span class="mono">lip_…</span> token here.</div>
					<div class="btn ghost" onclick="@( () => CopyTokenLink() )">@( _tokenLinkCopied < 2f ? "✓ Sign-in link copied" : "Copy sign-in link" )</div>
					<div class="row">
						<TextEntry @ref="_tokenEntry" class="entry" placeholder="Paste lip_… token" />
						<div class="btn primary @(_busy ? "disabled" : "")" onclick="@( () => BeginSignIn() )">@( _busy ? "…" : "Sign in" )</div>
					</div>
					@if ( !string.IsNullOrEmpty( _status ) )
					{
						<div class="status @(_ok ? "ok" : "err")">@_status</div>
					}

					<div class="or"><span>or use OAuth</span></div>
					@if ( !LichessOAuth.Pending )
					{
						<div class="btn ghost small" onclick="@( () => StartOAuth() )">Sign in with lichess (OAuth)</div>
					}
					else
					{
						<div class="hint">✓ Link copied. Authorize in your browser, then paste the page you land on (it won't load — the code is in the address bar):</div>
						<div class="row">
							<TextEntry @ref="_redirectEntry" class="entry" placeholder="Paste the address-bar URL" />
							<div class="btn @(_busy ? "disabled" : "")" onclick="@( () => CompleteOAuth() )">@( _busy ? "…" : "Complete" )</div>
						</div>
						<div class="minor-row">
							<div class="minor" onclick="@( () => CopyOAuthLink() )">copy link again</div>
							<div class="minor" onclick="@( () => CancelOAuth() )">cancel</div>
						</div>
					}

					<div class="or"><span>or</span></div>
					<div class="section">PLAY ANONYMOUSLY</div>
					<div class="hint">Just pick a display name — play locally at a board and get a shareable lichess link afterward.</div>
					<div class="row">
						<TextEntry @ref="_nameEntry" class="entry" placeholder="Display name" maxlength="24" />
						<div class="btn" onclick="@( () => PlayAnon() )">Play</div>
					</div>
				}
			</div>
		</div>
	}
</root>

<style>
	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
		z-index: 100;
	}

	.veil {
		position: absolute;
		left: 0; top: 0;
		width: 100%; height: 100%;
		justify-content: center;
		align-items: center;
		background-color: rgba(0, 0, 0, 0.55);
		pointer-events: all;
	}

	.card {
		flex-direction: column;
		width: 460px;
		padding: 26px 30px;
		gap: 10px;
		background-color: rgba(12, 12, 18, 0.97);
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 14px;
		color: rgba(255, 255, 255, 0.9);
	}

	.close {
		position: absolute;
		right: 14px; top: 12px;
		font-size: 16px;
		color: rgba(255, 255, 255, 0.4);
		cursor: pointer;
		pointer-events: all;
	}
	.close:hover { color: white; }

	.brand {
		font-size: 20px;
		font-weight: bold;
		letter-spacing: 3px;
		text-align: center;
		margin-bottom: 4px;
	}

	.section {
		font-size: 12px;
		font-weight: bold;
		letter-spacing: 2px;
		color: rgba(120, 200, 255, 0.9);
		margin-top: 4px;
	}

	.hint {
		font-size: 13px;
		line-height: 1.4;
		color: rgba(255, 255, 255, 0.6);
	}

	.signed { font-size: 16px; }
	.signed .user { color: #7fd47f; font-weight: bold; }

	.mono { font-family: monospace; color: rgba(255, 255, 255, 0.8); }

	.row { flex-direction: row; gap: 8px; align-items: stretch; }

	.entry {
		flex-grow: 1;
		padding: 9px 12px;
		font-size: 14px;
		color: white;
		background-color: rgba(255, 255, 255, 0.07);
		border: 1px solid rgba(255, 255, 255, 0.25);
		border-radius: 7px;
		pointer-events: all;
	}

	.btn {
		padding: 9px 16px;
		justify-content: center;
		align-items: center;
		background-color: rgba(255, 255, 255, 0.1);
		border-radius: 7px;
		font-size: 14px;
		cursor: pointer;
		pointer-events: all;
	}
	.btn:hover { background-color: rgba(255, 255, 255, 0.2); }
	.btn.primary { background-color: rgba(90, 140, 255, 0.35); }
	.btn.primary:hover { background-color: rgba(90, 140, 255, 0.55); }
	.btn.ghost { background-color: rgba(255, 255, 255, 0.06); }
	.btn.small { padding: 6px 10px; font-size: 12px; }
	.btn.disabled { color: rgba(255, 255, 255, 0.4); pointer-events: none; }

	.minor-row { flex-direction: row; gap: 16px; }
	.minor {
		font-size: 12px;
		color: rgba(255, 255, 255, 0.5);
		cursor: pointer;
		pointer-events: all;
	}
	.minor:hover { color: white; }

	.status { font-size: 13px; }
	.status.ok { color: #7fd47f; }
	.status.err { color: #ff8080; }

	.or {
		flex-direction: row;
		align-items: center;
		justify-content: center;
		margin: 6px 0;
	}
	.or span {
		font-size: 12px;
		color: rgba(255, 255, 255, 0.4);
		letter-spacing: 2px;
	}
</style>

@code
{
	/// <summary>True while the modal is up — LobbyPlayer frees the cursor/locks
	/// movement off this, exactly as it does for ChatPanel.IsOpen.</summary>
	public static bool IsOpen { get; private set; }

	/// <summary>Open the sign-in modal (console command, 401 re-prompt, first run).</summary>
	public static void Open() => IsOpen = true;

	TextEntry _tokenEntry;
	TextEntry _redirectEntry;
	TextEntry _nameEntry;
	bool _focused;
	bool _busy;
	bool _ok;
	string _status;
	string _oauthUrl;                          // the pending authorize URL, for re-copy
	RealTimeSince _tokenLinkCopied = 999f;
	bool _gamchessCopied;                      // copied this attempt's URL yet?

	protected override void OnUpdate()
	{
		if ( !IsOpen ) { _focused = false; return; }

		// Drive the gamchess /code poll. Safe to call unconditionally: it's a no-op
		// unless an attempt is waiting, and it rate-limits itself.
		GamchessSignIn.Tick();

		// The authorize URL only exists once /begin has replied, so the copy can't
		// happen in the click handler — do it the frame it appears. No API exists to
		// open a browser (CLAUDE.md), so copying is the whole affordance.
		if ( !_gamchessCopied && GamchessSignIn.Phase == GamchessSignInPhase.WaitingForBrowser
			&& !string.IsNullOrEmpty( GamchessSignIn.AuthorizeUrl ) )
		{
			Clipboard.SetText( GamchessSignIn.AuthorizeUrl );
			_gamchessCopied = true;
		}

		if ( Input.EscapePressed )
		{
			Input.EscapePressed = false;
			Close();
			return;
		}

		// Focus the field the user is most likely to type/paste into next — the
		// redirect box once OAuth is pending, otherwise the token box. _focused is
		// reset by the OAuth start/cancel handlers so the target can change.
		if ( !_focused && !LichessAuth.SignedIn )
		{
			var field = LichessOAuth.Pending ? _redirectEntry : _tokenEntry;
			if ( field != null )
			{
				field.Focus();
				_focused = true;
			}
		}
	}

	void Close()
	{
		IsOpen = false;
		_focused = false;
		_status = null;
		LichessOAuth.Cancel();
		GamchessSignIn.Reset();
		_gamchessCopied = false;
		StateHasChanged();
	}

	// ── gamchess sign-in (primary — no return paste) ──

	void BeginGamchess()
	{
		_status = null;
		_gamchessCopied = false;
		GamchessSignIn.Begin();          // async; OnUpdate copies the URL when it lands
		StateHasChanged();
	}

	void CopyGamchessLink()
	{
		if ( !string.IsNullOrEmpty( GamchessSignIn.AuthorizeUrl ) )
			Clipboard.SetText( GamchessSignIn.AuthorizeUrl );
	}

	void CancelGamchess()
	{
		GamchessSignIn.Cancel();
		_gamchessCopied = false;
		_focused = false;
		StateHasChanged();
	}

	// ── OAuth code-paste (fallback — works with gamchess down) ──

	void StartOAuth()
	{
		// This flow must always use the localhost redirect, even if a gamchess
		// attempt was mid-flight and left RedirectUri pointing at /callback — the
		// exchange compares it byte-for-byte, so a stale value would 400 here and
		// break the very fallback this exists to be.
		GamchessSignIn.Cancel();
		LichessOAuth.RedirectUri = LichessOAuth.LocalhostRedirectUri;
		_gamchessCopied = false;

		_oauthUrl = LichessOAuth.Start();
		Clipboard.SetText( _oauthUrl );
		_status = null;
		_focused = false;                      // re-focus onto the redirect box
		StateHasChanged();
	}

	void CopyOAuthLink()
	{
		if ( !string.IsNullOrEmpty( _oauthUrl ) ) Clipboard.SetText( _oauthUrl );
	}

	void CancelOAuth()
	{
		LichessOAuth.Cancel();
		_status = null;
		_focused = false;
		StateHasChanged();
	}

	async void CompleteOAuth()
	{
		if ( _busy ) return;
		var redirect = _redirectEntry?.Text?.Trim();
		_busy = true;
		_ok = false;
		_status = "Finishing sign-in with lichess…";
		StateHasChanged();

		var (ok, error) = await LichessOAuth.Complete( redirect );

		_busy = false;
		_ok = ok;
		_status = ok ? null : error;
		if ( ok && _redirectEntry != null ) _redirectEntry.Text = "";
		StateHasChanged();
	}

	// ── Personal-token paste (advanced) ──

	void CopyTokenLink()
	{
		Clipboard.SetText( LichessAuth.TokenCreateUrl );
		_tokenLinkCopied = 0f;
		StateHasChanged();
	}

	async void BeginSignIn()
	{
		if ( _busy ) return;
		var token = _tokenEntry?.Text?.Trim();
		_busy = true;
		_ok = false;
		_status = "Checking with lichess…";
		StateHasChanged();

		var (ok, error) = await LichessAuth.SignInWithToken( token );

		_busy = false;
		_ok = ok;
		if ( ok )
		{
			_status = null;
			if ( _tokenEntry != null ) _tokenEntry.Text = "";
			// Signed in — flip to the signed-in view (stays open so they can confirm).
		}
		else
		{
			_status = error;
		}
		StateHasChanged();
	}

	void PlayAnon()
	{
		var name = _nameEntry?.Text?.Trim();
		if ( string.IsNullOrEmpty( name ) ) { _status = "Enter a display name first."; _ok = false; StateHasChanged(); return; }

		var data = PlayerData.Load() ?? new PlayerData();
		data.Username = name;
		data.Save();
		Close();
	}

	void SignOut()
	{
		LichessAuth.SignOut();
		StateHasChanged();
	}

	// GamchessSignIn.Phase/Error are in here because the gamchess flow advances from
	// a background poll, not a click — without them the panel would sit on "waiting"
	// after sign-in actually succeeded.
	protected override int BuildHash() =>
		System.HashCode.Combine( IsOpen, LichessAuth.SignedIn, LichessAuth.Username,
			System.HashCode.Combine( _busy, _ok, _status, LichessOAuth.Pending, _tokenLinkCopied < 2f ),
			GamchessSignIn.Phase, GamchessSignIn.Error );
}
