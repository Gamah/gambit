@using System;
@using Sandbox;
@using Sandbox.UI;
@using Gambit.Chess;
@using Gambit.Game;
@using Gambit.World;
@namespace Gambit.UI
@inherits PanelComponent

@*
	The face of the clock lying in each table's −Y margin, between the board and White's
	tray (ChessRing.BuildStationClock). Display only — no pointer-events.

	This is where the clocks LIVE now. They were text in a 250px column pinned to the
	right of the screen while the board sat in the middle of it: in a 3+0 game that is
	the wrong place for the number that ends the game.

	ONE ROW, and that is geometry rather than taste. The clock is a thin strip sharing the
	Y margin with a tray, and the face is tilted up out of it — so its height projects
	back into Y and a tall face leans over the board. 1024×128 is what fits. Anything
	added here has to fit on one line at a glance from a seat, or it does not belong on
	this object.

	Everything reads the IBoardGame seam, never LocalGameController. During a lichess game
	the local controller's clocks are FROZEN by the host on purpose (HostTickClocks
	early-returns on LichessGame, so it cannot flag a player who is fine on lichess's
	clock) — a clock reading it would simply never move.
*@

<root>
	@* The centering lives on an absolutely-positioned full-size child, NOT on root —
	   CLAUDE.md's UI gotcha, and every WorldPanel in this repo that renders does exactly
	   this. Centering on root pins the content top-left. *@
	<div class="fit">
		<div class="face @FaceClass( ChessSeat.White )">
			<div class="who">W</div>
			<div class="time">@Face( ChessSeat.White )</div>
		</div>

		@* Material. Only while someone is actually ahead — "level" is the normal state of
		   a chess game and a permanently zeroed gauge is furniture. If it seems never to
		   appear: that is this condition, not a broken panel. Take a piece. *@
		<div class="mid">
			@if ( Advantage() is int adv && adv != 0 )
			{
				<div class="lead @( adv > 0 ? "white" : "black" )">@Lead( adv )</div>
				<div class="track">
					<div class="fill @( adv > 0 ? "white" : "black" )" style="width: @( FillPercent( adv ) )%;"></div>
				</div>
			}
		</div>

		<div class="face @FaceClass( ChessSeat.Black )">
			<div class="who">B</div>
			<div class="time">@Face( ChessSeat.Black )</div>
		</div>
	</div>
</root>

<style>
	@@import "WallTheme.scss";

	/*
		This panel's pixel space is ClockPxWidth × ClockPxHeight (1024 × 128), set by
		ChessRing.BuildStationClock — NOT the WorldPanel default of 512 square. Every px
		below lives in that space, and the face's world scale is DERIVED there so 1024px
		spans the clock body's length. Change the panel size there and these move with it;
		change them here and nothing else does.

		root carries NOTHING but size and pointer-events, and `.fit` does the centering.
		That is not style — it is the one shape every WorldPanel in this repo that renders
		actually uses, and CLAUDE.md's gotcha says why: centre on root and the content pins
		top-left. This panel had root { width: 1024px; align-items: center } and rendered
		wrong; MarqueeNumberPanel, SpectatorSeatPanel, CenterInfoPanel and
		StationScreenPanel all use exactly the two rules below. Copy the working one.
	*/
	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	.fit {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		flex-direction: row;
		align-items: center;
		justify-content: center;
		gap: 30px;
		font-family: $wall-font;
	}

	/* Big: read from a seat across a table, not from a HUD a foot from your face. */
	.face {
		flex-direction: row;
		align-items: center;
		gap: 12px;
		padding: 4px 20px;
		border-radius: 10px;
		background-color: rgba(12, 12, 16, 0.5);
	}

	/*
		"W" / "B" as TEXT, not ⬜ / ⬛ as glyphs. The glyphs are what this panel had, and
		they are emoji: CLAUDE.md's rule is that panel-rendered glyphs paint as colour
		emoji, which at this size made two big square blocks and shoved the actual clock
		off the face. GameHud gets away with them because it renders at 13px in a HUD;
		this does not.
	*/
	.who {
		font-size: 34px;
		font-weight: bold;
		letter-spacing: 2px;
		color: rgba(255, 255, 255, 0.4);
	}

	.time {
		font-size: 76px;
		font-weight: bold;
		color: rgba(255, 255, 255, 0.45);
	}

	/* The running side is the only one worth looking at. */
	.face.on { background-color: rgba(20, 22, 28, 0.92); }
	.face.on .time { color: #e8e6df; }
	.face.on .who { color: rgba(255, 255, 255, 0.7); }

	/* Under TimeControl.PanicSeconds — the same threshold the panic beep starts at,
	   which is why it is a shared constant and not a 10f typed in two files. */
	.face.on.panic .time { color: #ff5f5f; }

	/* Fixed width so the middle column doesn't shove the clocks around as the bar
	   appears and disappears mid-game. */
	.mid {
		width: 300px;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 6px;
	}

	.lead { font-size: 40px; font-weight: bold; }
	.lead.white { color: #e8e6df; }
	.lead.black { color: #9a9aa8; }

	.track {
		width: 260px;
		height: 12px;
		border-radius: 6px;
		background-color: rgba(255, 255, 255, 0.12);
		flex-direction: row;
		align-items: center;
	}

	.fill { height: 12px; border-radius: 6px; }
	.fill.white { background-color: #e8e6df; }
	.fill.black { background-color: #2b2b33; }
</style>

@code {
	/// <summary>Wired by ChessRing at build, exactly as the board view and the sounds are
	/// — same refs, same seam, so all three answer for the same game.
	///
	/// <para>No ChessStation here, unlike them: they need to know whose table this is (the
	/// sounds to pick 2D or 3D, the view to take input). A clock face says the same thing
	/// to everyone who can see it.</para></summary>
	[Property] public LocalGameController Controller { get; set; }
	[Property] public LichessGameController Lichess { get; set; }

	IBoardGame Source => BoardGame.Source( Controller, Lichess );

	/// <summary>
	/// A seat's clock face.
	///
	/// <para><b>An idle table shows the BANK the next game will start with</b>, not a
	/// dash. This is what a real chess clock does: you set it, it reads 3:00, and it does
	/// that until someone presses it. The first version returned SeatClock directly, which
	/// is null whenever nothing is live — so a table nobody had started yet showed "— —"
	/// and read as broken. It was, in fact, the entire reason the clock looked like it had
	/// nothing on it: an idle table is the state you find every table in.</para>
	///
	/// <para>Reads the local controller for the bank on purpose: only an idle table has
	/// one to advertise, and an idle table by definition has no lichess game on it, so
	/// there is no source to disagree with. Once a game IS live, the seam answers and this
	/// branch never runs.</para>
	///
	/// <para><b>An UNLIMITED game says so — "∞", not a dash.</b> There is genuinely no
	/// clock, so the honest thing is to say there is no clock; a dash says nothing and
	/// reads as a clock that failed. This one has already cost a round of "the clock isn't
	/// displaying anything" on a table that was working perfectly and simply had no time
	/// control. **A blank-looking readout and a broken readout must not look the same** —
	/// it is the TV fanfare's lesson (a feature that never fires looks exactly like one
	/// that isn't wired up) arriving on a different wall.</para>
	/// </summary>
	string Face( ChessSeat seat )
	{
		// TimeControl.Format, never our own formatting. It TRUNCATES rather than rounds,
		// which is the house rule: a live clock must never read higher than the time
		// actually left. "{seconds:0.0}" would render 59.96 as "60.0".
		if ( Source?.SeatClock( seat ) is float left ) return TimeControl.Format( left );

		// No live clock. Either the table is idle (advertise the bank the next game
		// starts with, like a real clock does) or the game is untimed (say so).
		var tc = Controller?.Tc;
		if ( tc is null ) return "—";                       // no table at all: nothing to claim
		if ( tc.Value.IsUnlimited ) return "∞";
		return TimeControl.Format( tc.Value.InitialSeconds );
	}

	/// <summary>Whose clock is running, off the seam. Not LocalGameController.TickingSeat:
	/// during a lichess game its ChessGame never advances, so it answers "White" for the
	/// whole game.</summary>
	ChessSeat? Ticking =>
		Source is { Playing: true, Game: { } game } && Source.SeatClock( ChessSeat.White ) != null
			? ( game.WhiteToMove ? ChessSeat.White : ChessSeat.Black )
			: null;

	string FaceClass( ChessSeat seat )
	{
		if ( Ticking != seat ) return "";
		return Source?.SeatClock( seat ) is float left && left < TimeControl.PanicSeconds
			? "on panic" : "on";
	}

	/// <summary>Material balance in pawns, positive for White — or null when there is no
	/// position to read.
	///
	/// <para>Derived from the FEN through CapturedMaterial, never from a tally of
	/// captures: this panel has no history, so a late joiner or a resync would show a
	/// level bar in a game somebody is a rook up in. Same rule the trays follow, and the
	/// same reason.</para></summary>
	int? Advantage()
	{
		var game = Source?.Game;
		if ( game == null ) return null;

		var squares = new char[64];
		for ( int rank = 0; rank < 8; rank++ )
			for ( int file = 0; file < 8; file++ )
				squares[rank * 8 + file] = game.PieceAt( file, rank );

		return CapturedMaterial.Advantage( squares );
	}

	/// <summary>"+3" — always the LEADER's margin, so the sign never has to be read. The
	/// colour says who; the number says by how much.</summary>
	string Lead( int adv ) => $"+{Math.Abs( adv )}";

	/// <summary>How much of the track the leader fills.
	///
	/// <para>Clamped at <see cref="BarFullAt"/> rather than scaled to the theoretical
	/// maximum (~103 pawns). A queen up is a winning game and should look like one;
	/// scaling to the maximum would draw it as a sliver.</para></summary>
	float FillPercent( int adv ) =>
		Math.Min( Math.Abs( adv ), BarFullAt ) / (float)BarFullAt * 100f;

	/// <summary>Material lead at which the bar is full. Nine — a queen. Past that the game
	/// is not more decided in any way a bar can show.</summary>
	const int BarFullAt = 9;

	/// <summary>Repaint on visible change only.
	///
	/// <para>The clock faces are hashed as their RENDERED STRINGS — the job the HUD's seat
	/// lines used to do, moved here with the clock. Hashing the raw float would repaint
	/// every frame of every live table in the ring; hashing the text repaints exactly when
	/// a digit changes. The face classes are in here because the panic colour crosses at
	/// 10.0s independently of anything else in the markup.</para></summary>
	protected override int BuildHash() => System.HashCode.Combine(
		Face( ChessSeat.White ), Face( ChessSeat.Black ),
		FaceClass( ChessSeat.White ), FaceClass( ChessSeat.Black ), Advantage() );
}
