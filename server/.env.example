# Copy to .env and fill in values. Never commit .env to git.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# No password to set: the Postgres port is loopback + internal-network only
# (never exposed publicly) and host access goes through `docker exec` (make psql),
# so the container runs with POSTGRES_HOST_AUTH_METHOD=trust. See docker-compose.yml.
# DATABASE_URL is set by compose, not here — it's the only fatal config key.

# ── App ───────────────────────────────────────────────────────────────────────
PORT=6464

# Public root gamchess is served at (scheme + host, no trailing slash) — Caddy
# terminates TLS on the host and proxies here over loopback.
#
# This is the Steam OpenID realm/return root for the archive viewer's web sign-in.
# Leave blank to disable that sign-in (the server logs a warning and starts).
PUBLIC_BASE_URL=https://chess.gamah.net

# Signs the archive viewer's session cookies. Blank is safe: a random key is
# generated per process, so sessions simply don't survive a restart (one click to
# sign back in). Set it to any long random string to keep sessions across deploys.
# This is a SECRET — anyone holding it can forge a session for any SteamID.
SESSION_SECRET=

# ── Lichess (M8) ──────────────────────────────────────────────────────────────
# There is deliberately no LICHESS_CLIENT_ID here. It is a constant in the code
# (lichess.ClientID), not config: lichess records the redirect ORIGIN on a token
# and never the client_id, so changing it revokes nothing and configures nothing.
# The thing that really differs per instance is the redirect URI, and that already
# derives from PUBLIC_BASE_URL.

# The KEK: encrypts the rotating data keys that seal the lichess tokens at rest
# (AES-256-GCM envelope encryption, M15), 32 bytes. It never seals a token
# directly anymore — it wraps the data keys in lichess_key_versions, and those
# seal the tokens.
#
# BLANK SWITCHES LICHESS OFF ENTIRELY — linking and play are disabled, the
# server warns and starts, and the game is unaffected. It never degrades to
# storing a plaintext token. A key that is SET but malformed is fatal, because
# you meant to set it.
#
# You do NOT request this from lichess — lichess issues nothing (no client id, no
# secret, no API key; it has no client registration at all). This key is ours.
# `make up` / `make testinst` generate it here if it's missing or blank, and
# NEVER touch it once it has a value.
#
# This is a SECRET and the one durable thing to back up. Losing it means every
# link must be redone. To CHANGE it, don't just regenerate (that orphans the
# stored data keys) — rotate: put the new key here, the old one in
# LICHESS_TOKEN_KEY_OLD below, deploy once, then clear OLD. See M15.md.
#
# NOTE the envelope adds no secrecy on this deployment: this file lives on the
# same box as the DB, so a full compromise reads both. Its value is the
# rotate/re-key-without-orphaning capability, not confidentiality vs a DB dump.
#
# The test instance shares this key, deliberately: it runs on the same host and
# reads this same file, so a second key would isolate nothing, and each key only
# ever decrypts its own instance's database (which are already separate).
LICHESS_TOKEN_KEY=

# The PREVIOUS KEK, set ONLY while rotating LICHESS_TOKEN_KEY. For one deploy it
# lets gamchess unwrap any data key the new KEK can't open and re-seal it under
# the new KEK (the logs say "re-wrapped a data key under the new KEK"). Clear it
# on the next deploy. Blank normally — this is not a standing secret.
LICHESS_TOKEN_KEY_OLD=

# How often the data key rotates, in days. Blank ⇒ 30. "0" disables timed
# rotation (versioning and the legacy-row migration still run; there's just no
# automatic re-key). The KEK above is untouched by this — only the data keys roll.
LICHESS_KEY_ROTATION_DAYS=

# Gates POST /api/v1/lichess/audit, which asks lichess which of our stored tokens
# are still live. This is the ONLY fast incident lever we have (see above: no bulk
# revoke), so it is worth having before real users link. Also ours, also
# generated by `make up` — nothing to request. Blank hides the route.
LICHESS_AUDIT_KEY=

# ── Test instance ─────────────────────────────────────────────────────────────
# A second, isolated copy of the whole stack for smoke-testing a branch before
# merging. Started with `make testinst BRANCH=<branch>` (see the Makefile); it
# reads the keys below from THIS file. Runs as its own Compose project
# (gamchess-test) with its own containers/network/volumes, so it never touches
# prod data. Both ports bind 127.0.0.1 only, same as prod.
TEST_PORT=6465
TEST_PG_PORT=5436

# Public URL for the TEST instance's Steam OpenID realm/return root. MUST be
# distinct from PUBLIC_BASE_URL above — the OpenID return has to come back to the
# instance that started the flow, not to prod. Blank disables web sign-in on test.
TEST_PUBLIC_BASE_URL=https://testchess.gamah.net
