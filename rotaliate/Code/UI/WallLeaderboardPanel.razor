@using System;
@using System.Collections.Generic;
@using Sandbox;
@using Sandbox.UI;
@using Rotaliate.Api;
@namespace Rotaliate.UI
@inherits PanelComponent

@*
	Display-only leaderboard board mounted on the lobby's north wall. One panel per
	board kind. Daily/hourly kinds refetch when the puzzle rolls over (the countdown
	itself is a separate WallCountdownPanel floated between each pair). Interaction
	(copying a game ID) is handled by LeaderboardScreen once the player engages
	the pair's LeaderboardStation.
*@

<root>
	<div class="board" style="@BoardStyle()">
		<div class="title" style="color:@WallTheme.Text;">@TitleText()</div>
		<div class="divider" style="background-color:@WallTheme.Divider;"></div>
		@if ( _loading && RowCount == 0 )
		{
			<div class="empty" style="color:@WallTheme.TextFaint;">Loading…</div>
		}
		else if ( RowCount == 0 )
		{
			<div class="empty" style="color:@WallTheme.TextFaint;">No scores yet</div>
		}
		else if ( IsMultiplayer )
		{
			@foreach ( var e in _mpEntries )
			{
				<div class="row" style="color:@WallTheme.TextDim;">
					<div class="rank" style="color:@WallTheme.TextFaint;">@(_mpEntries.IndexOf( e ) + 1)</div>
					<div class="name">@DisplayName( e.Username, e.PlayerTag )</div>
					<div class="score" style="color:@WallTheme.AccentCss;">@e.Wins</div>
				</div>
			}
		}
		else
		{
			@foreach ( var e in _entries )
			{
				<div class="row" style="color:@WallTheme.TextDim;">
					<div class="rank" style="color:@WallTheme.TextFaint;">@e.Rank</div>
					<div class="name">@DisplayName( e.Username, e.PlayerTag )</div>
					<div class="score" style="color:@WallTheme.AccentCss;">@FormatScore( e )</div>
				</div>
			}
		}
	</div>
</root>

<style>
	@@import "WallTheme.scss";

	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	/* Shared WallTheme (see WallTheme.scss). Layout happens in the WorldPanel's fixed
	   intrinsic pixel space, and overflow is CLIPPED at the panel edge — font sizes are
	   fixed px tuned to that space (Box.Rect measurement proved unreliable for
	   WorldPanels; see the heading panel). The GO is uniformly scaled so glyphs aren't
	   stretched; the board occupies a WidthFraction-wide centered sub-rect (BoardStyle). */
	.board {
		position: absolute;
		top: 0;
		height: 100%;
		flex-direction: column;
		align-items: stretch;
		justify-content: flex-start;
		padding: 12px 14px;
		border-radius: $wall-radius;
		font-family: $wall-font;
		gap: 4px;
	}

	.board > div {
		flex-shrink: 0;
	}

	.title {
		justify-content: center;
		white-space: nowrap;
		/* 15px: "HOURLY — MOVES" must fit the WidthFraction sub-rect at the
		   default wall proportions (boards ~0.76 as wide as tall) */
		font-size: 15px;
		font-weight: bold;
		letter-spacing: 2px;
	}

	.divider {
		height: 1.5px;
		margin: 3px 0;
	}

	.empty {
		justify-content: center;
		font-size: 14px;
		margin-top: 12px;
	}

	.row {
		flex-direction: row;
		align-items: center;
		font-size: 14px;
	}

	.rank {
		width: 12%;
	}

	.name {
		flex-grow: 1;
		overflow: hidden;
		white-space: nowrap;
	}

	.score {
		font-weight: bold;
	}
</style>

@code
{
	public enum LbKind
	{
		DailyMoves,
		DailyTime,
		HourlyMoves,
		HourlyTime,
		Multi2,
		Multi4,
	}

	[Property] public LbKind Kind { get; set; } = LbKind.DailyTime;

	/// <summary>How many entries to show.</summary>
	[Property] public int MaxRows { get; set; } = 10;

	/// <summary>Fraction of the (uniformly scaled, square) panel quad's width the
	/// board occupies, centered — set by LeaderboardWall to its width/height scale
	/// ratio so the board keeps its aspect without stretching glyphs.</summary>
	[Property] public float WidthFraction { get; set; } = 1f;

	// Live instances, so a cabinet exit (ArcadeStation.Leave) can refresh every board.
	static readonly List<WallLeaderboardPanel> Instances = new();

	/// <summary>Refetch every wall leaderboard board. Called on scene load (each
	/// board's OnStart) and on every cabinet exit — see ArcadeStation.Leave.</summary>
	public static void RefreshAll()
	{
		foreach ( var p in Instances )
			if ( p.IsValid() ) _ = p.Refresh();
	}

	List<LeaderboardEntry> _entries;
	List<MpWinEntry> _mpEntries;
	bool _loading;
	int _dataVersion; // bumped per refresh so new data with the same count still rebuilds

	string BoardStyle() =>
		$"left: {( 1f - WidthFraction ) * 50f:0.##}%; width: {WidthFraction * 100f:0.##}%;"
		+ $" background-color: {WallTheme.Bg}; border: 2px solid {WallTheme.Border};";

	// Legacy rows with no username show the player_tag instead
	static string DisplayName( string name, string playerTag ) =>
		!string.IsNullOrWhiteSpace( name ) ? name
			: ( string.IsNullOrWhiteSpace( playerTag ) ? "anonymous" : playerTag );

	bool IsMultiplayer => Kind is LbKind.Multi2 or LbKind.Multi4;
	bool IsHourly => Kind is LbKind.HourlyMoves or LbKind.HourlyTime;
	int RowCount => IsMultiplayer ? (_mpEntries?.Count ?? 0) : (_entries?.Count ?? 0);

	string TitleText() => Kind switch
	{
		LbKind.DailyMoves => "DAILY — MOVES",
		LbKind.DailyTime => "DAILY — TIME",
		LbKind.HourlyMoves => "HOURLY — MOVES",
		LbKind.HourlyTime => "HOURLY — TIME",
		LbKind.Multi2 => "2-PLAYER WINS",
		_ => "4-PLAYER WINS",
	};

	static string FormatScore( LeaderboardEntry e )
	{
		if ( e.TotalMoves > 0 && e.DurationMs == 0 )
			return e.TotalMoves.ToString();
		long ms = e.DurationMs;
		int secs = (int)(ms / 1000);
		int frac = (int)(ms % 1000);
		int mins = secs / 60;
		secs %= 60;
		return $"{mins}:{secs:D2}.{frac:D3}";
	}

	protected override void OnEnabled() => Instances.Add( this );

	protected override void OnDisabled() => Instances.Remove( this );

	// Scene load: each board fetches once. Subsequent refreshes come from
	// ArcadeStation.Leave → RefreshAll (no periodic polling for now).
	protected override void OnStart()
	{
		_ = Refresh();
	}

	async System.Threading.Tasks.Task Refresh()
	{
		if ( _loading ) return;
		_loading = true;
		try
		{
			switch ( Kind )
			{
				case LbKind.Multi2:
					_mpEntries = Trim( await ApiClient.GetMultiplayerLeaderboard( 2 ) );
					break;
				case LbKind.Multi4:
					_mpEntries = Trim( await ApiClient.GetMultiplayerLeaderboard( 4 ) );
					break;
				default:
				{
					// Without a puzzle_id the endpoint returns entries across all puzzles,
					// so resolve the current puzzle from the recent list first.
					var recent = IsHourly ? await ApiClient.GetRecentHourly() : await ApiClient.GetRecentDaily();
					var puzzleId = recent is { Count: > 0 } ? recent[0].PuzzleId : null;
					string metric = Kind is LbKind.DailyMoves or LbKind.HourlyMoves ? "moves" : "time";
					_entries = Trim( IsHourly
						? await ApiClient.GetHourlyLeaderboard( metric, puzzleId )
						: await ApiClient.GetDailyLeaderboard( metric, puzzleId ) );
					break;
				}
			}
			_dataVersion++;
		}
		catch ( Exception e )
		{
			Log.Warning( $"[Rotaliate] wall leaderboard ({Kind}) failed: {e.Message}" );
		}
		_loading = false;
		StateHasChanged();
	}

	List<T> Trim<T>( List<T> list )
	{
		if ( list != null && list.Count > MaxRows )
			list.RemoveRange( MaxRows, list.Count - MaxRows );
		return list;
	}

	protected override int BuildHash() =>
		HashCode.Combine( Kind, RowCount, _loading, _dataVersion, WidthFraction, SettingsModel.SettingsVersion );
}
