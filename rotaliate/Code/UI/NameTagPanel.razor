@using System;
@using Sandbox;
@using Sandbox.UI;
@using Rotaliate.World;
@namespace Rotaliate.UI
@inherits PanelComponent

@*
	Floating name tag above a remote player (issue #51): their Steam display name
	first, their Rotaliate username from the API in a smaller font underneath.
	Spawned by LobbyPlayer on proxies only (never on the local avatar), on a
	FacePlayer-billboarded WorldPanel. No pointer events.
*@

<root>
	<div class="tag">
		<div class="steam">@SteamName()</div>
		@if ( ShowRotaliateName() )
		{
			<div class="rota">@Player.RotaliateName</div>
		}
	</div>
</root>

<style>
	root {
		width: 100%;
		height: 100%;
		justify-content: center;
		align-items: center;
		pointer-events: none;
	}

	.tag {
		flex-direction: column;
		align-items: center;
		gap: 1px;
	}

	.steam {
		font-size: 16px;
		font-weight: bold;
		color: white;
		text-shadow: 0px 1px 3px rgba(0, 0, 0, 0.9);
		white-space: nowrap;
	}

	.rota {
		font-size: 11px;
		color: rgba(255, 255, 255, 0.65);
		text-shadow: 0px 1px 2px rgba(0, 0, 0, 0.9);
		white-space: nowrap;
	}
</style>

@code
{
	public LobbyPlayer Player { get; set; }

	string SteamName() =>
		Player?.Network?.Owner?.DisplayName ?? "";

	// The Rotaliate username can be empty (not yet enrolled) or identical to the
	// Steam name — only show the second line when it adds information.
	bool ShowRotaliateName() =>
		!string.IsNullOrWhiteSpace( Player?.RotaliateName ) &&
		!string.Equals( Player.RotaliateName, SteamName(), StringComparison.OrdinalIgnoreCase );

	protected override int BuildHash() =>
		HashCode.Combine( SteamName(), Player?.RotaliateName );
}
