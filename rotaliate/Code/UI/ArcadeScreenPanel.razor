@using System;
@using Sandbox;
@using Sandbox.UI;
@using Rotaliate.World;
@namespace Rotaliate.UI
@inherits PanelComponent

@*
	Attract display drawn on the WorldPanel mounted on the lobby wall.
	The actual game UI is the fullscreen ScreenPanel UI shown while the
	player is locked into the station; this panel is what everyone in the
	room sees on the wall. No pointer-events — input never goes to it.
*@

<root>
	@if ( _station != null && _station.Occupied && ArcadeStation.Active != _station )
	{
		@* Mostly transparent for OTHER players so the lit glass slab (and the
		   spectator cube board) shows through; just a badge naming the occupant *@
		<div class="occupant">▶ @( _station.OccupantName ?? "Someone" )</div>
	}
	else if ( _station?.DemoActive == true )
	{
		@* Fully transparent so the 3D cube board shows through — the demo caption
		   is a separate panel floating in front of the cabinet (DemoInfoPanel) *@
	}
	else if ( ArcadeStation.Active != _station )
	{
		@* Attract screen: translucent emissive content over the cabinet's physical
		   glass slab — the glass/bezel do the lighting, this is just the glow *@
		<div class="frame">
			<div class="title">ROTALIATE</div>
			<div class="subtitle">Press E to play</div>
			<div class="crt-scan"></div>
			<div class="crt-vignette"></div>
		</div>
	}
</root>

<style>
	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	.frame {
		width: 100%;
		height: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 10px;
		background-color: rgba(7, 5, 26, 0.45);
		border-radius: 10px;
	}

	.title {
		font-size: 28px;
		font-weight: bold;
		color: white;
		letter-spacing: 6px;
		text-shadow: 0px 0px 14px rgba(255, 255, 255, 0.9);
	}

	.subtitle {
		font-size: 12px;
		color: rgba(255, 255, 255, 0.55);
		letter-spacing: 2px;
		text-shadow: 0px 0px 8px rgba(255, 255, 255, 0.55);
	}

	// CRT dressing: repeating scanlines + edge vignette over the emissive content
	.crt-scan {
		position: absolute;
		left: 0px; top: 0px; right: 0px; bottom: 0px;
		background-image: linear-gradient(rgba(2, 1, 10, 0.5), rgba(2, 1, 10, 0));
		background-size: 100% 4px;
		background-repeat: repeat;
		border-radius: 10px;
		pointer-events: none;
		animation-name: crt-flicker;
		animation-duration: 3.7s;
		animation-iteration-count: infinite;
	}

	.crt-vignette {
		position: absolute;
		left: 0px; top: 0px; right: 0px; bottom: 0px;
		background-image: radial-gradient(rgba(7, 5, 26, 0), rgba(2, 1, 12, 0.6));
		background-size: 100% 100%;
		background-repeat: no-repeat;
		border-radius: 10px;
		pointer-events: none;
	}

	@@keyframes crt-flicker {
		0% { opacity: 1; }
		50% { opacity: 0.82; }
		100% { opacity: 1; }
	}

	.occupant {
		position: absolute;
		bottom: 6px;
		right: 8px;
		font-size: 9px;
		color: rgba(6, 214, 160, 0.6);
		letter-spacing: 1px;
	}
</style>

@code
{
	ArcadeStation _station;

	protected override void OnStart()
	{
		_station = Components.Get<ArcadeStation>( FindMode.Enabled | FindMode.InSelf | FindMode.InAncestors );
	}

	protected override int BuildHash() =>
		System.HashCode.Combine( _station?.Occupied, _station?.OccupantName,
			_station?.DemoActive, _station?.DemoUsername, _station?.DemoMode,
			ArcadeStation.Active == _station );
}
