@using System;
@using System.Collections.Generic;
@using Sandbox;
@using Sandbox.UI;
@using Rotaliate.Api;
@using Rotaliate.Game;
@namespace Rotaliate.UI.Screens
@inherits PanelComponent

<root>
	@{
		var ctrl = MultiplayerController.Instance;
	}
	<div class="arcade-fit" style="@Rotaliate.World.ArcadeRing.UiRectStyle()">
	@if ( false )
	{
		<div class="screen">
			@if ( ctrl.State == MpState.Connecting )
			{
				<div class="panel">
					<div class="title">CONNECTING…</div>
					<div class="cancel-btn" onclick="@Cancel">Cancel</div>
				</div>
			}
			else if ( ctrl.State == MpState.Lobby && ctrl.LobbyCode == null )
			{
				<div class="panel">
					<div class="mode-label">@( ctrl.Is2P ? "2-PLAYER" : "4-PLAYER" )</div>

					<div class="action-btn primary" onclick="@CreateLobby">Create Lobby</div>

					<div class="divider">— or join —</div>

					<div class="join-row">
						<TextEntry @ref="_joinEntry" placeholder="Lobby code" class="code-input" />
						<div class="action-btn" onclick="@JoinLobby">Join</div>
					</div>

					@if ( ctrl.Error != null )
					{
						<div class="error-msg">@ctrl.Error</div>
					}

					<div class="cancel-btn" onclick="@Cancel">← Back</div>
				</div>
			}
			else if ( ctrl.State == MpState.Lobby && ctrl.LobbyCode != null )
			{
				<div class="panel">
					<div class="mode-label">@( ctrl.Is2P ? "2-PLAYER" : "4-PLAYER" )</div>
					<div class="label">LOBBY CODE</div>
					<div class="code-display" onclick="@CopyCode">@ctrl.LobbyCode  @_copyLabel</div>
					<div class="player-count">@ctrl.LobbyCount / @ctrl.LobbyMax players</div>
					<div class="waiting-msg">Waiting for players…</div>
					<div class="cancel-btn" onclick="@Cancel">← Cancel</div>
				</div>
			}
			else if ( ctrl.State == MpState.WaitingRoom )
			{
				<div class="panel">
					<div class="title">MATCH FOUND</div>
					<div class="label">YOUR COLOR@( ctrl.MyColors?.Length > 1 ? "S" : "" )</div>
					<div class="color-chips">
						@if ( ctrl.MyColors != null )
						{
							@foreach ( var cid in ctrl.MyColors )
							{
								<div class="color-chip" style="background-color: @ColorHex( cid );"></div>
							}
						}
					</div>
					<div class="player-count">@ctrl.LobbyMax players matched</div>
					<div class="action-btn primary ready-btn" onclick="@Ready">Ready</div>
					<div class="cancel-btn" onclick="@Cancel">← Cancel</div>
				</div>
			}
				</div>
	}
	</div>
</root>

<style>
	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	// confines the UI to the cabinet-screen region (transform: scale misplaces
	// content, so it's an explicitly sized box)
	.arcade-fit {
		// left/top/width/height come from ArcadeRing.UiRectStyle() inline
		position: absolute;
		pointer-events: none;
	}

	.screen {
		width: 100%;
		height: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		background-color: #07051a;
		pointer-events: all;
	}

	.panel {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 16px;
		background-color: rgba(255,255,255,0.05);
		border-radius: 16px;
		padding: 40px 52px;
		min-width: 340px;
	}

	.title {
		font-size: 28px;
		font-weight: bold;
		color: white;
		letter-spacing: 6px;
		margin-bottom: 4px;
	}

	.mode-label {
		font-size: 13px;
		color: rgba(255,255,255,0.5);
		letter-spacing: 4px;
		margin-bottom: 4px;
	}

	.label {
		font-size: 11px;
		color: rgba(255,255,255,0.5);
		letter-spacing: 3px;
	}

	.action-btn {
		padding: 11px 28px;
		background-color: rgba(255,255,255,0.1);
		color: white;
		font-size: 15px;
		border-radius: 8px;
		cursor: pointer;
		text-align: center;
		pointer-events: all;
	}

	.action-btn:hover {
		background-color: rgba(255,255,255,0.2);
	}

	.action-btn.primary {
		width: 220px;
		padding: 14px 0px;
		font-size: 17px;
		background-color: rgba(255,255,255,0.12);
	}

	.action-btn.primary:hover {
		background-color: rgba(255,255,255,0.22);
	}

	.ready-btn {
		margin-top: 8px;
	}

	.divider {
		font-size: 13px;
		color: rgba(255,255,255,0.3);
		margin: 4px 0px;
	}

	.join-row {
		display: flex;
		flex-direction: row;
		gap: 10px;
		align-items: center;
	}

	.code-input {
		width: 160px;
		padding: 10px 14px;
		background-color: rgba(255,255,255,0.08);
		color: white;
		font-size: 16px;
		border-radius: 8px;
		border: 1px solid rgba(255,255,255,0.15);
		pointer-events: all;
	}

	.code-display {
		font-size: 28px;
		font-weight: bold;
		color: white;
		letter-spacing: 6px;
		cursor: pointer;
		padding: 8px 16px;
		border-radius: 8px;
		pointer-events: all;
	}

	.code-display:hover {
		background-color: rgba(255,255,255,0.07);
	}

	.player-count {
		font-size: 14px;
		color: rgba(255,255,255,0.55);
	}

	.waiting-msg {
		font-size: 13px;
		color: rgba(255,255,255,0.35);
		font-style: italic;
	}

	.cancel-btn {
		font-size: 14px;
		color: rgba(255,255,255,0.45);
		cursor: pointer;
		padding: 6px 14px;
		border-radius: 6px;
		margin-top: 4px;
		pointer-events: all;
	}

	.cancel-btn:hover {
		color: white;
		background-color: rgba(255,255,255,0.1);
	}

	.error-msg {
		font-size: 13px;
		color: #ff2d55;
		text-align: center;
		max-width: 280px;
	}

	.error-msg.big {
		font-size: 16px;
		margin-bottom: 8px;
	}

	.color-chips {
		display: flex;
		flex-direction: row;
		gap: 10px;
		margin: 4px 0px;
	}

	.color-chip {
		width: 28px;
		height: 28px;
		border-radius: 50%;
	}
</style>

@code
{
	TextEntry _joinEntry;
	string    _copyLabel = "copy";

	static readonly string[] ColorHexTable = { "#07051a", "#AA0000", "#0000AA", "#00AA00", "#AAAA00" };
	static string ColorHex( int id ) => (id >= 0 && id < ColorHexTable.Length) ? ColorHexTable[id] : "#ffffff";

	protected override void OnStart()
	{
		var ctrl = MultiplayerController.Instance;
		if ( ctrl != null ) ctrl.OnStateChanged += () => StateHasChanged();
	}

	void Cancel() => MultiplayerController.Instance?.ReturnToMenu();

	void CreateLobby() => MultiplayerController.Instance?.CreateLobby( false );

	void JoinLobby()
	{
		var code = _joinEntry?.Text?.Trim() ?? "";
		if ( string.IsNullOrEmpty( code ) ) return;
		MultiplayerController.Instance?.JoinLobby( code );
	}

	void Ready() => MultiplayerController.Instance?.SendReady();

	void CopyCode()
	{
		var code = MultiplayerController.Instance?.LobbyCode;
		if ( code == null ) return;
		try
		{
			Clipboard.SetText( code );
			_copyLabel = "✓";
		}
		catch
		{
			_copyLabel = "—";
		}
		StateHasChanged();
	}

	protected override int BuildHash()
	{
		var ctrl = MultiplayerController.Instance;
		return System.HashCode.Combine(
			ctrl?.State,
			ctrl?.LobbyCode,
			ctrl?.LobbyCount,
			ctrl?.Error,
			_copyLabel,
			Rotaliate.World.ArcadeRing.UiRectStyle()
		);
	}
}
