@using System;
@using System.Collections.Generic;
@using Sandbox;
@using Sandbox.UI;
@using Rotaliate.World;
@using Rotaliate.UI;
@namespace Rotaliate.UI.Screens
@inherits PanelComponent

@*
	Interactive info / dev-notes viewer opened when the player engages an InfoStation
	("Press E to view"). Shown (centered on screen) while InfoStation.Active != null; the
	camera doesn't move for boards, LobbyPlayer just frees the cursor. Mirrors the
	LeaderboardScreen engage pattern (.screen-fit centering wrapper). The Discord link is
	click-to-copy (DiscordButton.Copy); dev notes are read from DevNotesPanel.Notes.
*@

<root>
@{ var station = InfoStation.Active; }
@if ( station != null )
{
	<div class="screen-fit">
	<div class="info-fit" style="background-color:@WallTheme.Bg; border:1.5px solid @WallTheme.Border;">
		@if ( station.Kind == InfoStation.StationKind.DevNotes )
		{
			<div class="title amber">DEV NOTES</div>
			<div class="divider" style="background-color:@WallTheme.Divider;"></div>
			@if ( DevNotesPanel.Notes.Count == 0 )
			{
				<div class="body" style="color:@WallTheme.TextFaint;">No dev notes right now.</div>
			}
			else
			{
				@foreach ( var note in DevNotesPanel.Notes )
				{
					<div class="dev-notice">⚠  @note</div>
				}
			}
		}
		else
		{
			<div class="title" style="color:@WallTheme.Text;">Welcome to ROTALIATE</div>
			<div class="tagline" style="color:@WallTheme.TextFaint;">Rotate 2×2 blocks · Form matching groups · Race the clock</div>

			<div class="divider" style="background-color:@WallTheme.Divider;"></div>

			<div class="prizes-notice">Cash prizes are coming in July!!!</div>

			<div class="section-header" style="color:@WallTheme.AccentCss;">HOW TO PLAY</div>
			<div class="body" style="color:@WallTheme.TextDim;">Walk up to any screen and press E to start. Rotate 2×2 blocks on the 10×10 grid to form same-color groups of four. When four identical colors form a square they vanish. Clear your color before your opponents do.</div>

			<div class="divider" style="background-color:@WallTheme.Divider;"></div>

			<div class="section-header" style="color:@WallTheme.AccentCss;">DEFAULT CONTROLS</div>
			<div class="body" style="color:@WallTheme.TextDim;">Keyboard: ↑ ↓ ← → move the selector.   Z rotates counter-clockwise.   X rotates clockwise.</div>
			<div class="body" style="color:@WallTheme.TextDim;">Controller: D-pad moves the selector.   A rotates counter-clockwise.   B rotates clockwise.   X engages a screen, Back leaves it.</div>
			<div class="note" style="color:@WallTheme.TextFaint;">Keyboard and controller bindings can be remapped in the Settings tab on the mode picker screen.</div>

			<div class="divider" style="background-color:@WallTheme.Divider;"></div>

			<div class="section-header" style="color:@WallTheme.AccentCss;">ACCESSIBILITY</div>
			<div class="body" style="color:@WallTheme.TextDim;">Four colorblind palettes available — visit your Profile page to switch.</div>

			<div class="discord-btn" onclick="@CopyDiscord">@DiscordLabel()</div>
		}
	</div>
	</div>
}
</root>

<style>
	@@import "../WallTheme.scss";

	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	/* Centering must happen on an absolutely-positioned full-screen child, NOT on
	   root — same pattern as LeaderboardScreen (.screen-fit). */
	.screen-fit {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		align-items: center;
		justify-content: center;
		pointer-events: none;
	}

	/* Sizes are 1.6× the base tuning so the engaged viewer reads large on screen. */
	.info-fit {
		width: 992px;
		flex-direction: column;
		border-radius: $wall-radius;
		font-family: $wall-font;
		padding: 29px 35px;
		gap: 11px;
		pointer-events: all;
	}

	.info-fit > div {
		flex-shrink: 0;
	}

	.title {
		font-size: 42px;
		font-weight: bold;
		letter-spacing: 6px;
		text-align: center;
	}

	.title.amber {
		color: rgba(255, 165, 0, 0.9);
	}

	.tagline {
		font-size: 19px;
		text-align: center;
		letter-spacing: 2px;
	}

	.divider {
		height: 2px;
		margin: 5px 0;
	}

	.section-header {
		font-size: 19px;
		font-weight: bold;
		letter-spacing: 3px;
	}

	.body {
		font-size: 21px;
		line-height: 1.4;
		white-space: pre-wrap;
	}

	.note {
		font-size: 19px;
		font-style: italic;
	}

	.dev-notice {
		font-size: 21px;
		color: rgba(255, 165, 0, 0.85);
		background-color: rgba(255, 165, 0, 0.08);
		border-radius: $wall-radius;
		padding: 10px 14px;
		margin-bottom: 3px;
	}

	.discord-btn {
		justify-content: center;
		margin-top: 10px;
		padding: 14px 22px;
		background-color: rgba(88, 101, 242, 0.25);
		border: 2px solid rgba(88, 101, 242, 0.6);
		border-radius: $wall-radius;
		font-size: 22px;
		color: rgba(255, 255, 255, 0.9);
		font-weight: bold;
		cursor: pointer;
		pointer-events: all;
	}

	.discord-btn:hover {
		background-color: rgba(88, 101, 242, 0.4);
	}

	.prizes-notice {
		justify-content: center;
		margin-top: 10px;
		padding: 14px 22px;
		background-color: rgba(44, 200, 20, 0.25);
		border: 2px solid rgba(88, 101, 242, 0.6);
		border-radius: $wall-radius;
		font-size: 22px;
		color: rgba(255, 255, 255, 0.9);
		font-weight: bold;
	}
</style>

@code
{
	string DiscordLabel() =>
		DiscordButton.SinceCopied < 2f
			? "✓  Discord invite copied to clipboard"
			: $"Check out the Discord: {DiscordButton.InviteCode}  ·  click to copy";

	void CopyDiscord()
	{
		DiscordButton.Copy();
		StateHasChanged();
	}

	protected override int BuildHash() =>
		HashCode.Combine( InfoStation.Active != null, InfoStation.Active?.Kind,
			DevNotesPanel.Notes.Count, DiscordButton.SinceCopied < 2f, SettingsModel.SettingsVersion );
}
