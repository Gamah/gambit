@using System;
@using Sandbox;
@using Sandbox.UI;
@using Rotaliate.UI;
@using Rotaliate.World;
@namespace Rotaliate.UI.Screens
@inherits PanelComponent

@*
	Interactive editor for the south-wall settings boards (issue #49). The wall
	boards are display-only WorldPanels; this is the real UI — a screen-space
	ScreenPanel shown (centered) while the player is locked onto a board
	(SettingsStation). The camera doesn't move for boards, so this just draws on
	screen. Plain ScreenPanel input, so the cursor and clicks just work. Rows come
	from the shared SettingsModel.
*@

<root>
	@if ( SettingsStation.Active != null && !SettingsStation.Active.Music )
	{
	<div class="board-fit">
		<div class="settings" style="background-color:@WallTheme.Bg; border:1.5px solid @WallTheme.Border;">
			<div class="title" style="color:@WallTheme.Text;">@( SettingsStation.Active.Host ? "HOST SETTINGS" : "WORLD SETTINGS" )</div>
			<div class="divider" style="background-color:@WallTheme.Divider;"></div>
			@foreach ( var row in Rows() )
			{
				<div class="row">
					<div class="label" style="color:@WallTheme.TextFaint;">@row.Label</div>
					@if ( row.Cells.Count > 0 )
					{
						<div class="cells">
							@foreach ( var cell in row.Cells )
							{
								var c = cell;
								<div class="cell @c.Css @( c.Selected ? "selected" : "" ) @( c.Activate == null ? "disabled" : "" )" style="@CellStyle( c )" onclick="@( () => Click( c ) )">@c.Label</div>
							}
						</div>
					}
				</div>
			}
		</div>
	</div>
	}
</root>

<style>
	@@import "../WallTheme.scss";

	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	// camera no longer moves for boards — just centre the panel on the screen
	.board-fit {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		align-items: center;
		justify-content: center;
		pointer-events: none;
	}

	.settings {
		width: 620px;
		flex-direction: column;
		align-items: stretch;
		justify-content: flex-start;
		padding: 28px 34px;
		border-radius: $wall-radius;
		font-family: $wall-font;
		gap: 14px;
		pointer-events: all;
	}

	.settings > div {
		flex-shrink: 0;
	}

	.title {
		justify-content: center;
		white-space: nowrap;
		font-size: 26px;
		font-weight: bold;
		letter-spacing: 4px;
	}

	.divider {
		height: 2px;
		margin: 6px 0;
	}

	.row {
		flex-direction: column;
		gap: 6px;
	}

	.label {
		font-size: 16px;
		letter-spacing: 2px;
		white-space: nowrap;
	}

	.cells {
		flex-direction: row;
		gap: 8px;
	}

	/* Base bg/colour are inline (runtime theme, CellStyle); only layout + the hover/
	   selected border feedback live here. Inline bg defeats a :hover bg, so hover
	   feedback is the border alone. */
	.cell {
		justify-content: center;
		align-items: center;
		font-size: 16px;
		border: 2px solid transparent;
		border-radius: $wall-radius;
		cursor: pointer;
		pointer-events: all;
	}

	.cell:hover {
		border: 2px solid rgba(255, 255, 255, 0.6);
	}

	.cell.swatch {
		width: 42px;
		height: 34px;
	}

	.cell.tick {
		width: 30px;
		height: 34px;
	}

	.cell.toggle {
		padding: 4px 16px;
		height: 34px;
	}

	/* narrow enough that the full 2–16 cabinet row fits the board width */
	.cell.num {
		padding: 4px 9px;
		height: 34px;
	}

	.cell.selected {
		border: 2px solid rgba(255, 255, 255, 0.85);
	}

	.cell.disabled {
		cursor: default;
	}

	.cell.disabled:hover {
		border: 2px solid transparent;
	}
</style>

@code
{
	// Runtime theme colours for a cell, merged with the cell's own Style last so swatch
	// cells keep their real light-colour swatch background.
	string CellStyle( SettingsModel.SettingCell c )
	{
		bool filled = c.Css != null && c.Css.Contains( "filled" );
		string s = $"background-color:{( filled ? WallTheme.CellFill : WallTheme.Cell )};";
		s += c.Activate == null ? " color:rgba(255,255,255,0.25);" : $" color:{WallTheme.TextDim};";
		return s + c.Style;
	}

	System.Collections.Generic.List<SettingsModel.SettingRow> Rows() =>
		SettingsStation.Active?.Host ?? false
			? SettingsModel.BuildHostRows( Scene )
			: SettingsModel.BuildLocalRows();

	void Click( SettingsModel.SettingCell cell )
	{
		if ( cell?.Activate == null ) return;
		cell.Activate();
		Rotaliate.Audio.SoundPlayer.PlayTick();
		StateHasChanged();
	}

	protected override int BuildHash() =>
		HashCode.Combine( SettingsStation.Active != null && !( SettingsStation.Active?.Music ?? false ),
			SettingsStation.Active?.Host,
			SettingsModel.SettingsVersion, LobbyNetworkManager.LocalIsAdmin,
			HashCode.Combine( ArcadeRing.Instance?.StationCount ?? 0,
				ArcadeRing.Instance?.PendingStationCount ?? 0,
				ArcadeRing.Instance?.Rebuilding ?? false ),
			SettingsModel.AnyStationOccupied( Scene ),
			Rotaliate.Api.ApiClient.BaseUrl );
}
