@using System
@using Sandbox
@using Sandbox.UI
@using Gambit.Game
@using Gambit.World
@namespace Gambit.UI
@inherits PanelComponent

@*
	Scoreboard board (PLAN.md M5) floating just above the giant 3D spectator board
	(SpectatorWall). Shows both players — colour chip, title + name, rating, and a live
	clock — Black on top / White on bottom to mirror the board below it. Display-only
	WorldPanel (no pointer input); colours track the world light via WallTheme so it sits
	with the other lobby boards. Ratings/clocks come from the export PGN (lichess TV / watch
	by id); the sbox-table featured source has names only, so ratings/clocks are hidden.
*@

<root>
	<div class="board" style="background-color:@WallTheme.Bg; border:2px solid @WallTheme.Border;">
		@{
			var c = SpectatorController.Instance;
		}
		<div class="row">
			<div class="chip b"></div>
			<div class="name" style="color:@WallTheme.Text;">@NameText( c?.BlackTitle, c?.BlackName, "Black" )</div>
			<div class="spacer"></div>
			<div class="rating" style="color:@WallTheme.TextDim;">@RatingText( c?.BlackRating ?? 0 )</div>
			<div class="clock" style="color:@ClockColor( Ticking( c, white: false ) );">@ClockText( c?.BlackClock ?? -1 )</div>
		</div>
		<div class="divider" style="background-color:@WallTheme.Divider;"></div>
		<div class="row">
			<div class="chip w"></div>
			<div class="name" style="color:@WallTheme.Text;">@NameText( c?.WhiteTitle, c?.WhiteName, "White" )</div>
			<div class="spacer"></div>
			<div class="rating" style="color:@WallTheme.TextDim;">@RatingText( c?.WhiteRating ?? 0 )</div>
			<div class="clock" style="color:@ClockColor( Ticking( c, white: true ) );">@ClockText( c?.WhiteClock ?? -1 )</div>
		</div>
	</div>
</root>

<style>
	@@import "WallTheme.scss";

	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	/* Colours are runtime-driven (WallTheme, bound inline above); only layout + static
	   tokens live here. Fixed px in the WorldPanel's intrinsic pixel space. */
	.board {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		flex-direction: column;
		align-items: stretch;
		justify-content: center;
		padding: 20px 34px;
		border-radius: $wall-radius;
		font-family: $wall-font;
		gap: 6px;
	}

	.board > div { flex-shrink: 0; }

	.row {
		flex-direction: row;
		align-items: center;
		height: 74px;
	}

	.spacer { flex-grow: 1; }

	.chip {
		width: 34px;
		height: 34px;
		border-radius: 17px;
		margin-right: 20px;
		flex-shrink: 0;
	}
	.chip.w { background-color: #f5f5f7; border: 3px solid #101014; }
	.chip.b { background-color: #101014; border: 3px solid #f5f5f7; }

	.name {
		white-space: nowrap;
		font-size: 34px;
		font-weight: bold;
		letter-spacing: 1px;
	}

	.rating {
		white-space: nowrap;
		font-size: 26px;
		margin-right: 28px;
	}

	.clock {
		white-space: nowrap;
		font-size: 40px;
		font-weight: bold;
		letter-spacing: 1px;
		min-width: 150px;
		justify-content: flex-end;
	}

	.divider { height: 2px; margin: 2px 0; }
</style>

@code
{
	static string NameText( string title, string name, string fallback )
	{
		name = string.IsNullOrEmpty( name ) ? fallback : name;
		return string.IsNullOrEmpty( title ) ? name : $"{title} {name}";
	}

	static string RatingText( int rating ) => rating > 0 ? rating.ToString() : "";

	/// <summary>Is this side's clock the one currently ticking?</summary>
	static bool Ticking( SpectatorController c, bool white ) =>
		c != null && c.HasClocks && c.WhiteToMoveNow == white;

	/// <summary>Accent the ticking side's clock; the idle side stays dim.</summary>
	static string ClockColor( bool ticking ) => ticking ? WallTheme.AccentCss : WallTheme.TextDim;

	/// <summary>Seconds → "m:ss" (or "h:mm:ss" past an hour); empty when unknown (&lt; 0).</summary>
	static string ClockText( double seconds )
	{
		if ( seconds < 0 ) return "";
		int s = (int)Math.Floor( seconds );
		int h = s / 3600, m = ( s % 3600 ) / 60, ss = s % 60;
		return h > 0 ? $"{h}:{m:D2}:{ss:D2}" : $"{m}:{ss:D2}";
	}

	protected override int BuildHash()
	{
		var c = SpectatorController.Instance;
		// The whole-second clock values are in the hash so the panel repaints ~once a second
		// as the active clock ticks.
		return HashCode.Combine(
			HashCode.Combine( c?.WhiteName, c?.BlackName, c?.WhiteTitle, c?.BlackTitle ),
			HashCode.Combine( c?.WhiteRating, c?.BlackRating, c?.HasClocks, c?.WhiteToMoveNow ),
			(int)( c?.WhiteClock ?? -1 ), (int)( c?.BlackClock ?? -1 ),
			SettingsModel.SettingsVersion );
	}
}
