@using System;
@using Sandbox;
@using Sandbox.UI;
@namespace Gambit.UI
@inherits PanelComponent

@*
	Cabinet number printed on the outward (player-facing) face of the marquee
	slab. Display only — no pointer-events.
*@

<root>
	<div class="num">@Number</div>
</root>

<style>
	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	.num {
		position: absolute;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		text-align: center;
		font-size: 312px;
		font-weight: bold;
		letter-spacing: 8px;
		color: #e8e6df;
	}
</style>

@code {
	[Property] public string Number { get; set; } = "1";

	protected override int BuildHash() => Number?.GetHashCode() ?? 0;
}
