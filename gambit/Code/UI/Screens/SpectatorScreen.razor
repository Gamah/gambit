@using System
@using Sandbox
@using Sandbox.UI
@using Gambit.World
@using Gambit.Game
@namespace Gambit.UI.Screens
@inherits PanelComponent

@*
	Channel picker for the spectator wall (PLAN.md M5). A screen-space ScreenPanel, shown
	only while engaged at the SpectatorStation (walk up + press E) — the camera stays put;
	LobbyPlayer frees the cursor. Self-attached to the scene ScreenPanel at runtime by
	LobbyPlayer.EnsureSpectatorScreen (no scene rewire). The board itself renders on the
	wall (SpectatorBoardPanel); this just switches what it shows.
*@

<root>
	@if ( SpectatorStation.Active != null )
	{
		var c = SpectatorController.Instance;
		<div class="screen-fit">
			<div class="spectate">
				<div class="title">SPECTATE</div>
				<div class="now">@( c?.ChannelLabel ?? "—" )</div>

				<div class="section">FEATURED — sbox tables</div>
				<div class="row">
					<div class="button" onclick="@( () => c?.ShowFeatured() )">Show a live table</div>
					<div class="button ghost" onclick="@( () => c?.CycleFeatured() )">Next table</div>
				</div>

				<div class="section">LICHESS TV</div>
				<div class="row wrap">
					@foreach ( var ch in SpectatorController.TvChannels )
					{
						<div class="button ghost" onclick="@( () => c?.ShowLichessTv( ch ) )">@Cap( ch )</div>
					}
				</div>

				<div class="section">WATCH A GAME</div>
				<TextEntry @ref="_idEntry" class="input" placeholder="lichess game id or URL" />
				<div class="button" onclick="@Watch">Watch</div>

				@if ( !string.IsNullOrEmpty( c?.StatusText ) )
				{
					<div class="status">@c.StatusText</div>
				}
				<div class="note">Ongoing lichess games are shown a few seconds behind (fair-play delay). Press Escape to leave.</div>
			</div>
		</div>
	}
</root>

<style>
	root { width: 100%; height: 100%; pointer-events: none; }

	.screen-fit {
		position: absolute;
		left: 0; top: 0;
		width: 100%; height: 100%;
		justify-content: center;
		align-items: center;
	}

	.spectate {
		flex-direction: column;
		width: 420px;
		gap: 8px;
		padding: 22px;
		background-color: rgba(10, 10, 14, 0.92);
		border-radius: 14px;
		color: rgba(255, 255, 255, 0.9);
		pointer-events: all;
	}

	.title { font-size: 22px; letter-spacing: 4px; font-weight: bold; }
	.now { font-size: 14px; color: #7fd47f; }
	.section {
		font-size: 12px;
		letter-spacing: 2px;
		color: rgba(255, 255, 255, 0.45);
		margin-top: 10px;
	}
	.row { flex-direction: row; gap: 8px; }
	.row.wrap { flex-wrap: wrap; }

	.button {
		padding: 8px 12px;
		background-color: rgba(90, 140, 255, 0.25);
		border-radius: 6px;
		cursor: pointer;
		font-size: 14px;
		justify-content: center;
	}
	.button:hover { background-color: rgba(90, 140, 255, 0.45); }
	.button.ghost { background-color: rgba(255, 255, 255, 0.08); }
	.button.ghost:hover { background-color: rgba(255, 255, 255, 0.18); }

	.input {
		background-color: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.15);
		border-radius: 6px;
		padding: 7px 9px;
		font-size: 13px;
		color: white;
	}

	.status { font-size: 13px; color: rgba(255, 255, 255, 0.6); margin-top: 6px; }
	.note { font-size: 11px; color: rgba(255, 255, 255, 0.4); margin-top: 6px; }
</style>

@code
{
	TextEntry _idEntry;

	void Watch() => SpectatorController.Instance?.WatchGame( _idEntry?.Text?.Trim() );

	static string Cap( string s ) => string.IsNullOrEmpty( s ) ? s : char.ToUpperInvariant( s[0] ) + s[1..];

	protected override int BuildHash()
	{
		var c = SpectatorController.Instance;
		return System.HashCode.Combine( SpectatorStation.Active != null, c?.ChannelLabel, c?.StatusText );
	}
}
