		_ = LoadLeaderboardView();
	}

	async Task LoadLeaderboardView()
	{
		if ( _recentDaily == null || _recentHourly == null )
		{
			_recentLoading = true;
			StateHasChanged();
			try
			{
				_recentDaily  = await ApiClient.GetRecentDaily();
				_recentHourly = await ApiClient.GetRecentHourly();
			}
			catch ( Exception e )
			{
				Log.Warning( $"[Gambit] Recent puzzles failed: {e.Message}" );
				_recentDaily  ??= new List<RecentPuzzle>();
				_recentHourly ??= new List<RecentPuzzle>();
			}
			_recentLoading = false;
			StateHasChanged();
		}
		await LoadLeaderboard();
	}

	async void SetLbPuzzle( int idx )
	{
		if ( _lbPuzzleIdx == idx ) return;
		_lbPuzzleIdx = idx;
		_lb          = null;
		StateHasChanged();
		await LoadLeaderboard();
	}

	async void SetLbMetric( bool time )
	{
		if ( _lbTime == time ) return;
		_lbTime = time;
		_lb     = null;
		StateHasChanged();
		await LoadLeaderboard();
	}

	async Task LoadLeaderboard()
	{
		var puzzles = _lbDaily ? _recentDaily : _recentHourly;
		string puzzleId = ( puzzles != null && puzzles.Count > _lbPuzzleIdx )
			? puzzles[_lbPuzzleIdx].PuzzleId
			: null;
		string metric = _lbTime ? "time" : "moves";

		_lbLoading = true;
		StateHasChanged();
		try
		{
			_lb = _lbDaily
				? await ApiClient.GetDailyLeaderboard( metric, puzzleId )
				: await ApiClient.GetHourlyLeaderboard( metric, puzzleId );
		}
		catch ( Exception e )
		{
			Log.Warning( $"[Gambit] Leaderboard failed: {e.Message}" );
			_lb = new List<LeaderboardEntry>();
		}
		_lbLoading = false;
		StateHasChanged();
	}

	void SwitchToMpLb()
	{
		if ( _lbMp ) return;
		_lbMp    = true;
		_lbMp2p  = true;
		StateHasChanged();
		_ = LoadMpLeaderboard();
	}

	async void SetLbType( bool daily )
	{
		if ( !_lbMp && _lbDaily == daily ) return;
		_lbMp        = false;
		_lbDaily     = daily;
		_lbPuzzleIdx = 0;
		_lb          = null;
		StateHasChanged();
		await LoadLeaderboard();
	}

	async void SetMpSize( bool is2p )
	{
		if ( _lbMp2p == is2p ) return;
		_lbMp2p = is2p;
		StateHasChanged();
		if ( is2p ? _mpLb2p == null : _mpLb4p == null )
			await LoadMpLeaderboard();
	}

	async Task LoadMpLeaderboard()
	{
		_mpLbLoading = true;
		StateHasChanged();
		try
		{
			_mpLb2p = await ApiClient.GetMultiplayerLeaderboard( 2 );
			_mpLb4p = await ApiClient.GetMultiplayerLeaderboard( 4 );
		}
		catch ( Exception e )
		{
			Log.Warning( $"[Gambit] MP leaderboard failed: {e.Message}" );
			_mpLb2p ??= new List<MpWinEntry>();
			_mpLb4p ??= new List<MpWinEntry>();
		}
		_mpLbLoading = false;
		StateHasChanged();
	}

	static string PuzzleTabLabel( RecentPuzzle p, bool daily )
	{
		// ActiveFrom is RFC3339 like "2026-06-08T14:00:00Z"
		if ( p.ActiveFrom == null || p.ActiveFrom.Length < 10 ) return "?";
		var dateStr  = p.ActiveFrom.Substring( 0, 10 ); // "2026-06-08"
		var dateParts = dateStr.Split( '-' );
		if ( dateParts.Length == 3
			&& int.TryParse( dateParts[1], out int mo )
			&& int.TryParse( dateParts[2], out int dy )
			&& mo >= 1 && mo <= 12 )
		{
			if ( daily ) return $"{_monthNames[mo - 1]} {dy}";
			// Hourly: show "HH:mm"
			if ( p.ActiveFrom.Length >= 16 )
				return p.ActiveFrom.Substring( 11, 5 );
			return $"{_monthNames[mo - 1]} {dy}";
		}
		return p.ActiveFrom.Substring( 0, 10 );
	}

	// Legacy rows from players who never set a name fall back to their player_tag
	static string LbDisplayName( string username, string playerTag ) =>
		!string.IsNullOrEmpty( username ) ? username : ( playerTag ?? "Anonymous" );

	static string FormatLbScore( LeaderboardEntry e )
	{
		if ( e.TotalMoves > 0 && e.DurationMs == 0 )
			return e.TotalMoves.ToString();
		long ms   = e.DurationMs;
		int  secs = (int)(ms / 1000);
		int  frac = (int)(ms % 1000) / 100;
		int  mins = secs / 60;
		secs %= 60;
		return $"{mins}:{secs:D2}.{frac}";
	}

	// ── Public player profile view ──

	ProfileResponse _ppProfile;
	bool            _ppLoading;
	string          _ppError;
	Action          _ppBack;         // restores the view the profile was opened from
	int             _ppGen;          // cancels a stale fetch when the view changes

	void OpenPlayerProfile( string playerTag, Action back )
	{
		if ( string.IsNullOrEmpty( playerTag ) ) return;
		_ppBack    = back;
		_ppProfile = null;
		_ppError   = null;
		_ppLoading = true;
		_view      = MenuView.PlayerProfile;
		SetNav( ProfileBack ); // 0: Back
		StateHasChanged();
		_ = LoadPlayerProfile( playerTag, ++_ppGen );
	}

	async Task LoadPlayerProfile( string playerTag, int gen )
	{
		try
		{
			var profile = await ApiClient.GetProfile( playerTag );
			if ( gen != _ppGen ) return;
			_ppProfile = profile;
			_ppError   = profile == null ? "Profile unavailable." : null;
		}
		catch ( Exception e )
		{
			Log.Warning( $"[Gambit] Profile load failed: {e.Message}" );
			if ( gen != _ppGen ) return;
			_ppError = "Profile unavailable.";
		}
		_ppLoading = false;
		StateHasChanged();
	}

	void ProfileBack()
	{
		_ppGen++; // drop any in-flight fetch
		if ( _ppBack != null ) _ppBack();
		else BackToMain();
	}

	// Back target when a profile was opened from a multiplayer roster: re-derive the
	// lobby/waiting view + nav from the current MP state.
	void RestoreMpView()
	{
		var mp = MultiplayerController.Instance;
		if ( mp == null ) { BackToMain(); return; }
		_view = mp.State == MpState.WaitingRoom ? MenuView.MpWaiting : MenuView.MpLobby;
		OnMpStateChanged();
	}

	// Play the recorded game on the giant spectator board, then leave the cabinet so
	// the player can watch it from the room (engaging anything stops the replay).
	void WatchOnSpectator( string sessionId )
	{
		if ( string.IsNullOrEmpty( sessionId ) ) return;
		Gambit.World.SpectatorBoard.StartReplay( sessionId );
		Gambit.World.LobbyPlayer.Local?.Disengage();
	}

	static string ProfileTypeLabel( string t ) => t switch
	{
		"daily"    => "Daily",
		"hourly"   => "Hourly",
		"freeplay" => "Free Play",
		"2p"       => "2-Player",
		"4p"       => "4-Player",
		_          => t ?? "Game",
	};

	static string ProfileGameMeta( ProfileGame g )
	{
		var parts = new List<string>();
		if ( g.Rank.HasValue )       parts.Add( g.Rank.Value == 1 ? "Winner" : $"#{g.Rank.Value}" );
		if ( g.DurationMs.HasValue ) parts.Add( FormatMs( g.DurationMs.Value ) );
		if ( g.TotalMoves.HasValue ) parts.Add( $"{g.TotalMoves.Value} moves" );
		return parts.Count > 0 ? string.Join( "  ·  ", parts ) : "—";
	}

	static string FormatMs( long ms )
	{
		int secs = (int)(ms / 1000);
		int frac = (int)(ms % 1000) / 100;
		int mins = secs / 60;
		secs %= 60;
		return $"{mins}:{secs:D2}.{frac}";
	}

	// completed_at is RFC3339 like "2026-06-17T12:00:00Z" → "Jun 17"
	static string ProfileGameDate( string completedAt )
	{
		if ( completedAt == null || completedAt.Length < 10 ) return "";
		var parts = completedAt.Substring( 0, 10 ).Split( '-' );
		if ( parts.Length == 3
			&& int.TryParse( parts[1], out int mo )
			&& int.TryParse( parts[2], out int dy )
			&& mo >= 1 && mo <= 12 )
			return $"{_monthNames[mo - 1]} {dy}";
		return completedAt.Substring( 0, 10 );
	}

	// ── Profile view ──

	void OpenProfile()
	{
		var data       = PlayerData.Load();
		_profileUsername = data?.Username ?? "";
		_profileGuid     = data?.Guid ?? "(no player ID)";
		_profileScheme   = data?.ColorScheme ?? "normal";
		_saveMsg         = null;
		_copyLabel       = "Copy";
		_importMsg       = null;
		_nameEntryInit   = false;
		_guidEntryInit   = false;
		_view = MenuView.Profile;
		SetNav(
			() => SetScheme( "normal" ),      // 0
			() => SetScheme( "deuteranopia" ), // 1
			() => SetScheme( "protanopia" ),   // 2
			() => SetScheme( "tritanopia" ),   // 3
			BackToMain                         // 4
		);
		StateHasChanged();
	}

	protected override void OnUpdate()
	{
		IsRebinding = _rebindingAction != null && _view == MenuView.Settings;

		if ( _view == MenuView.Profile && !_nameEntryInit && _nameEntry != null )
		{
			_nameEntry.Text = _profileUsername;
			_nameEntryInit  = true;
		}
		if ( _view == MenuView.Profile && !_guidEntryInit && _guidEntry != null )
		{
			_guidEntry.Text = "";
			_guidEntryInit  = true;
		}
		if ( _view == MenuView.MpLobby && !_mpJoinEntryInit && _mpJoinEntry != null )
		{
			_mpJoinEntry.Text = "";
			_mpJoinEntryInit  = true;
		}
		// Poll the public match browser every 5s while on the create/join screen
		if ( _view == MenuView.MpLobby && _openLobbiesAge > 5f )
		{
			var mpc = MultiplayerController.Instance;
			if ( mpc != null && mpc.State == MpState.Lobby && mpc.LobbyCode == null )
				_ = RefreshOpenLobbies( mpc.Is2P ? 2 : 4 );
			else
				_openLobbiesAge = 0;
		}
		if ( _view == MenuView.Feedback && !_feedbackEntryInit && _feedbackEntry != null )
		{
			_feedbackEntry.Text = "";
			_feedbackEntryInit  = true;
		}
		if ( _rebindingAction != null && _view == MenuView.Settings )
		{
			if ( Input.EscapePressed )
			{
				Input.EscapePressed = false;
				_rebindingAction = null;
				StateHasChanged();
				return;
			}
			if ( _rebindingController )
			{
				// Scan the per-button probe actions; the one that fired is the button
				// the player just pressed (all readable via the public Input API).
				foreach ( var (probe, _) in GamepadBinds.Buttons )
				{
					if ( Input.Pressed( probe ) )
					{
						CommitGamepadBinding( _rebindingAction, probe );
						_rebindingAction = null;
						StateHasChanged();
						break;
					}
				}
			}
			else
			{
				foreach ( var key in _scanKeys )
				{
					if ( Input.Keyboard.Pressed( key ) )
					{
						CommitBinding( _rebindingAction, key );
						_rebindingAction = null;
						StateHasChanged();
						break;
					}
				}
			}
			return; // don't process nav while rebinding
		}

		if ( _visible && _navActions.Length > 0 )
		{
			bool changed = false;
			// Action-based so the gamepad d-pad (DpadNorth/South/West/East) drives the
			// menu too, not just the arrow keys; one Pressed call per direction covers
			// both the keyboard arrow and the d-pad without double-stepping.
			if ( Input.Pressed( "MoveUp" )   || Input.Pressed( "MoveLeft" )  || GamepadBinds.Pressed( "MoveUp" )   || GamepadBinds.Pressed( "MoveLeft" ) )  { _navIdx = Math.Max( 0, _navIdx - 1 ); changed = true; }
			if ( Input.Pressed( "MoveDown" ) || Input.Pressed( "MoveRight" ) || GamepadBinds.Pressed( "MoveDown" ) || GamepadBinds.Pressed( "MoveRight" ) ) { _navIdx = Math.Min( _navActions.Length - 1, _navIdx + 1 ); changed = true; }
			if ( changed ) StateHasChanged();
			// Confirm: Enter, or the gamepad A button (the "Jump" action's gamepad code).
			if ( _navIdx >= 0 && (Input.Keyboard.Pressed( "ENTER" ) || Input.Keyboard.Pressed( "SPACE" ) || Input.Pressed( "Jump" )) )
				_navActions[_navIdx]?.Invoke();
		}
	}

	async void SaveUsername()
	{
		var newName = _nameEntry?.Text?.Trim() ?? "";
		if ( string.IsNullOrEmpty( newName ) ) return;
		var data = PlayerData.Load();
		if ( data?.Guid == null ) return;
		try
		{
			var resp = await ApiClient.SetUsername( data.Guid, newName );
			data.Username    = newName;
			// The tag is derived from the username, so a rename changes it
			if ( !string.IsNullOrEmpty( resp?.PlayerTag ) ) data.PlayerTag = resp.PlayerTag;
			data.Save();
			_profileUsername = newName;
			_saveMsg         = "Saved!";
			_saveFailed      = false;
		}
		catch ( Exception e )
		{
			Log.Warning( $"[Gambit] SetUsername failed: {e.Message}" );
			_saveMsg    = string.IsNullOrEmpty( e.Message ) ? "Failed to save." : e.Message;
			_saveFailed = true;
		}
		StateHasChanged();
	}

	void CopyGuid()
	{
		try
		{
			Clipboard.SetText( _profileGuid );
			_copyLabel = "Copied!";
		}
		catch
		{
			_copyLabel = "—";
		}
		StateHasChanged();
	}

	/// <summary>Adopt an existing account by pasting its GUID from the web client.
	/// Validated against the server before overwriting the local identity; the
	/// account's username comes along with it.</summary>
	async void ImportGuid()
	{
		var guid = _guidEntry?.Text?.Trim() ?? "";
		if ( string.IsNullOrEmpty( guid ) ) return;
		try
		{
			var player = await ApiClient.GetPlayer( guid );
			if ( string.IsNullOrEmpty( player?.Guid ) ) throw new Exception( "unknown player" );

			var data = PlayerData.Load() ?? new PlayerData();
			data.Guid      = player.Guid;
			data.Username  = player.Username;
			data.PlayerTag = player.PlayerTag ?? "";
			data.Save();

			_profileGuid     = player.Guid;
			_profileUsername = player.Username ?? "";
			if ( _nameEntry != null ) _nameEntry.Text = _profileUsername;
			Gambit.World.ArcadeStation.Active?.RefreshOccupant();
			_importMsg    = "Imported!";
			_importFailed = false;
		}
		catch ( Exception e )
		{
			Log.Warning( $"[Gambit] GUID import failed: {e.Message}" );
			_importMsg    = "Invalid player ID.";
			_importFailed = true;
		}
		StateHasChanged();
	}

	void SetScheme( string scheme )
	{
		_profileScheme = scheme;
		var data = PlayerData.Load();
		if ( data == null ) return;
		data.ColorScheme = scheme;
		data.Save();
		StateHasChanged();
	}

	// ── Feedback view ──

	void OpenFeedback()
	{
		_feedbackMsg       = null;
		_feedbackEntryInit = false;
		_view = MenuView.Feedback;
		StateHasChanged();
	}

	async void SendFeedback()
	{
		var msg = _feedbackEntry?.Text?.Trim() ?? "";
		if ( string.IsNullOrEmpty( msg ) ) return;
		if ( msg.Length > 2000 ) msg = msg.Substring( 0, 2000 );
		try
		{
			await ApiClient.SubmitFeedback( msg );
			_feedbackMsg    = "Thanks for the feedback!";
			_feedbackFailed = false;
			if ( _feedbackEntry != null ) _feedbackEntry.Text = "";
		}
		catch ( Exception e )
		{
			Log.Warning( $"[Gambit] Feedback failed: {e.Message}" );
			_feedbackMsg    = "Error sending — please try again.";
			_feedbackFailed = true;
		}
		StateHasChanged();
	}

