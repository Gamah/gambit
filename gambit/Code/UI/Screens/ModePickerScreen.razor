	// ── Lifecycle ──

	protected override void OnStart()
	{
		SplashScreen.OnPlayerReady += Show;
		GameEvents.OnReturnToMenu  += Show;
		PlayerData.OnIdentityCleared += Hide;

		if ( PlayerData.Load()?.Guid != null )
			Show();
	}

	protected override void OnDestroy()
	{
		SplashScreen.OnPlayerReady -= Show;
		GameEvents.OnReturnToMenu  -= Show;
		PlayerData.OnIdentityCleared -= Hide;
		var mp = MultiplayerController.Instance;
		if ( mp != null ) mp.OnStateChanged -= OnMpStateChanged;
