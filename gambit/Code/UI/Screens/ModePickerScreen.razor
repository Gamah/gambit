@using System;
@using System.Collections.Generic;
@using System.Linq;
@using System.Threading.Tasks;
@using Sandbox;
@using Sandbox.UI;
@using Gambit.Api;
@using Gambit.Game;
@using Gambit.Theme;
@using Gambit.World;
@namespace Gambit.UI.Screens
@inherits PanelComponent

<root>
	<div class="arcade-fit" style="@Gambit.World.ArcadeRing.UiRectStyle()">
	@if ( _visible && ArcadeStation.Active != null && ( Gambit.World.LobbyPlayer.Local?.CameraSettled ?? true ) )
	{
		@if ( _view == MenuView.Main )
		{
			<div class="screen">
				<div class="title">TERRY'S GAMBIT</div>
				<div class="modes">
					<div class="mode-btn primary @( IsFocused(0) ? "focused" : "" )" onclick="@(() => Play( GameMode.Daily ))">Daily Puzzle</div>
					<div class="mode-btn primary @( IsFocused(1) ? "focused" : "" )" onclick="@(() => Play( GameMode.Hourly ))">Hourly Puzzle</div>
					<div class="mode-btn primary @( IsFocused(2) ? "focused" : "" )" onclick="@(() => Play( GameMode.Freeplay ))">Free Play</div>
					<div class="mp-row">
						<div class="mode-btn primary mp @( IsFocused(3) ? "focused" : "" )" onclick="@(() => PlayMultiplayer( false ))">4-Player</div>
						<div class="mode-btn primary mp @( IsFocused(4) ? "focused" : "" )" onclick="@(() => PlayMultiplayer( true ))">2-Player</div>
					</div>
				</div>
				<div class="secondary-row">
					<div class="mode-btn secondary @( IsFocused(5) ? "focused" : "" )" onclick="@OpenProfile">Profile</div>
					<div class="mode-btn secondary @( IsFocused(6) ? "focused" : "" )" onclick="@OpenSettings">Settings</div>
					<div class="mode-btn secondary @( IsFocused(7) ? "focused" : "" )" onclick="@OpenFeedback">Feedback</div>
				</div>
				@if ( CanDeleteGuid )
				{
					<div class="mode-btn danger @( IsFocused(8) ? "focused" : "" )" onclick="@DeleteGuid">Delete Gambit GUID</div>
				}
			</div>
		}
		else if ( _view == MenuView.Leaderboard )
		{
			<div class="screen subscreen">
				<div class="nav-bar">
					<div class="back-btn @( IsFocused(3) ? "focused" : "" )" onclick="@BackToMain">← Back</div>
					<div class="screen-title">LEADERBOARD</div>
				</div>

				<div class="toggle-row">
					<div class="toggle-btn @( !_lbMp && _lbDaily ? "active" : "" ) @( IsFocused(0) ? "focused" : "" )" onclick="@(() => SetLbType( true ))">Daily</div>
					<div class="toggle-btn @( !_lbMp && !_lbDaily ? "active" : "" ) @( IsFocused(1) ? "focused" : "" )" onclick="@(() => SetLbType( false ))">Hourly</div>
					<div class="toggle-btn @( _lbMp ? "active" : "" ) @( IsFocused(2) ? "focused" : "" )" onclick="@SwitchToMpLb">Multiplayer</div>
				</div>

				@if ( !_lbMp )
				{
					@if ( _recentLoading )
					{
						<div class="loading-msg">Loading…</div>
					}
					else
					{
						var puzzles = _lbDaily ? _recentDaily : _recentHourly;
						@if ( puzzles != null && puzzles.Count > 0 )
						{
							<div class="puzzle-tabs">
								@for ( int i = 0; i < puzzles.Count; i++ )
								{
									var idx = i;
									<div class="puzzle-tab @( _lbPuzzleIdx == idx ? "active" : "" )"
									     onclick="@(() => SetLbPuzzle( idx ))">
										@PuzzleTabLabel( puzzles[idx], _lbDaily )
									</div>
								}
							</div>
						}
					}

					<div class="toggle-row">
						<div class="toggle-btn @( _lbTime ? "active" : "" )" onclick="@(() => SetLbMetric( true ))">Time</div>
						<div class="toggle-btn @( !_lbTime ? "active" : "" )" onclick="@(() => SetLbMetric( false ))">Moves</div>
					</div>

					@if ( _lbLoading )
					{
						<div class="loading-msg">Loading…</div>
					}
					else if ( _lb != null )
					{
						<div class="lb-list">
							@if ( _lb.Count == 0 )
							{
								<div class="loading-msg">No entries yet.</div>
							}
							else
							{
								@foreach ( var e in _lb )
								{
									<div class="lb-row @( e.Username == _playerUsername ? "lb-row-me" : "" )">
										<span class="lb-rank">#@e.Rank</span>
										<span class="lb-name @( string.IsNullOrEmpty( e.PlayerTag ) ? "" : "lb-name-link" )" onclick="@(() => OpenPlayerProfile( e.PlayerTag, OpenLeaderboard ))">@LbDisplayName( e.Username, e.PlayerTag )</span>
										<span class="lb-score">@FormatLbScore( e )</span>
									</div>
								}
							}
						</div>
					}
				}
				else
				{
					<div class="toggle-row">
						<div class="toggle-btn @( _lbMp2p ? "active" : "" )" onclick="@(() => SetMpSize( true ))">2-Player</div>
						<div class="toggle-btn @( !_lbMp2p ? "active" : "" )" onclick="@(() => SetMpSize( false ))">4-Player</div>
					</div>

					@if ( _mpLbLoading )
					{
						<div class="loading-msg">Loading…</div>
					}
					else
					{
						var mpLb = _lbMp2p ? _mpLb2p : _mpLb4p;
						<div class="lb-list">
							@if ( mpLb == null || mpLb.Count == 0 )
							{
								<div class="loading-msg">No entries yet.</div>
							}
							else
							{
								@for ( int i = 0; i < mpLb.Count; i++ )
								{
									var e   = mpLb[i];
									var pos = i;
									<div class="lb-row @( e.Username == _playerUsername ? "lb-row-me" : "" )">
										<span class="lb-rank">#@(pos + 1)</span>
										<span class="lb-name @( string.IsNullOrEmpty( e.PlayerTag ) ? "" : "lb-name-link" )" onclick="@(() => OpenPlayerProfile( e.PlayerTag, OpenLeaderboard ))">@LbDisplayName( e.Username, e.PlayerTag )</span>
										<span class="lb-score">@e.Wins wins</span>
									</div>
								}
							}
						</div>
					}
				}
			</div>
		}
		else if ( _view == MenuView.PlayerProfile )
		{
			<div class="screen subscreen">
				<div class="nav-bar">
					<div class="back-btn @( IsFocused(0) ? "focused" : "" )" onclick="@ProfileBack">← Back</div>
					<div class="screen-title">PLAYER</div>
				</div>

				@if ( _ppLoading )
				{
					<div class="loading-msg">Loading…</div>
				}
				else if ( _ppError != null )
				{
					<div class="loading-msg">@_ppError</div>
				}
				else if ( _ppProfile != null )
				{
					<div class="pp-head">
						<div class="pp-name">@( string.IsNullOrEmpty( _ppProfile.Username ) ? "Anonymous" : _ppProfile.Username )</div>
						<div class="pp-tag">@_ppProfile.PlayerTag</div>
					</div>

					<div class="lb-list">
						@if ( _ppProfile.Games == null || _ppProfile.Games.Count == 0 )
						{
							<div class="loading-msg">No games yet.</div>
						}
						else
						{
							@foreach ( var g in _ppProfile.Games )
							{
								<div class="lb-row">
									<span class="pp-type">@ProfileTypeLabel( g.GameType )</span>
									<span class="pp-meta">@ProfileGameMeta( g )</span>
									<span class="pp-date">@ProfileGameDate( g.CompletedAt )</span>
									@if ( !string.IsNullOrEmpty( g.SessionId ) )
									{
										<span class="pp-share" onclick="@(() => WatchOnSpectator( g.SessionId ))">▶ watch</span>
									}
								</div>
							}
						}
					</div>
				}
			</div>
		}
		else if ( _view == MenuView.MpLobby )
		{
			var mp = MultiplayerController.Instance;
			<div class="screen subscreen">
				<div class="nav-bar">
					<div class="back-btn @( IsFocused(0) ? "focused" : "" )" onclick="@MpCancel">← Back</div>
					<div class="screen-title">@( mp?.Is2P == true ? "2-PLAYER" : "4-PLAYER" )</div>
				</div>
				@if ( mp?.State == MpState.Connecting )
				{
					<div class="loading-msg">Connecting…</div>
				}
				else if ( mp?.LobbyCode == null )
				{
					<div class="input-row" style="margin-top:12px;">
						<div class="mode-btn primary @( IsFocused(1) ? "focused" : "" )" style="width:200px;" onclick="@( () => MpCreate( true ) )">Public Match</div>
						<div class="mode-btn primary @( IsFocused(2) ? "focused" : "" )" style="width:200px;" onclick="@( () => MpCreate( false ) )">Private Match</div>
					</div>
					<div class="loading-msg" style="margin:4px 0;">— or —</div>
					<div class="input-row">
						<TextEntry @ref="_mpJoinEntry" placeholder="Lobby code" class="text-input" style="width:210px;" />
						<div class="action-btn @( IsFocused(3) ? "focused" : "" )" onclick="@MpJoin">Join</div>
					</div>
					<div class="mp-open-title">
						<div class="label">PUBLIC MATCHES</div>
						<div class="mp-open-refresh @( IsFocused(4) ? "focused" : "" )" onclick="@MpRefreshOpen">⟳</div>
					</div>
					@if ( _openLobbies == null )
					{
						<div class="loading-msg">Loading…</div>
					}
					else if ( _openLobbies.Count == 0 )
					{
						<div class="loading-msg">No public matches right now — create one!</div>
					}
					else
					{
						@foreach ( var ol in _openLobbies )
						{
							var code = ol.Code;
							<div class="mp-open-row">
								<div class="mp-open-code">@ol.Code</div>
								<div class="mp-open-host">@( string.IsNullOrEmpty( ol.Host ) ? "Anonymous" : ol.Host )</div>
								<div class="mp-open-count">@ol.Count/@ol.Max</div>
								<div class="action-btn mp-open-join" onclick="@( () => MpJoinCode( code ) )">Join</div>
							</div>
						}
					}
				}
				else
				{
					<div class="label" style="margin-top:12px;">LOBBY CODE</div>
					<div class="mp-code" onclick="@MpCopy">@mp.LobbyCode  @_mpCopyLabel</div>
					<div class="loading-msg">@mp.LobbyCount / @mp.LobbyMax players</div>
					@foreach ( var lp in mp.LobbyPlayers )
					{
						<div class="mp-player-row"><div class="mp-player-name @( string.IsNullOrEmpty( lp.PlayerTag ) ? "" : "lb-name-link" )" onclick="@(() => OpenPlayerProfile( lp.PlayerTag, RestoreMpView ))">@MpDisplayName( lp.PlayerTag, lp.Username )</div></div>
					}
					<div class="loading-msg">@( mp.LobbyPublic ? "Public match — waiting for players…" : "Waiting for players…" )</div>
				}
				@if ( mp?.Error != null )
				{
					<div class="status msg-error">@mp.Error</div>
				}
			</div>
		}
		else if ( _view == MenuView.MpWaiting )
		{
			var mp = MultiplayerController.Instance;
			<div class="screen subscreen">
				<div class="nav-bar">
					<div class="back-btn @( IsFocused(1) ? "focused" : "" )" onclick="@MpCancel">← Back</div>
					<div class="screen-title">MATCH FOUND</div>
				</div>
				<div class="label" style="margin-top:16px;">YOUR COLOR@( mp?.MyColors?.Length > 1 ? "S" : "" )</div>
				<div class="input-row" style="gap:10px;margin-top:4px;">
					@if ( mp?.MyColors != null )
					{
						@foreach ( var cid in mp.MyColors )
						{
							<div style="width:26px;height:26px;border-radius:50%;background-color:@MpColorHex(cid);"></div>
						}
					}
				</div>
				<div class="loading-msg">@mp?.LobbyMax players matched</div>
				@if ( mp?.RoomPlayers != null )
				{
					@foreach ( var rp in mp.RoomPlayers )
					{
						var ready = mp.ReadyIds.Contains( rp.PlayerTag );
						<div class="mp-player-row">
							@foreach ( var cid in rp.Colors ?? new[] { rp.Color } )
							{
								<div style="width:14px;height:14px;border-radius:50%;background-color:@MpColorHex(cid);"></div>
							}
							<div class="mp-player-name @( string.IsNullOrEmpty( rp.PlayerTag ) ? "" : "lb-name-link" )" onclick="@(() => OpenPlayerProfile( rp.PlayerTag, RestoreMpView ))">@MpDisplayName( rp.PlayerTag, rp.Username )</div>
							<div class="mp-player-ready @( ready ? "is-ready" : "" )">@( ready ? "✓ ready" : "…" )</div>
						</div>
					}
				}
				@if ( mp?.SentReady == true )
				{
					<div class="mode-btn primary disabled" style="width:200px;margin-top:12px;">Waiting…</div>
				}
				else
				{
					<div class="mode-btn primary" style="width:200px;margin-top:12px;" onclick="@MpReady">Ready</div>
				}
			</div>
		}
		else if ( _view == MenuView.Profile )
		{
			<div class="screen subscreen">
				<div class="nav-bar">
					<div class="back-btn @( IsFocused(4) ? "focused" : "" )" onclick="@BackToMain">← Back</div>
					<div class="screen-title">PROFILE</div>
				</div>

				<div class="profile-section">
					<div class="label">USERNAME</div>
					@if ( !string.IsNullOrEmpty( _profileUsername ) )
					{
						<div class="current-value">@_profileUsername</div>
					}
					<div class="input-row">
						<TextEntry @ref="_nameEntry" placeholder="New username" class="text-input" />
						<div class="action-btn" onclick="@SaveUsername">Save</div>
					</div>
					@if ( _saveMsg != null )
					{
						<div class="status @( _saveFailed ? "msg-error" : "msg-ok" )">@_saveMsg</div>
					}
				</div>

				<div class="profile-section">
					<div class="label">PLAYER ID</div>
					<div class="input-row">
						<div class="guid-box">@_profileGuid</div>
						<div class="action-btn" onclick="@CopyGuid">@_copyLabel</div>
					</div>
					<div class="input-row">
						<TextEntry @ref="_guidEntry" placeholder="Paste ID from the web client" class="text-input" />
						<div class="action-btn" onclick="@ImportGuid">Import</div>
					</div>
					@if ( _importMsg != null )
					{
						<div class="status @( _importFailed ? "msg-error" : "msg-ok" )">@_importMsg</div>
					}
				</div>

				<div class="profile-section">
					<div class="label">COLOR SCHEME</div>
					<div class="scheme-row">
						@{ int _si = 0; }
						@foreach ( var s in _schemeOptions )
						{
							var key = s.Key;
							var si  = _si++;
							<div class="scheme-card @( _profileScheme == key ? "active" : "" ) @( IsFocused(si) ? "focused" : "" )"
							     onclick="@(() => SetScheme( key ))">
								<div class="swatches">
									@foreach ( var hex in s.Swatches )
									{
										<div class="dot" style="background-color: @hex;"></div>
									}
								</div>
								<div class="scheme-label">@key</div>
							</div>
						}
					</div>
				</div>
			</div>
		}
		else if ( _view == MenuView.Feedback )
		{
			<div class="screen subscreen">
				<div class="nav-bar">
					<div class="back-btn" onclick="@BackToMain">← Back</div>
					<div class="screen-title">FEEDBACK</div>
				</div>
				<div class="profile-section">
					<div class="label">MESSAGE</div>
					<TextEntry @ref="_feedbackEntry" placeholder="Tell us anything… (max 2000 chars)" class="text-input feedback-entry" multiline="true" />
					@if ( _feedbackMsg != null )
					{
						<div class="status @( _feedbackFailed ? "msg-error" : "msg-ok" )">@_feedbackMsg</div>
					}
					<div class="action-btn" style="align-self:flex-end;" onclick="@SendFeedback">Send Feedback</div>
				</div>
			</div>
		}
		else if ( _view == MenuView.Settings )
		{
			<div class="screen subscreen">
				<div class="nav-bar">
					<div class="back-btn @( IsFocused(1) ? "focused" : "" )" onclick="@BackToMain">← Back</div>
					<div class="screen-title">SETTINGS</div>
				</div>

				<div class="settings-section">
					<div class="label">CABINET (% OF DEFAULT)</div>
					<div class="bind-row">
						<div class="bind-label">Cube size</div>
						<div class="slider-track">
							@for ( int p = 75; p <= 125; p += 5 )
							{
								int pct = p;
								<div class="slider-tick @( CubeSizePct >= pct ? "filled" : "" )" onclick="@(() => CubeSizePct = pct)"></div>
							}
						</div>
						<div class="slider-value">@(CubeSizePct)%</div>
					</div>
					<div class="bind-row">
						<div class="bind-label">Camera backoff</div>
						<div class="slider-track">
							@for ( int p = 0; p <= 1000; p += 100 )
							{
								int pct = p;
								<div class="slider-tick @( CameraBackoffPct >= pct ? "filled" : "" )" onclick="@(() => CameraBackoffPct = pct)"></div>
							}
						</div>
						<div class="slider-value">@(CameraBackoffPct)%</div>
					</div>
					<div class="bind-row">
						<div class="bind-label">Camera rise</div>
						<div class="slider-track">
							@for ( int p = 0; p <= 1000; p += 100 )
							{
								int pct = p;
								<div class="slider-tick @( CameraRisePct >= pct ? "filled" : "" )" onclick="@(() => CameraRisePct = pct)"></div>
							}
						</div>
						<div class="slider-value">@(CameraRisePct)%</div>
					</div>
				</div>

				<div class="settings-section">
					<div class="label">KEYBINDINGS</div>
					<div class="bind-row bind-head">
						<div class="bind-label"></div>
						<div class="bind-col-head bind-col-kb">Keyboard</div>
						<div class="bind-col-head bind-col-pad">Controller</div>
					</div>
					@foreach ( var entry in _bindableActions )
					{
						var action = entry.Action;
						bool kbListening  = _rebindingAction == action && !_rebindingController;
						bool padListening = _rebindingAction == action && _rebindingController;
						<div class="bind-row">
							<div class="bind-label">@entry.Label</div>
							<div class="bind-col bind-col-kb">
								<div class="bind-key @( kbListening ? "bind-key-listening" : "" )">
									@( kbListening ? "Press a key\u2026" : GetKeyboardDisplay( action ) )
								</div>
								<div class="action-btn bind-btn" onclick="@(() => ToggleRebind( action ))">
									@( kbListening ? "Cancel" : "Rebind" )
								</div>
							</div>
							<div class="bind-col bind-col-pad">
								<div class="bind-key @( padListening ? "bind-key-listening" : "" )">
									@( padListening ? "Press a button\u2026" : GetGamepadDisplay( action ) )
								</div>
								<div class="action-btn bind-btn" onclick="@(() => ToggleRebindController( action ))">
									@( padListening ? "Cancel" : "Rebind" )
								</div>
							</div>
						</div>
					}
				</div>

				<div class="action-btn @( IsFocused(0) ? "focused" : "" )" style="margin-top:8px;" onclick="@ResetBindings">Reset to Defaults</div>
			</div>
		}
		@* CRT dressing over whatever view is up — scanlines + vignette, no input *@
		<div class="crt-scan"></div>
		<div class="crt-vignette"></div>
	}
	</div>
</root>

<style>
	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	// confines the UI to the cabinet-screen region (transform: scale misplaces
	// content, so it's an explicitly sized box)
	.arcade-fit {
		// left/top/width/height come from ArcadeRing.UiRectStyle() inline
		position: absolute;
		pointer-events: none;
	}

	.screen {
		width: 100%;
		height: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 34px;
		// translucent so the cabinet's lit glass slab shows through (#33)
		background-color: rgba(7, 5, 26, 0.55);
		border-radius: 18px;
		pointer-events: all;
	}

	.subscreen {
		justify-content: flex-start;
		padding-top: 24px;
		gap: 16px;
	}

	// CRT dressing over the whole screen rect — emissive content only, no input
	.crt-scan {
		position: absolute;
		left: 0px; top: 0px; right: 0px; bottom: 0px;
		background-image: linear-gradient(rgba(2, 1, 10, 0.45), rgba(2, 1, 10, 0));
		background-size: 100% 5px;
		background-repeat: repeat;
		border-radius: 18px;
		pointer-events: none;
		animation-name: crt-flicker;
		animation-duration: 3.7s;
		animation-iteration-count: infinite;
	}

	.crt-vignette {
		position: absolute;
		left: 0px; top: 0px; right: 0px; bottom: 0px;
		background-image: radial-gradient(rgba(7, 5, 26, 0), rgba(2, 1, 12, 0.55));
		background-size: 100% 100%;
		background-repeat: no-repeat;
		border-radius: 18px;
		pointer-events: none;
	}

	@@keyframes crt-flicker {
		0% { opacity: 1; }
		50% { opacity: 0.82; }
		100% { opacity: 1; }
	}

	/* ── Main ── */

	.title {
		font-size: 62px;
		font-weight: bold;
		color: white;
		letter-spacing: 8px;
		text-shadow: 0px 0px 18px rgba(255, 255, 255, 0.9);
	}

	.modes {
		display: flex;
		flex-direction: column;
		gap: 15px;
		align-items: center;
	}

	.secondary-row {
		display: flex;
		flex-direction: row;
		gap: 12px;
	}

	.mode-btn {
		text-align: center;
		border-radius: 8px;
		cursor: pointer;
		transition: background-color 0.12s;
		pointer-events: all;
	}

	.mode-btn.primary {
		width: 350px;
		padding: 18px 0px;
		font-size: 26px;
		color: white;
		background-color: rgba(255,255,255,0.08);
	}

	.mode-btn.secondary {
		width: 168px;
		padding: 13px 0px;
		font-size: 19px;
		color: white;
		background-color: rgba(255,255,255,0.08);
	}

	.mode-btn.danger {
		width: 350px;
		padding: 13px 0px;
		font-size: 18px;
		color: #ff2d55;
		background-color: rgba(255,45,85,0.12);
		margin-top: 4px;
	}

	.mp-row {
