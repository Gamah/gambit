	static bool CanDeleteGuid => string.IsNullOrEmpty( PlayerData.Load()?.LinkedSteamId );

	void SetMainNav()
	{
		var nav = new List<Action>
		{
			() => Play( GameMode.Daily ),    // 0
			() => Play( GameMode.Hourly ),   // 1
			() => Play( GameMode.Freeplay ), // 2
			() => PlayMultiplayer( false ),  // 3
			() => PlayMultiplayer( true ),   // 4
			OpenProfile,                     // 5
			OpenSettings,                    // 6
			OpenFeedback,                    // 7
		};
		if ( CanDeleteGuid ) nav.Add( DeleteGuid ); // 8
		SetNav( nav.ToArray() );
	}

	void DeleteGuid()
	{
		_visible = false;
		StateHasChanged();
		PlayerData.ClearIdentity(); // SplashScreen re-shows enrollment via OnIdentityCleared
	}

	void BackToMain()
	{
		_view = MenuView.Main;
		SetMainNav();
		StateHasChanged();
	}

	// ── Main view ──

	async void Play( GameMode mode )
	{
		_visible = false;
		StateHasChanged();
		var ctrl = GameController.Instance;
		if ( ctrl == null ) return;
		await ctrl.StartGame( mode );
	}

	async void PlayMultiplayer( bool is2p )
	{
		var mpCtrl = MultiplayerController.Instance
			?? GameObject.Components.GetOrCreate<MultiplayerController>();
		mpCtrl.OnStateChanged -= OnMpStateChanged;
		mpCtrl.OnStateChanged += OnMpStateChanged;
		_mpJoinEntryInit = false;
		_mpCopyLabel     = "copy";
		_openLobbies     = null;
		_view            = MenuView.MpLobby;
		SetNav( MpCancel ); // connecting view: Back only; browse nav installed on Lobby state
		StateHasChanged();
		_ = RefreshOpenLobbies( is2p ? 2 : 4 );
