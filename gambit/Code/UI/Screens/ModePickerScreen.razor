	// ArcadeRing tuning sliders (issue #15) — segmented click-track storing percent
	// of the scene default as a 0.75–1.25 multiplier. Cube size applies on the next
	// board slide-out (CubeBoardView.ComputeGeometry); camera values apply live.

	int CubeSizePct
	{
		get => (int)MathF.Round( (PlayerData.Load()?.CubeSizeScale ?? 1f) * 100f );
		set
		{
			var data = PlayerData.Load() ?? new PlayerData();
			data.CubeSizeScale = PlayerData.ClampScale( value / 100f );
			data.Save();
			StateHasChanged();
		}
	}

	int CameraBackoffPct
