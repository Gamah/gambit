			var data = PlayerData.Load() ?? new PlayerData();
			data.CameraBackoffScale = PlayerData.ClampCameraScale( value / 100f );
			data.Save();
			StateHasChanged();
		}
	}

	int CameraRisePct
	{
		get => (int)MathF.Round( (PlayerData.Load()?.CameraRiseScale ?? 1f) * 100f );
		set
