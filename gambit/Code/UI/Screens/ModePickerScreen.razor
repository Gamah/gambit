	void ToggleRebind( string action )
	{
		bool same = _rebindingAction == action && !_rebindingController;
		_rebindingAction     = same ? null : action;
		_rebindingController = false;
		StateHasChanged();
	}

	void ToggleRebindController( string action )
	{
		bool same = _rebindingAction == action && _rebindingController;
		_rebindingAction     = same ? null : action;
		_rebindingController = !same;
		StateHasChanged();
	}

	void CommitBinding( string action, string key )
	{
		var data = PlayerData.Load() ?? new PlayerData();
		data.Bindings[action] = key;
		data.Save();
		_bindingsVersion++;
	}

	void CommitGamepadBinding( string action, string probe )
	{
		var data = PlayerData.Load() ?? new PlayerData();
		data.GamepadBindings[action] = probe;
		data.Save();
		_bindingsVersion++;
	}

	void ResetBindings()
	{
		var data = PlayerData.Load();
		if ( data == null ) return;
		data.Bindings.Clear();
		data.GamepadBindings.Clear();
		data.Save();
		_bindingsVersion++;
		_rebindingAction = null;
		_rebindingController = false;
		StateHasChanged();
	}

	static string GetKeyboardDisplay( string action )
	{
		var data = PlayerData.Load();
		if ( data?.Bindings != null && data.Bindings.TryGetValue( action, out var key ) && !string.IsNullOrEmpty( key ) )
			return KeyDisplayName( key );
		return action switch
		{
			"MoveUp"    => "↑",
			"MoveDown"  => "↓",
			"MoveLeft"  => "←",
			"MoveRight" => "→",
			"RotateCCW" => "Z",
			"RotateCW"  => "X",
			"Chat"      => "T",
			_           => "?",
		};
	}

	/// <summary>The controller button currently mapped to an action (rebindable via
	/// the per-button probe actions — see <see cref="GamepadBinds"/>).</summary>
	static string GetGamepadDisplay( string action ) => GamepadBinds.DisplayFor( action );

	static string KeyDisplayName( string key ) => key switch
	{
		"UPARROW"   => "↑",
		"DOWNARROW" => "↓",
		"LEFTARROW" => "←",
		"RIGHTARROW" => "→",
		"SPACE"     => "Space",
		"ENTER"     => "Enter",
		"BACKSPACE" => "Backspace",
		"TAB"       => "Tab",
		"SEMICOLON" => ";",
		"KP_0"      => "Num 0",
		"KP_1"      => "Num 1",
		"KP_2"      => "Num 2",
		"KP_3"      => "Num 3",
		"KP_4"      => "Num 4",
		"KP_5"      => "Num 5",
		"KP_6"      => "Num 6",
		"KP_7"      => "Num 7",
		"KP_8"      => "Num 8",
		"KP_9"      => "Num 9",
		_           => key.Length == 1 ? key.ToUpper() : key,
	};

	protected override int BuildHash()
	{
		var h = new System.HashCode();
		h.Add( _visible );      h.Add( (int)_view );
		h.Add( _lbDaily );      h.Add( _lbTime );    h.Add( _lbPuzzleIdx );
		h.Add( _lb?.Count );    h.Add( _lbLoading );  h.Add( _recentLoading );
		h.Add( _lbMp );         h.Add( _lbMp2p );
		h.Add( _mpLb2p?.Count ); h.Add( _mpLb4p?.Count ); h.Add( _mpLbLoading );
		h.Add( _saveMsg );      h.Add( _copyLabel );  h.Add( _profileScheme );
		h.Add( _feedbackMsg );
		h.Add( _ppLoading );    h.Add( _ppError );    h.Add( _ppProfile?.PlayerTag );
		h.Add( _ppProfile?.Games?.Count );
		var mp = MultiplayerController.Instance;
		h.Add( mp?.State ); h.Add( mp?.LobbyCode ); h.Add( mp?.LobbyCount ); h.Add( mp?.Error ); h.Add( _mpCopyLabel );
		h.Add( mp?.LobbyPlayers?.Count ); h.Add( mp?.RoomPlayers?.Count ); h.Add( mp?.ReadyIds?.Count ); h.Add( mp?.SentReady );
		h.Add( _openLobbiesVersion );
		h.Add( _rebindingAction ); h.Add( _rebindingController ); h.Add( _bindingsVersion );
		h.Add( ArcadeStation.Active != null );
		h.Add( Gambit.World.LobbyPlayer.Local?.CameraSettled );
		h.Add( Gambit.World.ArcadeRing.UiRectStyle() );
		h.Add( _navIdx );
		h.Add( CanDeleteGuid );
		return h.ToHashCode();
	}
