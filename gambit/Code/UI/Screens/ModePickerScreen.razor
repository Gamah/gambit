	void OnMpStateChanged()
	{
		var mp = MultiplayerController.Instance;
		if ( mp == null ) return;
		switch ( mp.State )
		{
			case MpState.Lobby:
				// Nav follows the rendered view: full browse nav while picking, Back
				// only once in a lobby — Enter can't fire hidden create/join buttons
				if ( _view == MenuView.MpLobby )
				{
					if ( mp.LobbyCode == null )
						SetNav( MpCancel, () => MpCreate( true ), () => MpCreate( false ), MpJoin, MpRefreshOpen ); // 0: Back, 1: Public, 2: Private, 3: Join, 4: Refresh
					else
						SetNav( MpCancel ); // 0: Back
				}
				break;
			case MpState.WaitingRoom: _view = MenuView.MpWaiting; SetNav( MpReady, MpCancel ); break; // 0: Ready, 1: Back
			case MpState.Playing:
			case MpState.GameOver:    _visible = false; break;
