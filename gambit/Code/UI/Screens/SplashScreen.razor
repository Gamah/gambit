@using System;
@using Sandbox;
@using Sandbox.UI;
@using Gambit.Api;
@using Gambit.Game;
@using Gambit.World;
@namespace Gambit.UI.Screens
@inherits PanelComponent

<root>
	<div class="arcade-fit" style="@Gambit.World.ArcadeRing.UiRectStyle()">
	@if ( _show && ArcadeStation.Active != null && ( Gambit.World.LobbyPlayer.Local?.CameraSettled ?? true ) )
	{
		<div class="splash">
			<div class="title">Welcome to ROTALIATE</div>
			<div class="subtitle">Choose a display name</div>
			<div class="name-row">
				<TextEntry @ref="_nameEntry" placeholder="Username" class="name-input" />
				<div class="reroll-btn" onclick="@Reroll">⟳</div>
			</div>
			@if ( !string.IsNullOrEmpty( _error ) )
			{
				<div class="error-msg">@_error</div>
			}
			<div class="confirm-btn" onclick="@Confirm">Let's Go</div>
			<div class="crt-scan"></div>
			<div class="crt-vignette"></div>
		</div>
	}
	</div>
</root>

<style>
	root {
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	// confines the UI to the cabinet-screen region (transform: scale misplaces
	// content, so it's an explicitly sized box)
	.arcade-fit {
		// left/top/width/height come from ArcadeRing.UiRectStyle() inline
		position: absolute;
		pointer-events: none;
	}

	.splash {
		width: 100%;
		height: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		// translucent so the cabinet's lit glass slab shows through (#33)
		background-color: rgba(7, 5, 26, 0.55);
		border-radius: 18px;
		gap: 30px;
		pointer-events: all;
	}

	.title {
		font-size: 52px;
		color: white;
		font-weight: bold;
		letter-spacing: 6px;
		text-shadow: 0px 0px 18px rgba(255, 255, 255, 0.9);
	}

	// CRT dressing — emissive overlay only, no input
	.crt-scan {
		position: absolute;
		left: 0px; top: 0px; right: 0px; bottom: 0px;
		background-image: linear-gradient(rgba(2, 1, 10, 0.45), rgba(2, 1, 10, 0));
		background-size: 100% 5px;
		background-repeat: repeat;
		border-radius: 18px;
		pointer-events: none;
		animation-name: crt-flicker;
		animation-duration: 3.7s;
		animation-iteration-count: infinite;
	}

	.crt-vignette {
		position: absolute;
		left: 0px; top: 0px; right: 0px; bottom: 0px;
		background-image: radial-gradient(rgba(7, 5, 26, 0), rgba(2, 1, 12, 0.55));
		background-size: 100% 100%;
		background-repeat: no-repeat;
		border-radius: 18px;
		pointer-events: none;
	}

	@@keyframes crt-flicker {
		0% { opacity: 1; }
		50% { opacity: 0.82; }
		100% { opacity: 1; }
	}

	.subtitle {
		font-size: 23px;
		color: rgba(255,255,255,0.6);
	}

	.error-msg {
		font-size: 18px;
		color: #ff2d55;
	}

	.name-row {
		flex-direction: row;
		align-items: center;
		gap: 10px;
		pointer-events: all;
	}

	.reroll-btn {
		padding: 15px 18px;
		background-color: rgba(255,255,255,0.1);
		color: white;
		font-size: 23px;
		border-radius: 8px;
		border: 1px solid rgba(255,255,255,0.2);
		cursor: pointer;
		pointer-events: all;
	}

	.name-input {
		width: 370px;
		padding: 15px 20px;
		background-color: rgba(255,255,255,0.1);
		color: white;
		font-size: 23px;
		border-radius: 8px;
		border: 1px solid rgba(255,255,255,0.2);
		pointer-events: all;
	}

	.confirm-btn {
		width: 270px;
		padding: 15px 0px;
		text-align: center;
		background-color: #ff2d55;
		color: white;
		font-size: 23px;
		border-radius: 8px;
		cursor: pointer;
		pointer-events: all;
	}
</style>

@code
{
	public static Action OnPlayerReady;

	bool _show;
	bool _recovering;    // SteamID→GUID recovery in flight (issue #71); gates enrollment
	string _error;
	string _pendingGuid; // created player kept across failed name attempts
	string _lastBackend; // detect host-driven LIVE/TEST switches (per-backend identity)
	TextEntry _nameEntry;
	bool _nameEntryInit;

	// Username is mandatory — pre-fill a generated suggestion (adjective + noun +
	// 2 digits, matching the web frontend) so the entry is never empty.
	static readonly string[] _adjectives =
	{
		"Swift", "Bold", "Clever", "Lucky", "Mighty", "Sneaky", "Cosmic", "Turbo",
		"Shiny", "Wild", "Quiet", "Rapid", "Brave", "Neon", "Frosty", "Atomic",
	};
	static readonly string[] _nouns =
	{
		"Rotator", "Puzzler", "Block", "Spinner", "Pixel", "Cube", "Comet", "Falcon",
		"Wizard", "Rocket", "Badger", "Otter", "Vortex", "Knight", "Gizmo", "Nova",
	};

	static string SuggestName()
	{
		var r = Random.Shared;
		return $"{_adjectives[r.Next( _adjectives.Length )]}{_nouns[r.Next( _nouns.Length )]}{r.Next( 10, 100 )}";
	}

	void Reroll()
	{
		if ( _nameEntry != null ) _nameEntry.Text = SuggestName();
	}

	protected override void OnStart()
	{
		PlayerData.OnIdentityCleared += OnIdentityCleared;

		var data = PlayerData.Load();
		_lastBackend = ApiClient.BaseUrl;

		if ( data?.Guid != null )
		{
			_show = false;
			OnPlayerReady?.Invoke();
		}
		else
		{
			// No stored GUID: try to recover an existing account from the SteamID
			// (issue #71) before falling through to manual enrollment.
			BeginRecovery();
		}

		StateHasChanged();
	}

	/// <summary>Attempt SteamID→GUID account recovery (issue #71). On success, store the
	/// identity and proceed as if a GUID had been found; otherwise show enrollment. Bails
	/// without touching state if the host switched backends mid-flight.</summary>
	async void BeginRecovery()
	{
		if ( _recovering ) return;
		_recovering = true;
		var backend = ApiClient.BaseUrl;
		try
		{
			var rec = await ApiClient.RecoverBySteamId();
			if ( backend != ApiClient.BaseUrl ) return; // backend switched — stale result

			if ( rec != null && !string.IsNullOrEmpty( rec.Guid ) )
			{
				var data = PlayerData.Load() ?? new PlayerData();
				data.Guid          = rec.Guid;
				data.Username      = rec.Username ?? "";
				data.PlayerTag     = rec.PlayerTag ?? "";
				// This account is linked to our SteamID (that's how we found it), so record
				// it — no link/token needed on the first cabinet entry (issue #71).
				data.LinkedSteamId = rec.SteamId ?? "";
				data.Save();

				_recovering = false;
				_show = false;
				OnPlayerReady?.Invoke();
				StateHasChanged();
				return;
			}
		}
		catch ( Exception e )
		{
			Log.Warning( $"[Gambit] SteamID recovery error: {e.Message}" );
			if ( backend != ApiClient.BaseUrl ) return;
		}

		// No account recovered — fall through to manual enrollment.
		_recovering = false;
		if ( PlayerData.Load()?.Guid == null ) ShowEnrollment();
	}

	protected override void OnDestroy()
	{
		PlayerData.OnIdentityCleared -= OnIdentityCleared;
	}

	/// <summary>Identity was deleted — re-run the launch auth flow (SteamID recovery) so a
	/// Steam-linked account is silently re-established and the cabinet gets its GUID back
	/// without dumping the player into a confusing re-enrollment. Only a player with no
	/// recoverable account (web/non-Steam) falls through to manual enrollment.</summary>
	void OnIdentityCleared()
	{
		_show        = false;
		_pendingGuid = null;
		_recovering  = false;
		BeginRecovery();
		StateHasChanged();
	}

	void ShowEnrollment()
	{
		_show = true;
		_nameEntryInit = false;
		StateHasChanged();
	}

	protected override void OnUpdate()
	{
		// The host can switch the target backend (LIVE/TEST) mid-session; identity is
		// per-backend, so re-show enrollment when we land on an instance we have no
		// identity for, and hide it once we do.
		if ( _lastBackend != ApiClient.BaseUrl )
		{
			_lastBackend = ApiClient.BaseUrl;
			_pendingGuid = null; // belonged to the previous backend
			_recovering  = false; // any in-flight recovery targeted the old backend
			if ( PlayerData.Load()?.Guid != null )
			{
				if ( _show ) { _show = false; OnPlayerReady?.Invoke(); StateHasChanged(); }
			}
			else
			{
				// Try SteamID recovery on the new backend before enrolling (issue #71).
				_show = false;
				BeginRecovery();
				StateHasChanged();
			}
		}

		// TextEntry ref only exists once the splash has rendered — seed the suggestion then
		if ( _show && !_nameEntryInit && _nameEntry != null )
		{
			_nameEntry.Text = SuggestName();
			_nameEntryInit  = true;
		}
	}

	async void Confirm()
	{
		var username = _nameEntry?.Text?.Trim();
		if ( string.IsNullOrEmpty( username ) )
		{
			_error = "Pick a display name first.";
			StateHasChanged();
			return;
		}

		try
		{
			_pendingGuid ??= ( await ApiClient.CreatePlayer() ).Guid;
			var resp = await ApiClient.SetUsername( _pendingGuid, username );

			// Load-or-create: a second instance's enrollment must keep the first
			// instance's identity and all shared settings (per-backend identity).
			var data = PlayerData.Load() ?? new PlayerData();
			data.Guid      = _pendingGuid;
			data.Username  = username;
			data.PlayerTag = resp?.PlayerTag ?? "";
			data.Save();

			_pendingGuid = null;
			_error = null;
			_show = false;
			StateHasChanged();
			OnPlayerReady?.Invoke();
		}
		catch ( Exception e )
		{
			Log.Warning( $"[Gambit] SplashScreen error: {e.Message}" );
			_error = e.Message;
			// 409 — name collision: suggest a fresh one so the next try can succeed
			if ( e.Message?.Contains( "taken" ) == true ) Reroll();
			StateHasChanged();
		}
	}

	protected override int BuildHash() =>
		System.HashCode.Combine( _show, _error, ArcadeStation.Active != null, Gambit.World.LobbyPlayer.Local?.CameraSettled,
			Gambit.World.ArcadeRing.UiRectStyle() );
}
