@using System
@using Sandbox
@using Sandbox.UI
@using Gambit.Game
@namespace Gambit.UI
@inherits PanelComponent

@*
	The giant spectator board floating over the west wall (PLAN.md M5). Display-only WorldPanel —
	no pointer input (the channel picker is the separate engaged SpectatorScreen). Renders
	the SpectatorController's current FEN as a 2D Unicode-glyph board, plus the two player
	names and a status line. Fixed px sizing (deriving from Box.Rect on a WorldPanel
	doesn't work — CLAUDE.md); the WorldPanel GO scale sets the world size.
*@

<root>
	@{
		var c = SpectatorController.Instance;
	}
	<div class="frame">
		<div class="head">@( c?.ChannelLabel ?? "SPECTATE" )</div>

		<div class="names">
			<div class="pname">♔ @( c?.WhiteName ?? "White" )</div>
			<div class="pname">♚ @( c?.BlackName ?? "Black" )</div>
		</div>

		<div class="board">
			@{
				var squares = Placement( c?.Fen );
				(int fromSq, int toSq) = LastMove( c?.LastMoveUci );
			}
			@for ( int r = 7; r >= 0; r-- )
			{
				<div class="rankrow">
					@for ( int f = 0; f < 8; f++ )
					{
						int sq = r * 8 + f;
						bool light = ( ( f + r ) & 1 ) == 1;
						bool moved = sq == fromSq || sq == toSq;
						char pc = squares[sq];
						<div class="cell @( light ? "light" : "dark" ) @( moved ? "moved" : "" )">
							@if ( pc != '\0' )
							{
								<div class="piece @( char.IsUpper( pc ) ? "w" : "b" )" style="background-position:@( PieceIndex( pc ) * 20 )% 0%;"></div>
							}
						</div>
					}
				</div>
			}
		</div>

		@if ( !string.IsNullOrEmpty( c?.StatusText ) )
		{
			<div class="status">@c.StatusText</div>
		}
	</div>
</root>

<style>
	root {
		width: 720px;
		height: 820px;
		justify-content: center;
		align-items: center;
		font-family: "Segoe UI", "DejaVu Sans", sans-serif;
	}

	.frame {
		flex-direction: column;
		align-items: center;
		width: 700px;
		padding: 16px;
		gap: 8px;
		background-color: rgba(8, 8, 12, 0.92);
		border-radius: 14px;
		border: 2px solid rgba(255, 255, 255, 0.10);
	}

	.head {
		font-size: 24px;
		letter-spacing: 4px;
		font-weight: bold;
		color: rgba(255, 255, 255, 0.7);
	}

	.names {
		flex-direction: row;
		justify-content: space-between;
		width: 576px;
	}
	.pname { font-size: 20px; color: rgba(255, 255, 255, 0.85); }

	.board {
		flex-direction: column;
		width: 576px;
		height: 576px;
		border: 3px solid rgba(0, 0, 0, 0.8);
	}
	.rankrow { flex-direction: row; height: 72px; }

	.cell {
		width: 72px;
		height: 72px;
		justify-content: center;
		align-items: center;
		overflow: hidden;
	}
	.cell.light { background-color: #ededed; }
	.cell.dark { background-color: #2b2b2b; }
	.cell.moved.light { background-color: #c7d16a; }
	.cell.moved.dark { background-color: #6f7a2f; }

	/* Pieces are drawn from our own monochrome CC0 glyph atlas (the same
	   Assets/textures/chess_glyphs.png the floor pops use), NOT the Unicode chess
	   characters — s&box renders the pawn codepoint (U+265F) as a colour EMOJI (it came
	   out purple regardless of `color`), while the atlas is a plain white silhouette we
	   tint per side. 6 cells wide (King Queen Rook Bishop Knight Pawn); background-position
	   selects the piece (set inline). */
	.piece {
		width: 72px;
		height: 72px;
		background-image: url( "textures/chess_glyphs.png" );
		background-repeat: no-repeat;
		background-size: 600% 100%;
	}
	/* Tint the white silhouette to the side colour and outline it in the opposite colour
	   (drop-shadow follows the alpha shape) so a piece reads on either square colour. */
	.piece.w {
		background-image-tint: #ffffff;
		filter: drop-shadow( 0px 0px 2px #000 ) drop-shadow( 0px 0px 1px #000 );
	}
	.piece.b {
		background-image-tint: #0b0b0b;
		filter: drop-shadow( 0px 0px 2px #fff ) drop-shadow( 0px 0px 1px #fff );
	}

	.status {
		font-size: 17px;
		color: rgba(255, 255, 255, 0.5);
		text-align: center;
		width: 576px;
	}
</style>

@code
{
	const string StartPlacement = "rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR";

	/// <summary>FEN placement field → 64 chars indexed rank*8+file ('\0' = empty).</summary>
	static char[] Placement( string fen )
	{
		string placement = string.IsNullOrEmpty( fen ) ? StartPlacement
			: fen.IndexOf( ' ' ) is var s && s > 0 ? fen[..s] : fen;

		var squares = new char[64];
		int rank = 7, file = 0;
		foreach ( var ch in placement )
		{
			if ( ch == '/' ) { rank--; file = 0; }
			else if ( char.IsDigit( ch ) ) file += ch - '0';
			else if ( file < 8 && rank >= 0 )
				squares[rank * 8 + file++] = ch;
		}
		return squares;
	}

	static (int from, int to) LastMove( string uci )
	{
		if ( uci is not { Length: >= 4 } ) return (-1, -1);
		int from = Square( uci[0], uci[1] );
		int to = Square( uci[2], uci[3] );
		return (from, to);
	}

	static int Square( char file, char rank )
	{
		if ( file is < 'a' or > 'h' || rank is < '1' or > '8' ) return -1;
		return ( rank - '1' ) * 8 + ( file - 'a' );
	}

	/// <summary>0-based cell index into chess_glyphs.png for a FEN char, matching the atlas
	/// order (King Queen Rook Bishop Knight Pawn — see scripts/gen_glyph_atlas.py). Drives
	/// the piece div's background-position; the side (upper/lower case) drives the tint.</summary>
	static int PieceIndex( char fenChar ) => char.ToLowerInvariant( fenChar ) switch
	{
		'k' => 0,
		'q' => 1,
		'r' => 2,
		'b' => 3,
		'n' => 4,
		'p' => 5,
		_ => 0,
	};

	protected override int BuildHash()
	{
		var c = SpectatorController.Instance;
		return System.HashCode.Combine( c?.Fen, c?.LastMoveUci, c?.WhiteName, c?.BlackName,
			c?.ChannelLabel, c?.StatusText );
	}
}
