# Root keeps only genuinely repo-wide entries. The two halves ignore their own
# build output: client/.gitignore (s&box) and server/.gitignore (Go).
#
# Nothing here may be unanchored build-output junk (bin/, obj/, *_c): those match
# at any depth and would silently swallow the server's build output.

# IDE
.vs/
.vscode/
*.user
*.suo

# OS
.DS_Store
Thumbs.db

# Claude Code local settings (may contain secrets)
.claude/settings.local.json
